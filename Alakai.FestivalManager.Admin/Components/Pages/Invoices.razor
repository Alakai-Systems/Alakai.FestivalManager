@page "/invoices"
@using Alakai.FestivalManager.Admin.Contracts.Editions.DTOs

@inject InvoiceApiClient InvoiceApiClient
@inject EditionApiClient EditionApiClient

<PageHeader Title="Operations" pTitle="Invoices"></PageHeader>

<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)]">
    <div class="card">
        <div class="flex flex-col gap-4 mb-5 xl:flex-row xl:items-center xl:justify-between">
            <div class="flex flex-col gap-3 md:flex-row md:items-center">
                <input class="form-input md:w-72" placeholder="Search number, customer, email..." @bind="searchText" @bind:event="oninput" @bind:after="ResetPage" />

                <select class="form-select md:w-56" @bind="editionFilter" @bind:after="ResetPage">
                    <option value="">All editions</option>
                    @foreach (EditionDto edition in editions)
                    {
                        <option value="@edition.Id">@edition.Name</option>
                    }
                </select>

                <select class="form-select md:w-32" @bind="pageSize" @bind:after="ResetPage">
                    <option value="10">10 rows</option>
                    <option value="25">25 rows</option>
                    <option value="50">50 rows</option>
                </select>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">@errorMessage</div>
        }

        @if (isLoading)
        {
            <p class="text-sm text-black/50 dark:text-white/40">Loading invoices...</p>
        }
        else if (FilteredInvoices.Count == 0)
        {
            <p class="text-sm text-black/50 dark:text-white/40">No invoices found.</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full table-hover">
                    <thead class="bg-gray-50 dark:bg-dark">
                        <tr class="text-left">
                            <th class="px-3 py-3 font-semibold">Number</th>
                            <th class="px-3 py-3 font-semibold">Date</th>
                            <th class="px-3 py-3 font-semibold">Customer</th>
                            <th class="px-3 py-3 font-semibold">Edition</th>
                            <th class="px-3 py-3 font-semibold text-right">Base</th>
                            <th class="px-3 py-3 font-semibold text-right">VAT</th>
                            <th class="px-3 py-3 font-semibold text-right">Total</th>
                            <th class="px-3 py-3 font-semibold text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (InvoiceDto invoice in PagedInvoices)
                        {
                            <tr class="border-b border-black/10 dark:border-darkborder">
                                <td class="px-4 py-3">@invoice.Number</td>
                                <td class="px-3 py-3">@invoice.IssuedAt.ToString("dd/MM/yyyy")</td>
                                <td class="px-3 py-3">@invoice.CustomerFirstName @invoice.CustomerLastName</td>
                                <td class="px-3 py-3">@invoice.EditionName</td>
                                <td class="px-3 py-3 text-right">@invoice.BaseAmount.ToString("0.00") &euro;</td>
                                <td class="px-3 py-3 text-right">@invoice.VatAmount.ToString("0.00") &euro;</td>
                                <td class="px-3 py-3 text-right font-medium">@invoice.Amount.ToString("0.00") &euro;</td>
                                <td class="px-3 py-3 text-right">
                                    <a href="@invoice.PdfUrl" target="_blank" class="text-black dark:text-white/80" title="Download">
                                        <i class="ri-download-line text-lg"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between mt-4">
                <p class="text-sm text-black/50 dark:text-white/40">
                    Showing @StartRow to @EndRow of @FilteredInvoices.Count invoices
                </p>

                <div class="flex items-center gap-2">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                    <span class="flex items-center justify-center w-10 h-10 text-sm rounded-md bg-purple/10 text-purple">@currentPage</span>
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage >= TotalPages)" @onclick="NextPage">Next</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<InvoiceDto> invoices = [];
    private List<EditionDto> editions = [];
    private string searchText = string.Empty;
    private string editionFilter = string.Empty;
    private int pageSize = 10;
    private int currentPage = 1;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            invoices = (await InvoiceApiClient.GetAllAsync()).ToList();
            editions = (await EditionApiClient.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<InvoiceDto> FilteredInvoices
    {
        get
        {
            IEnumerable<InvoiceDto> query = invoices;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                string term = searchText.Trim();
                query = query.Where(i =>
                    i.Number.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    $"{i.CustomerFirstName} {i.CustomerLastName}".Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    (i.CustomerEmail ?? string.Empty).Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(editionFilter) && Guid.TryParse(editionFilter, out Guid editionId))
            {
                query = query.Where(i => i.EditionId == editionId);
            }

            return query.OrderByDescending(i => i.IssuedAt).ToList();
        }
    }

    private IEnumerable<InvoiceDto> PagedInvoices => FilteredInvoices.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredInvoices.Count / (double)pageSize));
    private int StartRow => FilteredInvoices.Count == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int EndRow => Math.Min(currentPage * pageSize, FilteredInvoices.Count);

    private void ResetPage()
    {
        currentPage = 1;
        NormalizePage();
    }

    private void NormalizePage()
    {
        if (currentPage > TotalPages)
        {
            currentPage = TotalPages;
        }

        if (currentPage < 1)
        {
            currentPage = 1;
        }
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
        }
    }
}