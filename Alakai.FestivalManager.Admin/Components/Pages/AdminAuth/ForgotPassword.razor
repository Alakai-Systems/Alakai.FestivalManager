@page "/forgot-password"
@layout AuthLayout
@attribute [AllowAnonymous]


<PageTitle>Admin - Forgot Password</PageTitle>

<div class="min-h-[calc(100vh-134px)] py-4 px-4 sm:px-12 flex justify-center items-center max-w-[1440px] mx-auto bg-light/60 dark:bg-dark">
    <div class="max-w-[550px] flex-none w-full bg-white border border-black/10 p-6 sm:p-10 lg:px-10 lg:py-14 rounded-2xl shadow-3xl shadow-black/10 dark:bg-darklight dark:border-darkborder">
        <MudText Typo="Typo.h1" Class="mb-2 text-2xl font-semibold text-center dark:text-white">Forgot your password?</MudText>
        <MudText Class="text-center text-muted mb-7 dark:text-darkmuted">Enter your admin email and instructions will be sent to you.</MudText>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">
                @Message
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">
                @ErrorMessage
            </div>
        }

        <EditForm Model="@FormModel" OnValidSubmit="@SubmitAsync">
            <DataAnnotationsValidator />

            <div class="grid grid-cols-1 gap-4">
                <div>
                    <InputText @bind-Value="FormModel.Email" placeholder="Email" type="email" class="form-input" />
                    <ValidationMessage For="@(() => FormModel.Email)" />
                </div>

                <button type="submit" disabled="@IsLoading" class="btn w-full py-3.5 text-base bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85] disabled:opacity-70">
                    @(IsLoading ? "Sending..." : "Email Password Reset Link")
                </button>
            </div>
        </EditForm>

        <MudText Class="mt-5 text-center">
            <MudLink Href="/login" Class="flex items-center justify-center gap-1 leading-none text-black dark:text-white">
                <i class="ri-home-4-line align-middle"></i>
                Back to login
            </MudLink>
        </MudText>
    </div>
</div>

@code {
    private ForgotPasswordFormModel FormModel { get; set; } = new();
    private bool IsLoading { get; set; }
    private string? Message { get; set; }
    private string? ErrorMessage { get; set; }

    private async Task SubmitAsync()
    {
        Message = null;
        ErrorMessage = null;
        IsLoading = true;

        try
        {
            string? message = await AuthApiClient.ForgotPasswordAsync(FormModel.Email);

            Message = string.IsNullOrWhiteSpace(message)
                ? "If the email exists, a password reset link has been sent."
                : message;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    [Inject]
    private IAuthApiClient AuthApiClient { get; set; } = default!;

    private class ForgotPasswordFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email address.")]
        public string Email { get; set; } = string.Empty;
    }
}