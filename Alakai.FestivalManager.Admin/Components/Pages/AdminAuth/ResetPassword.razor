@page "/reset-password"
@layout AuthLayout
@attribute [AllowAnonymous]

@using Alakai.FestivalManager.Admin.Components.Layout

<PageTitle>Admin - Reset Password</PageTitle>

<div class="min-h-[calc(100vh-134px)] py-4 px-4 sm:px-12 flex justify-center items-center max-w-[1440px] mx-auto bg-light/60 dark:bg-dark">
    <div class="max-w-[550px] flex-none w-full bg-white border border-black/10 p-6 sm:p-10 lg:px-10 lg:py-14 rounded-2xl shadow-3xl shadow-black/10 dark:bg-darklight dark:border-darkborder">
        <MudText Typo="Typo.h1" Class="mb-2 text-2xl font-semibold text-center dark:text-white">Reset your password</MudText>
        <MudText Class="text-center text-muted mb-7 dark:text-darkmuted">Choose a new password for your admin account.</MudText>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">
                @Message
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">
                @ErrorMessage
            </div>
        }

        <EditForm Model="@FormModel" OnValidSubmit="@ResetAsync">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="sm:col-span-2">
                    <InputText @bind-Value="FormModel.NewPassword" placeholder="New password" type="password" class="form-input" />
                </div>

                <div class="sm:col-span-2">
                    <InputText @bind-Value="FormModel.ConfirmPassword" placeholder="Confirm password" type="password" class="form-input" />
                </div>

                <button type="submit" disabled="@IsLoading" class="btn sm:col-span-2 w-full py-3.5 text-base bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85] disabled:opacity-70">
                    @(IsLoading ? "Saving..." : "Reset password")
                </button>
            </div>
        </EditForm>

        <MudText Class="mt-5 text-center">
            <MudLink Href="/login" Class="flex items-center justify-center gap-1 leading-none text-black dark:text-white">
                Back to login
            </MudLink>
        </MudText>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private ResetPasswordFormModel FormModel { get; set; } = new();
    private bool IsLoading { get; set; }
    private string? Message { get; set; }
    private string? ErrorMessage { get; set; }

    [Inject]
    private IAuthApiClient AuthApiClient { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private async Task ResetAsync()
    {
        Message = null;
        ErrorMessage = null;

        if (string.IsNullOrWhiteSpace(Token))
        {
            ErrorMessage = "Reset token is missing.";
            return;
        }

        if (FormModel.NewPassword != FormModel.ConfirmPassword)
        {
            ErrorMessage = "Passwords do not match.";
            return;
        }

        IsLoading = true;

        try
        {
            string? message = await AuthApiClient.ResetPasswordAsync(Token, FormModel.NewPassword, FormModel.ConfirmPassword);

            Message = string.IsNullOrWhiteSpace(message)
                ? "Password reset successfully."
                : message;

            FormModel.NewPassword = string.Empty;
            FormModel.ConfirmPassword = string.Empty;

            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private class ResetPasswordFormModel
    {
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}