@page "/"
@using System.Globalization
@using System.Text
@inject DashboardApiClient DashboardApiClient
@inject AnalyticsApiClient AnalyticsApiClient
@inject EditionApiClient EditionApiClient
@inject FestivalApiClient FestivalApiClient
@inject ActiveFestivalState ActiveFestivalState
@inject IJSRuntime JsRuntime

<PageHeader Title="Dashboard" pTitle="Overview"></PageHeader>

<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)]">

    <div class="card shadow-sm">
        <div class="flex flex-col gap-4 md:flex-row md:items-end">
            <div class="flex-1">
                <label class="block mb-1 text-sm font-semibold text-black dark:text-white">Festival</label>
                <select class="form-select w-full" @bind="selectedFestivalId" @bind:after="OnFestivalChangedAsync">
                    @foreach (FestivalDto festival in festivals)
                    {
                        <option value="@festival.Id">@festival.Name</option>
                    }
                </select>
            </div>
            <div class="flex-1">
                <label class="block mb-1 text-sm font-semibold text-black dark:text-white">Edition</label>
                <select class="form-select w-full" @bind="selectedEditionId" @bind:after="LoadAllAsync">
                    @foreach (EditionDto edition in editionsForSelectedFestival)
                    {
                        <option value="@edition.Id">@edition.Name</option>
                    }
                </select>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="card shadow-sm text-danger">@errorMessage</div>
    }

    @if (isLoading)
    {
        <div class="card shadow-sm">Loading dashboard...</div>
    }
    else if (stats is not null)
    {
        @if (analytics is { IsAvailable: true })
        {
            <p class="text-xs text-black/40 dark:text-white/60">Analytics period: @analytics.DateRangeLabel</p>
        }

        <!-- Row 1: Google Analytics KPI cards, full-width sparkline below value -->
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <div class="card shadow-sm">
                <MudText Class="text-muted dark:text-darkmuted">Views</MudText>
                @if (analytics is { IsAvailable: true })
                {
                    <div class="flex items-center gap-3 mt-1 mb-2">
                        <span class="text-2xl font-bold text-black dark:text-white">@analytics.Overview.TotalViews</span>
                        @PercentBadge(analytics.Overview.TotalViewsChangePercent)
                    </div>
                    <svg viewBox="0 0 300 50" preserveAspectRatio="none" style="width:100%; height:48px;">
                        @BuildSparkline(analytics.Overview.ViewsSparkline, analytics.Overview.TotalViewsChangePercent)
                    </svg>
                }
                else
                {
                    <MudText Typo="Typo.h5" Class="text-lg font-bold text-black/30 dark:text-white/30">N/A</MudText>
                }
            </div>

            <div class="card shadow-sm">
                <MudText Class="text-muted dark:text-darkmuted">Active Users</MudText>
                @if (analytics is { IsAvailable: true })
                {
                    <div class="flex items-center gap-3 mt-1 mb-2">
                        <span class="text-2xl font-bold text-black dark:text-white">@analytics.Overview.ActiveUsers</span>
                        @PercentBadge(analytics.Overview.ActiveUsersChangePercent)
                    </div>
                    <svg viewBox="0 0 300 50" preserveAspectRatio="none" style="width:100%; height:48px;">
                        @BuildSparkline(analytics.Overview.ActiveUsersSparkline, analytics.Overview.ActiveUsersChangePercent)
                    </svg>
                }
                else
                {
                    <MudText Typo="Typo.h5" Class="text-lg font-bold text-black/30 dark:text-white/30">N/A</MudText>
                }
            </div>

            <div class="card shadow-sm">
                <MudText Class="text-muted dark:text-darkmuted">Event Count</MudText>
                @if (analytics is { IsAvailable: true })
                {
                    <div class="flex items-center gap-3 mt-1 mb-2">
                        <span class="text-2xl font-bold text-black dark:text-white">@analytics.Overview.EventCount</span>
                        @PercentBadge(analytics.Overview.EventCountChangePercent)
                    </div>
                    <svg viewBox="0 0 300 50" preserveAspectRatio="none" style="width:100%; height:48px;">
                        @BuildSparkline(analytics.Overview.EventCountSparkline, analytics.Overview.EventCountChangePercent)
                    </svg>
                }
                else
                {
                    <MudText Typo="Typo.h5" Class="text-lg font-bold text-black/30 dark:text-white/30">N/A</MudText>
                }
            </div>

            <div class="card shadow-sm">
                <MudText Class="text-muted dark:text-darkmuted">New Users</MudText>
                @if (analytics is { IsAvailable: true })
                {
                    <div class="flex items-center gap-3 mt-1 mb-2">
                        <span class="text-2xl font-bold text-black dark:text-white">@analytics.Overview.NewUsers</span>
                        @PercentBadge(analytics.Overview.NewUsersChangePercent)
                    </div>
                    <svg viewBox="0 0 300 50" preserveAspectRatio="none" style="width:100%; height:48px;">
                        @BuildSparkline(analytics.Overview.NewUsersSparkline, analytics.Overview.NewUsersChangePercent)
                    </svg>
                }
                else
                {
                    <MudText Typo="Typo.h5" Class="text-lg font-bold text-black/30 dark:text-white/30">N/A</MudText>
                }
            </div>
        </div>

        @if (analytics is { IsAvailable: false })
        {
            <div class="card shadow-sm text-sm text-danger">
                Google Analytics error: @analytics.ErrorMessage
            </div>
        }

        <!-- Row 2: Revenue 50% + Top Countries 25% + Top Pages 25% -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-4">
            <div class="card shadow-sm md:col-span-2">
                <div class="flex items-center justify-between gap-3 mb-4">
                    <h2 class="text-lg font-bold text-black dark:text-white">Revenue</h2>
                    <select class="form-select w-auto min-w-[110px]" @bind="revenueRange" @bind:after="LoadRevenueAsync">
                        <option value="week">Weekly</option>
                        <option value="month">Monthly</option>
                        <option value="year">Yearly</option>
                    </select>
                </div>

                @if (ChartPoints.Count == 0)
                {
                    <p class="text-sm text-black/40 dark:text-white/60">No revenue data.</p>
                }
                else
                {
                    <svg viewBox="0 0 800 235" preserveAspectRatio="none" style="width:100%; height:235px;">
                        @BuildSvgContent()
                    </svg>
                }
            </div>

            <div class="card shadow-sm md:col-span-1">
                <h2 class="mb-4 text-base font-bold text-black dark:text-white">Top Countries</h2>
                @if (analytics is { IsAvailable: true } && analytics.TopCountries.Count > 0)
                {
                    long maxUsers = Math.Max(1, analytics.TopCountries.Max(c => c.ActiveUsers));

                    @foreach (AnalyticsCountryStatDto country in analytics.TopCountries)
                    {
                        double pct = (double)country.ActiveUsers / maxUsers * 100;
                        string pctWidth = pct.ToString("0.0", CultureInfo.InvariantCulture);

                        <div class="mb-3">
                            <div class="flex items-center justify-between mb-1">
                                <span class="text-sm">@country.Country</span>
                                <div class="flex items-center gap-2">
                                    <span class="text-sm font-semibold">@country.ActiveUsers</span>
                                    @PercentBadge(country.ActiveUsersChangePercent)
                                </div>
                            </div>
                            <div class="w-full h-2 rounded-full bg-black/10 dark:bg-white/10">
                                <div class="h-2 rounded-full bg-purple" style="width:@(pctWidth)%;"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-black/40 dark:text-white/60">No data available.</p>
                }
            </div>

            <div class="card shadow-sm md:col-span-1">
                <h2 class="mb-4 text-base font-bold text-black dark:text-white">Top Pages</h2>
                @if (analytics is { IsAvailable: true } && analytics.TopPages.Count > 0)
                {
                    long maxViews = Math.Max(1, analytics.TopPages.Max(p => p.Views));

                    @foreach (AnalyticsPageStatDto pageStat in analytics.TopPages)
                    {
                        double pct = (double)pageStat.Views / maxViews * 100;
                        string pctWidth = pct.ToString("0.0", CultureInfo.InvariantCulture);

                        <div class="mb-3">
                            <div class="flex items-center justify-between mb-1 gap-3">
                                <span class="text-sm truncate" title="@pageStat.PagePath">@pageStat.PagePath</span>
                                <div class="flex items-center gap-2 shrink-0">
                                    <span class="text-sm font-semibold whitespace-nowrap">@pageStat.Views</span>
                                    @PercentBadge(pageStat.ViewsChangePercent)
                                </div>
                            </div>
                            <div class="w-full h-2 rounded-full bg-black/10 dark:bg-white/10">
                                <div class="h-2 rounded-full bg-info" style="width:@(pctWidth)%;"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-black/40 dark:text-white/60">No data available.</p>
                }
            </div>
        </div>

        <!-- Pass Type Purchases + Levels per pass type: one shared grid -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div class="card shadow-sm">
                <h2 class="mb-4 text-lg font-bold text-black dark:text-white">Pass Type Purchases</h2>
                <div class="overflow-x-auto">
                    <table class="w-full table-hover">
                        <thead class="bg-gray-50 dark:bg-dark">
                            <tr class="text-left">
                                <th class="px-4 py-3 font-semibold whitespace-nowrap">PASS TYPE</th>
                                <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Purchased</th>
                                <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Fully Paid</th>
                                <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Partially Paid</th>
                                <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Unpaid</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (stats.PassTypes.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="px-4 py-3 text-center text-black/40">No pass types found for this edition.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (PassTypeStatDto passType in stats.PassTypes)
                                {
                                    <tr class="border-b border-black/10 dark:border-darkborder">
                                        <td class="px-4 py-3">@passType.PassTypeName</td>
                                        <td class="px-4 py-3 text-right">@passType.Purchased</td>
                                        <td class="px-4 py-3 text-right">@passType.FullyPaid</td>
                                        <td class="px-4 py-3 text-right">@passType.PartiallyPaid</td>
                                        <td class="px-4 py-3 text-right">@passType.Unpaid</td>
                                    </tr>
                                }
                                <tr class="font-semibold border-t-2 border-black/10 dark:border-darkborder">
                                    <td class="px-4 py-3">TOTAL</td>
                                    <td class="px-4 py-3 text-right">@stats.PassTypes.Sum(p => p.Purchased)</td>
                                    <td class="px-4 py-3 text-right">@stats.PassTypes.Sum(p => p.FullyPaid)</td>
                                    <td class="px-4 py-3 text-right">@stats.PassTypes.Sum(p => p.PartiallyPaid)</td>
                                    <td class="px-4 py-3 text-right">@stats.PassTypes.Sum(p => p.Unpaid)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @foreach (PassTypeStatDto passType in stats.PassTypes)
            {
                <div class="card shadow-sm">
                    <h2 class="mb-4 text-lg font-bold text-black dark:text-white">@passType.PassTypeName</h2>
                    <div class="overflow-x-auto">
                        <table class="w-full table-hover">
                            <thead class="bg-gray-50 dark:bg-dark">
                                <tr class="text-left">
                                    <th class="px-4 py-3 font-semibold whitespace-nowrap">LEVEL</th>
                                    <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Purchased</th>
                                    @if (passType.HasRoleBreakdown)
                                    {
                                        <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Followers</th>
                                        <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Leaders</th>
                                        <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Foll. W/P</th>
                                        <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Lead. W/P</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @if (passType.Levels.Count == 0)
                                {
                                    <tr>
                                        <td colspan="@(passType.HasRoleBreakdown ? 7 : 2)" class="px-4 py-3 text-center text-black/40">No data.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (LevelStatDto level in passType.Levels)
                                    {
                                        <tr class="border-b border-black/10 dark:border-darkborder">
                                            <td class="px-4 py-3">@level.LevelName</td>
                                            <td class="px-4 py-3 text-right">@level.Purchased</td>
                                            @if (passType.HasRoleBreakdown)
                                            {
                                                <td class="px-4 py-3 text-right">@level.Follower</td>
                                                <td class="px-4 py-3 text-right">@level.Leader</td>
                                                <td class="px-4 py-3 text-right">@level.FollowerWithoutPartner</td>
                                                <td class="px-4 py-3 text-right">@level.LeaderWithoutPartner</td>
                                            }
                                        </tr>
                                    }
                                    <tr class="font-semibold border-t-2 border-black/10 dark:border-darkborder">
                                        <td class="px-4 py-3">TOTAL</td>
                                        <td class="px-4 py-3 text-right">@passType.Levels.Sum(l => l.Purchased)</td>
                                        @if (passType.HasRoleBreakdown)
                                        {
                                            <td class="px-4 py-3 text-right">@passType.Levels.Sum(l => l.Follower)</td>
                                            <td class="px-4 py-3 text-right">@passType.Levels.Sum(l => l.Leader)</td>
                                            <td class="px-4 py-3 text-right">@passType.Levels.Sum(l => l.FollowerWithoutPartner)</td>
                                            <td class="px-4 py-3 text-right">@passType.Levels.Sum(l => l.LeaderWithoutPartner)</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            <div class="card shadow-sm">
                <h2 class="mb-4 text-lg font-bold text-black dark:text-white">Competitions</h2>
                @if (stats.Competitions.Count == 0)
                {
                    <p class="text-sm text-black/40 dark:text-white/60">No competitions found for this edition.</p>
                }
                else
                {
                    @foreach (CompetitionStatDto competition in stats.Competitions)
                    {
                        <div class="mb-4 overflow-x-auto">
                            <p class="mb-1 text-sm font-semibold text-black dark:text-white">@competition.CompetitionName</p>
                            <table class="w-full table-hover">
                                <thead class="bg-gray-50 dark:bg-dark">
                                    <tr class="text-left">
                                        <th class="px-4 py-3 font-semibold whitespace-nowrap">LEVEL</th>
                                        @if (competition.RequiresRole)
                                        {
                                            <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Follower</th>
                                            <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Leader</th>
                                        }
                                        <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (CompetitionLevelStatDto level in competition.Levels)
                                    {
                                        <tr class="border-b border-black/10 dark:border-darkborder">
                                            <td class="px-4 py-3">@level.LevelLabel</td>
                                            @if (competition.RequiresRole)
                                            {
                                                <td class="px-4 py-3 text-right">@level.Follower</td>
                                                <td class="px-4 py-3 text-right">@level.Leader</td>
                                            }
                                            <td class="px-4 py-3 text-right font-semibold">@level.Total</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Competitions + Groups -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">

            <div class="card shadow-sm">
                <h2 class="mb-4 text-lg font-bold text-black dark:text-white">Groups</h2>
                <div class="overflow-x-auto">
                    <table class="w-full table-hover">
                        <thead class="bg-gray-50 dark:bg-dark">
                            <tr class="text-left">
                                <th class="px-4 py-3 font-semibold whitespace-nowrap">Group Name</th>
                                <th class="px-4 py-3 font-semibold text-right whitespace-nowrap">Purchased</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (stats.Groups.Count == 0)
                            {
                                <tr>
                                    <td colspan="2" class="px-4 py-3 text-center text-black/40">No groups found for this edition.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (GroupStatDto group in stats.Groups)
                                {
                                    <tr class="border-b border-black/10 dark:border-darkborder">
                                        <td class="px-4 py-3">@group.GroupName</td>
                                        <td class="px-4 py-3 text-right">@group.Purchased</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="flex flex-col gap-4">
                <BusesSummaryWidget EditionId="@selectedEditionId" />
                <MealsSummaryWidget EditionId="@selectedEditionId" />
            </div>
        </div>
    }
</div>

@code {
    private List<FestivalDto> festivals = [];
    private List<EditionDto> allEditions = [];
    private Guid selectedFestivalId;
    private Guid selectedEditionId;

    private DashboardStatsDto? stats;
    private AnalyticsStatsDto? analytics;
    private List<RevenuePointDto> revenuePoints = [];
    private string revenueRange = "month";
    private bool isLoading = true;
    private string? errorMessage;

    private List<RevenueChartPoint> ChartPoints { get; set; } = [];
    private decimal axisMax = 200000m;

    private const double ViewBoxWidth = 800;
    private const double LeftPadding = 50;
    private const double RightPadding = 20;
    private const double ChartTop = 10;
    private const double ChartHeight = 200;

    private List<EditionDto> editionsForSelectedFestival =>
        allEditions.Where(e => e.FestivalId == selectedFestivalId).OrderByDescending(e => e.Year).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            festivals = (await FestivalApiClient.GetAllAsync()).Where(f => f.IsActive).ToList();
            allEditions = (await EditionApiClient.GetAllAsync()).ToList();

            Guid? activeFestivalId = allEditions.FirstOrDefault(e => e.IsActive)?.FestivalId;
            if (ActiveFestivalState.IsInitialized && ActiveFestivalState.Active is not null && festivals.Any(f => f.Id == ActiveFestivalState.Active.Id))
            {
                selectedFestivalId = ActiveFestivalState.Active.Id;
            }
            else
            {
                selectedFestivalId = activeFestivalId ?? festivals.FirstOrDefault()?.Id ?? Guid.Empty;
            }

            await SyncActiveFestivalStateAsync();

            EditionDto? defaultEdition = editionsForSelectedFestival.FirstOrDefault(e => e.IsActive)
                ?? editionsForSelectedFestival.FirstOrDefault();

            if (defaultEdition is not null)
            {
                selectedEditionId = defaultEdition.Id;
                await LoadAllAsync();
            }
            else
            {
                isLoading = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            string? savedFestivalIdString = await JsRuntime.InvokeAsync<string?>("getActiveFestivalId");

            if (!Guid.TryParse(savedFestivalIdString, out Guid savedFestivalId)
                || savedFestivalId == selectedFestivalId
                || !festivals.Any(f => f.Id == savedFestivalId))
            {
                return;
            }

            selectedFestivalId = savedFestivalId;
            await SyncActiveFestivalStateAsync();

            EditionDto? defaultEdition = editionsForSelectedFestival.FirstOrDefault(e => e.IsActive)
                ?? editionsForSelectedFestival.FirstOrDefault();

            selectedEditionId = defaultEdition?.Id ?? Guid.Empty;

            if (selectedEditionId != Guid.Empty)
            {
                await LoadAllAsync();
            }

            StateHasChanged();
        }
        catch
        {
            // Non-critical: if JS interop or localStorage fails, the dashboard just keeps its default selection.
        }
    }

    private async Task OnFestivalChangedAsync()
    {
        await SyncActiveFestivalStateAsync();

        EditionDto? defaultEdition = editionsForSelectedFestival.FirstOrDefault(e => e.IsActive)
            ?? editionsForSelectedFestival.FirstOrDefault();

        selectedEditionId = defaultEdition?.Id ?? Guid.Empty;

        if (selectedEditionId != Guid.Empty)
        {
            await LoadAllAsync();
        }
        else
        {
            stats = null;
            analytics = null;
        }
    }

    private async Task SyncActiveFestivalStateAsync()
    {
        FestivalDto? festival = festivals.FirstOrDefault(f => f.Id == selectedFestivalId);

        if (festival is null)
        {
            return;
        }

        if (!ActiveFestivalState.IsInitialized)
        {
            ActiveFestivalState.Initialize(festivals, festival.Id);
        }
        else
        {
            ActiveFestivalState.SetActive(festival);
        }

        try
        {
            await JsRuntime.InvokeVoidAsync("setActiveFestivalId", festival.Id.ToString());
        }
        catch
        {
            // Non-critical: the Sidebar just won't remember the choice across reloads if this fails.
        }
    }

    private async Task LoadAllAsync()
    {
        if (selectedEditionId == Guid.Empty)
        {
            return;
        }

        isLoading = true;
        errorMessage = null;
        stats = null;
        analytics = null;

        try
        {
            stats = await DashboardApiClient.GetStatsAsync(selectedEditionId);

            EditionDto? edition = allEditions.FirstOrDefault(e => e.Id == selectedEditionId);

            if (edition is not null)
            {
                DateOnly today = DateOnly.FromDateTime(DateTime.UtcNow);
                DateOnly candidateStart = DateOnly.FromDateTime(edition.RegistrationOpenDate ?? edition.StartDate);
                DateOnly start = candidateStart > today ? today.AddDays(-7) : candidateStart;
                DateOnly end = today;

                analytics = await AnalyticsApiClient.GetAnalyticsAsync(selectedFestivalId, start, end);
            }

            await LoadRevenueAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadRevenueAsync()
    {
        if (selectedEditionId == Guid.Empty)
        {
            return;
        }

        try
        {
            revenuePoints = await DashboardApiClient.GetRevenueAsync(selectedEditionId, revenueRange);
            BuildChartGeometry();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void BuildChartGeometry()
    {
        ChartPoints = [];

        if (revenuePoints.Count == 0)
        {
            axisMax = 200000m;
            return;
        }

        decimal rawMax = revenuePoints.Max(p => p.Amount);
        decimal rounded = rawMax <= 0 ? 0 : Math.Ceiling(rawMax / 50000m) * 50000m;
        axisMax = Math.Max(200000m, rounded);

        double plotWidth = ViewBoxWidth - LeftPadding - RightPadding;
        int count = revenuePoints.Count;

        for (int i = 0; i < count; i++)
        {
            double x = count <= 1
                ? LeftPadding + (plotWidth / 2)
                : LeftPadding + (i * (plotWidth / (count - 1)));

            double ratio = axisMax == 0 ? 0 : (double)(revenuePoints[i].Amount / axisMax);
            double y = ChartTop + ((1 - ratio) * ChartHeight);

            ChartPoints.Add(new RevenueChartPoint
            {
                X = x,
                Y = y,
                Label = revenuePoints[i].Label,
                Amount = revenuePoints[i].Amount
            });
        }
    }

    private string PolylinePoints =>
        string.Join(" ", ChartPoints.Select(p => $"{p.X.ToString(CultureInfo.InvariantCulture)},{p.Y.ToString(CultureInfo.InvariantCulture)}"));

    private int LabelStep => ChartPoints.Count <= 10 ? 1 : (int)Math.Ceiling(ChartPoints.Count / 10.0);

    private List<(double Y, decimal Value)> GridLines
    {
        get
        {
            List<(double Y, decimal Value)> lines = [];

            for (int g = 0; g <= 4; g++)
            {
                double y = ChartTop + (g * ChartHeight / 4.0);
                decimal value = axisMax - (axisMax * g / 4m);
                lines.Add((y, value));
            }

            return lines;
        }
    }

    private MarkupString BuildSvgContent()
    {
        StringBuilder sb = new();

        foreach ((double Y, decimal Value) line in GridLines)
        {
            string y = line.Y.ToString(CultureInfo.InvariantCulture);
            string width = ViewBoxWidth.ToString(CultureInfo.InvariantCulture);
            string labelY = (line.Y + 4).ToString(CultureInfo.InvariantCulture);
            string value = line.Value.ToString("0", CultureInfo.InvariantCulture);

            sb.Append($"<line x1=\"{LeftPadding.ToString(CultureInfo.InvariantCulture)}\" y1=\"{y}\" x2=\"{width}\" y2=\"{y}\" stroke=\"#e5e7eb\" stroke-dasharray=\"4,4\" stroke-width=\"1\" vector-effect=\"non-scaling-stroke\" />");
            sb.Append($"<text x=\"0\" y=\"{labelY}\" font-size=\"11\" fill=\"#9ca3af\">{value}</text>");
        }

        if (ChartPoints.Count > 1)
        {
            sb.Append($"<polyline points=\"{PolylinePoints}\" fill=\"none\" stroke=\"#7c3aed\" stroke-width=\"2\" vector-effect=\"non-scaling-stroke\" />");
        }

        for (int i = 0; i < ChartPoints.Count; i++)
        {
            RevenueChartPoint point = ChartPoints[i];
            string x = point.X.ToString(CultureInfo.InvariantCulture);
            string y = point.Y.ToString(CultureInfo.InvariantCulture);
            string amount = point.Amount.ToString("0.00", CultureInfo.InvariantCulture);
            string label = System.Net.WebUtility.HtmlEncode(point.Label);

            sb.Append($"<circle cx=\"{x}\" cy=\"{y}\" r=\"3.5\" fill=\"#7c3aed\" vector-effect=\"non-scaling-stroke\"><title>{label}: {amount} &#8364;</title></circle>");

            if (i % LabelStep == 0)
            {
                sb.Append($"<text x=\"{x}\" y=\"225\" font-size=\"11\" fill=\"#9ca3af\" text-anchor=\"middle\">{label}</text>");
            }
        }

        return new MarkupString(sb.ToString());
    }

    private static MarkupString BuildSparkline(List<long> values, decimal? changePercent)
    {
        if (values is null || values.Count < 2)
        {
            return new MarkupString(string.Empty);
        }

        // Color follows the same sign as the percent-change badge: green for growth,
        // red for decline, neutral gray when there is no previous-period baseline to compare against.
        string color = changePercent switch
        {
            > 0 => "#16a34a",
            < 0 => "#dc2626",
            _ => "#9ca3af"
        };

        long max = Math.Max(1, values.Max());
        double stepX = 300.0 / (values.Count - 1);

        StringBuilder points = new();

        for (int i = 0; i < values.Count; i++)
        {
            double x = i * stepX;
            double y = 46 - ((double)values[i] / max * 40);
            points.Append(x.ToString(CultureInfo.InvariantCulture));
            points.Append(',');
            points.Append(y.ToString(CultureInfo.InvariantCulture));
            points.Append(' ');
        }

        return new MarkupString($"<polyline points=\"{points.ToString().Trim()}\" fill=\"none\" stroke=\"{color}\" stroke-width=\"2\" vector-effect=\"non-scaling-stroke\" />");
    }

    private static MarkupString PercentBadge(decimal? percent)
    {
        if (percent is null)
        {
            return new MarkupString(string.Empty);
        }

        bool isPositive = percent.Value >= 0;
        string colorClass = isPositive ? "bg-success/10 text-success" : "bg-danger/10 text-danger";
        string arrow = isPositive ? "+" : "";
        string text = $"{arrow}{percent.Value.ToString("0.#", CultureInfo.InvariantCulture)}%";

        return new MarkupString($"<span class=\"inline-block rounded-full px-2 py-0.5 text-xs font-semibold {colorClass}\">{text}</span>");
    }

    private class RevenueChartPoint
    {
        public double X { get; set; }
        public double Y { get; set; }
        public string Label { get; set; } = string.Empty;
        public decimal Amount { get; set; }
    }
}





