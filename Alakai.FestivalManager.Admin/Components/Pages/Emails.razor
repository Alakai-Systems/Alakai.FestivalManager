@page "/emails"
@using Alakai.FestivalManager.Admin.Components.Layout
@using Alakai.FestivalManager.Admin.Contracts.Editions.DTOs
@using Radzen.Blazor
@using Alakai.FestivalManager.Admin.Contracts.Festivals.DTOs
@inject EmailTemplateApiClient EmailTemplateApiClient
@inject EditionApiClient EditionApiClient
@inject ActiveFestivalState ActiveFestivalState
@inject FestivalApiClient FestivalApiClient

<PageHeader Title="Communication" pTitle="Email Templates"></PageHeader>

<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)]">
    <div class="card">
        <div class="flex flex-col gap-4 mb-5 xl:flex-row xl:items-center xl:justify-between">
            <div class="flex flex-col gap-3 md:flex-row md:items-center">
                <input class="form-input md:w-72" placeholder="Search email templates..." @bind="searchText" @bind:event="oninput" @bind:after="ResetPage" />

                <select class="form-select md:w-56" @bind="festivalFilter" @bind:after="OnFestivalFilterChangedAsync">
                    <option value="">All festivals</option>
                    @foreach (FestivalDto f in festivals)
                    {
                        <option value="@f.Id">@f.Name</option>
                    }
                </select>

                <select class="form-select md:w-56" @bind="editionFilter" @bind:after="ResetPage">
                    <option value="@Guid.Empty">All editions</option>
                    @foreach (EditionDto edition in EditionsForSelectedFestival)
                    {
                        <option value="@edition.Id">@edition.Name</option>
                    }
                </select>

                <select class="form-select w-full md:w-44" @bind="statusFilter" @bind:after="ResetPage">
                    <option value="All">All statuses</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>

                <select class="form-select w-full md:w-32" @bind="pageSize" @bind:after="ResetPage">
                    <option value="10">10 rows</option>
                    <option value="25">25 rows</option>
                    <option value="50">50 rows</option>
                </select>

                <button type="button" class="transition-all duration-300 border rounded-md btn text-purple border-purple hover:bg-purple hover:text-white whitespace-nowrap" @onclick="OpenCreateModal">
                    <i class="ri-add-line ltr:mr-1 rtl:ml-1"></i>
                    New Template
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">@successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">@errorMessage</div>
        }

        @if (isLoading)
        {
            <p class="text-sm text-black/50 dark:text-white/40">Loading templates...</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full table-hover">
                    <thead class="bg-gray-50 dark:bg-dark">
                        <tr class="text-left">
                            <th class="px-3 py-3 font-semibold">Name</th>
                            <th class="px-3 py-3 font-semibold">Key</th>
                            <th class="px-3 py-3 font-semibold">Subject</th>
                            <th class="px-3 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Edition")'>Edition @SortIcon("Edition")</button></th>
                            <th class="px-3 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Status")'>Status @SortIcon("Status")</button></th>
                            <th class="px-3 py-3 font-semibold text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (FilteredEmailTemplates.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="px-4 py-6 text-center text-black/50 dark:text-white/40">No email templates found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (EmailTemplateDto template in PagedCodes)
                            {
                                <tr class="border-b border-black/10 dark:border-darkborder">
                                    <td class="px-3 py-3">@template.Name</td>
                                    <td class="px-3 py-3">@template.TemplateKey</td>
                                    <td class="px-3 py-3">@template.Subject</td>
                                    <td class="px-3 py-3">@GetEditionName(template.EditionId)</td>
                                    <td class="px-3 py-3"><span class="@GetStatusClass(template.IsActive)">@(template.IsActive ? "Active" : "Inactive")</span></td>
                                    <td class="px-3 py-3">
                                        <div class="flex items-center justify-end gap-2">
                                            <button type="button" class="text-black dark:text-white/80" title="Edit" @onclick="() => OpenEditModal(template)"><i class="ri-pencil-line text-lg"></i></button>
                                            <button type="button" class="text-danger" title="Delete" @onclick="() => OpenDeleteModal(template)"><i class="ri-delete-bin-line text-lg"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between mt-4">
                <p class="text-sm text-black/50 dark:text-white/40">
                    Showing @StartRow to @EndRow of @FilteredEmailTemplates.Count discount codes
                </p>

                <div class="flex items-center gap-2">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                    <span class="flex items-center justify-center w-10 h-10 text-sm rounded-md bg-purple/10 text-purple">@currentPage</span>
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage >= TotalPages)" @onclick="NextPage">Next</button>
                </div>
            </div>
        }
    </div>
</div>

@if (showModal)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative mx-auto overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder" style="width: min(95vw, 900px);">
                <div class="flex items-center justify-between px-5 py-3 border-b border-black/10 dark:border-darkborder">
                    <h3 class="text-lg font-semibold text-black dark:text-white">@(editingTemplate is null ? "New Email Template" : "Edit Email Template")</h3>
                    <button type="button" class="text-black/50 hover:text-black dark:text-white/60" @onclick="CloseModal"><i class="ri-close-line text-2xl"></i></button>
                </div>

                <div class="p-5 space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Edition</label>
                            <select class="form-select" @bind="formModel.EditionId">
                                <option value="">Global</option>
                                @foreach (EditionDto edition in editions)
                                {
                                    <option value="@edition.Id">@edition.Name</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Template Key</label>
                            <select class="form-select" @bind="formModel.TemplateKey">
                                @foreach (EmailTemplateKey key in Enum.GetValues<EmailTemplateKey>())
                                {
                                    <option value="@key">@key</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Name</label>
                            <InputText class="form-input" @bind-Value="formModel.Name" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Subject</label>
                            <InputText class="form-input" @bind-Value="formModel.Subject" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm text-black/60 dark:text-white/60">Body HTML</label>
                            <EmailTemplateEditor @ref="bodyEditor"
                                                 @bind-Value="formModel.BodyHtml"
                                                 Variables="@(new List<string> {
                                                                       "FestivalName", "EditionName", "FirstName", "LastName",
                                                                       "FullName", "UserEmail", "PortalUrl", "PassTypeName",
                                                                       "FinalPrice", "PartnerEmail", "ResetPasswordUrl",
                                                                       "AccommodationBuildingName", "AccommodationOccupantNames",
                                                                       "DepartureBusTime", "DepartureBusPickup", "DepartureBusDestination", "DepartureBusPrice",
                                                                       "ReturnBusTime", "ReturnBusPickup", "ReturnBusDestination", "ReturnBusPrice",
                                                                       "MenuType", "IsCeliacOrGlutenIntolerant", "AllergiesNotes"})" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm text-black/60 dark:text-white/60">Body Text</label>
                            <InputTextArea class="form-input" rows="4" @bind-Value="formModel.BodyText" />
                        </div>

                        <div class="flex items-center gap-4">
                            <label class="inline-flex items-center gap-2"><InputCheckbox @bind-Value="formModel.IsSystem" />System template</label>
                            <label class="inline-flex items-center gap-2"><InputCheckbox @bind-Value="formModel.IsActive" />Active</label>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="px-4 py-2 text-sm text-white rounded-md bg-purple" @onclick="SaveAsync">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (deletingTemplate is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-[92vw] md:w-[380px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="px-5 py-4">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Delete Email Template</h3>
                    <p class="mt-2 text-sm text-black/60 dark:text-white/60">Delete @deletingTemplate.Name?</p>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10" @onclick="CloseDeleteModal">Cancel</button>
                    <button type="button" class="btn border border-danger text-danger hover:bg-danger hover:text-white disabled:opacity-50" disabled="@isSaving" @onclick="DeleteAsync"> @(isSaving ? "Deleting..." : "Delete")</button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private List<EmailTemplateDto> templates = [];
    private List<EditionDto> editions = [];
    private List<FestivalDto> festivals = [];
    private string festivalFilter = string.Empty;

    private List<EditionDto> EditionsForSelectedFestival =>
        string.IsNullOrWhiteSpace(festivalFilter) || !Guid.TryParse(festivalFilter, out Guid fid)
            ? editions
            : editions.Where(e => e.FestivalId == fid).ToList();

    private void OnFestivalFilterChanged()
    {
        editionFilter = string.Empty;
        ResetPage();
    }

    private async Task OnFestivalFilterChangedAsync()
    {
        OnFestivalFilterChanged();
        await Task.CompletedTask;
    }
    private EmailTemplateDto? editingTemplate;
    private EmailTemplateDto? deletingTemplate;
    private EmailTemplateFormModel formModel = new();
    private EmailTemplateEditor bodyEditor = default!;
    private string searchText = string.Empty;
    private bool isSaving;
    private string editionFilter = string.Empty;
    private string statusFilter = "All";
    private int pageSize = 10;
    private int currentPage = 1;
    private bool isLoading = true;
    private bool showModal;
    private string? successMessage;
    private string? errorMessage;
    private string sortColumn = "Name";
    private bool sortAscending = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            editions = (await EditionApiClient.GetAllAsync()).ToList();
            templates = (await EmailTemplateApiClient.GetAllAsync()).ToList();
            festivals = (await FestivalApiClient.GetAllAsync()).ToList();

            if (ActiveFestivalState.Active is not null && string.IsNullOrWhiteSpace(festivalFilter))
            {
                festivalFilter = ActiveFestivalState.Active.Id.ToString();
            }

            if (ActiveFestivalState.Active is not null && string.IsNullOrWhiteSpace(editionFilter))
            {
                EditionDto? preferred = editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id && e.IsActive)
                    ?? editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id);

                if (preferred is not null)
                {
                    editionFilter = preferred.Id.ToString();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void NormalizePage()
    {
        if (currentPage > TotalPages)
        {
            currentPage = TotalPages;
        }

        if (currentPage < 1)
        {
            currentPage = 1;
        }
    }

    private void ResetPage()
    {
        currentPage = 1;
        StateHasChanged();
        NormalizePage();
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }

        ResetPage();
    }

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column)
        {
            return new MarkupString("<i class=\"ri-arrow-up-down-fill text-xs text-black/30\"></i>");
        }

        string icon = sortAscending ? "ri-arrow-up-fill" : "ri-arrow-down-fill";
        return new MarkupString($"<i class=\"{icon} text-xs text-purple\"></i>");
    }

    private string GetEditionName(Guid? editionId)
    {
        if (editionId is null || editionId == Guid.Empty) return string.Empty;
        EditionDto? ed = editions.FirstOrDefault(e => e.Id == editionId);

        if (ed is null)
        {
            return editionId.ToString() ?? string.Empty;
        }

        return $"{ed.Year} - {ed.Name}";
    }

    private void ShowSuccess(string message)
    {
        successMessage = message;
        errorMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            successMessage = null;
            StateHasChanged();
        });
    }

    private void ShowError(string message)
    {
        errorMessage = message;
        successMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            errorMessage = null;
            StateHasChanged();
        });
    }

    private List<EmailTemplateDto> FilteredEmailTemplates
    {
        get
        {
            IEnumerable<EmailTemplateDto> query = templates;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(c =>
                 c.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                 c.Subject.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                 c.TemplateKey.ToString().Contains(searchText, StringComparison.OrdinalIgnoreCase)
 );
            }

            if (Guid.TryParse(editionFilter, out Guid editionId) && editionId != Guid.Empty)
            {
                query = query.Where(c => c.EditionId == editionId);
            }

            if (statusFilter == "Active")
            {
                query = query.Where(c => c.IsActive);
            }
            else if (statusFilter == "Inactive")
            {
                query = query.Where(c => !c.IsActive);
            }

            query = sortColumn switch
            {
                "Edition" => sortAscending ? query.OrderBy(c => c.EditionId) : query.OrderByDescending(c => c.EditionId),
                "Status" => sortAscending
                    ? query.OrderBy(c => c.IsActive ? 0 : 1)
                    : query.OrderByDescending(c => c.IsActive ? 0 : 1),

                _ => sortAscending ? query.OrderBy(c => c.Name) : query.OrderByDescending(c => c.Name)
            };

            return query.ToList();
        }
    }

    private IEnumerable<EmailTemplateDto> PagedCodes => FilteredEmailTemplates.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredEmailTemplates.Count / (double)pageSize));
    private int StartRow => FilteredEmailTemplates.Count == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int EndRow => Math.Min(currentPage * pageSize, FilteredEmailTemplates.Count);

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
        }
    }

    private void OpenCreateModal()
    {
        editingTemplate = null;
        formModel = new EmailTemplateFormModel
        {
            TemplateKey = EmailTemplateKey.RegistrationCreated,
            IsActive = true
        };
        showModal = true;
    }

    private void OpenEditModal(EmailTemplateDto template)
    {
        editingTemplate = template;
        formModel = new EmailTemplateFormModel
        {
            EditionId = template.EditionId,
            TemplateKey = template.TemplateKey,
            Name = template.Name,
            Subject = template.Subject,
            BodyHtml = template.BodyHtml,
            BodyText = template.BodyText,
            IsSystem = template.IsSystem,
            IsActive = template.IsActive
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveAsync()
    {
        try
        {
            formModel.BodyText = EmailTemplateEditor.ConvertHtmlToPlainText(formModel.BodyHtml);

            if (editingTemplate is null)
            {
                CreateEmailTemplateRequest request = new()
                {
                    EditionId = formModel.EditionId,
                    TemplateKey = formModel.TemplateKey,
                    Name = formModel.Name,
                    Subject = formModel.Subject,
                    BodyHtml = formModel.BodyHtml,
                    BodyText = formModel.BodyText,
                    IsSystem = formModel.IsSystem
                };

                await EmailTemplateApiClient.CreateAsync(request);
                successMessage = "Email template created successfully.";
                ShowSuccess(successMessage);
            }
            else
            {
                UpdateEmailTemplateRequest request = new()
                {
                    EditionId = formModel.EditionId,
                    TemplateKey = formModel.TemplateKey,
                    Name = formModel.Name,
                    Subject = formModel.Subject,
                    BodyHtml = formModel.BodyHtml,
                    BodyText = formModel.BodyText,
                    IsSystem = formModel.IsSystem,
                    IsActive = formModel.IsActive
                };

                await EmailTemplateApiClient.UpdateAsync(editingTemplate.Id, request);
                successMessage = "Email template updated successfully.";
                ShowSuccess(successMessage);
            }

            showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            ShowError(errorMessage);
        }
    }

    private void OpenDeleteModal(EmailTemplateDto template)
    {
        deletingTemplate = template;
    }

    private void CloseDeleteModal()
    {
        deletingTemplate = null;
    }

    private async Task DeleteAsync()
    {
        if (deletingTemplate is null)
        {
            return;
        }

        try
        {
            await EmailTemplateApiClient.DeleteAsync(deletingTemplate.Id);
            successMessage = "Email template deleted successfully.";
            deletingTemplate = null;
            ShowSuccess(successMessage);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            ShowError(errorMessage);
        }
    }

    private static string GetStatusClass(bool isActive)
    {
        return isActive ? "inline-block rounded text-xs px-2 py-1 bg-success/10 text-success" : "inline-block rounded text-xs px-2 py-1 bg-danger/10 text-danger";
    }

    private class EmailTemplateFormModel
    {
        public Guid? EditionId { get; set; }
        public EmailTemplateKey TemplateKey { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Subject { get; set; } = string.Empty;
        public string BodyHtml { get; set; } = string.Empty;
        public string? BodyText { get; set; }
        public bool IsSystem { get; set; }
        public bool IsActive { get; set; }
    }
}
