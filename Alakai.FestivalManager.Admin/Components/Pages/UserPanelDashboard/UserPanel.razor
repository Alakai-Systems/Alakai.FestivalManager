    private void OnCompetitionChanged(ChangeEventArgs args)
    {
        string? value = args.Value?.ToString();

        if (!Guid.TryParse(value, out Guid competitionId))
        {
            CompetitionFormCompetitionId = Guid.Empty;
            CompetitionFormCompetitionCapacityId = Guid.Empty;
            CompetitionFormLevelId = Guid.Empty;
            CompetitionFormDanceRole = null;
            return;
        }

        CompetitionFormCompetitionId = competitionId;
        CompetitionFormCompetitionCapacityId = Guid.Empty;
        CompetitionFormLevelId = Guid.Empty;

        if (!SelectedCompetitionRequiresRole)
        {
            CompetitionCapacityDto? capacity = SelectedCompetition?.Capacities?.FirstOrDefault(c => c.IsActive);

            if (capacity is not null)
            {
                CompetitionFormCompetitionCapacityId = capacity.Id;
            }

            CompetitionFormDanceRole = "Individual";
            return;
        }

        CompetitionFormDanceRole = null;
    }


    private async Task SaveCompetitionEntryAsync()
    {
        CompetitionModalError = null;
        CompetitionModalSuccess = null;

        if (Dashboard?.Registration is null)
        {
            CompetitionModalError = "Registration not found.";
            await ShowCompetitionErrorAsync(CompetitionModalError);
            return;
        }

        if (CompetitionFormCompetitionId == Guid.Empty)
        {
            CompetitionModalError = "Please select a competition.";
            await ShowCompetitionErrorAsync(CompetitionModalError);
            return;
        }

        if (!SelectedCompetitionRequiresRole)
        {
            CompetitionFormDanceRole = "Individual";
        }
        else
        {
            if (SelectedCompetitionHasLevels && CompetitionFormLevelId == Guid.Empty)
            {
                CompetitionModalError = "Please select a level.";
                await ShowCompetitionErrorAsync(CompetitionModalError);
                return;
            }

            if (string.IsNullOrWhiteSpace(CompetitionFormDanceRole))
            {
                CompetitionModalError = "Please select a role.";
                await ShowCompetitionErrorAsync(CompetitionModalError);
                return;
            }
        }

        // BUGFIX: this used to read CompetitionFormCompetitionCapacityId directly, which
        // for role-based competitions only ever held the LEVEL's placeholder capacity id
        // (whichever role happened to sort first), ignoring the role the user actually
        // picked. GetSelectedCompetitionCapacityId() resolves the real capacity that
        // matches BOTH the selected level and the selected role.
        Guid competitionCapacityId = GetSelectedCompetitionCapacityId();

        if (competitionCapacityId == Guid.Empty)
        {
            CompetitionModalError = !SelectedCompetitionRequiresRole
                ? "This competition has no capacity configured. Please create one in the admin panel."
                : "Competition capacity could not be found for the selected level/role.";
            await ShowCompetitionErrorAsync(CompetitionModalError);
            return;
        }

        if (IsEditingCompetitionEntry)
        {
            if (!EditingCompetitionEntryId.HasValue)
            {
                CompetitionModalError = "Competition entry not found.";
                await ShowCompetitionErrorAsync(CompetitionModalError);
                return;
            }

            UpdateCompetitionEntryRequest request = new()
            {
                CompetitionId = CompetitionFormCompetitionId,
                RegistrationId = Dashboard.Registration.Id,
                PartnerRegistrationId = null,
                CompetitionCapacityId = competitionCapacityId,
                DanceRole = ParseDanceRole(CompetitionFormDanceRole),
                Notes = CompetitionFormNotes,
                InternalNotes = null,
                Status = CompetitionFormStatus,
                CancelledAt = null,
                IsActive = CompetitionFormIsActive,
            };

            try
            {
                await CompetitionEntryApiClient.UpdateAsync(EditingCompetitionEntryId.Value, request);
                CloseCompetitionModal();
                await LoadDashboardAsync();
                await ShowCompetitionSuccessAsync("Competition entry updated successfully.");
            }
            catch (Exception ex)
            {
                CompetitionModalError = ex.Message;
                await ShowCompetitionErrorAsync(CompetitionModalError);
            }

            return;
        }

        CreateCompetitionEntryRequest createRequest = new()
        {
            CompetitionId = CompetitionFormCompetitionId,
            RegistrationId = Dashboard.Registration.Id,
            PartnerRegistrationId = null,
            CompetitionCapacityId = competitionCapacityId,
            DanceRole = ParseDanceRole(CompetitionFormDanceRole),
            Notes = CompetitionFormNotes,
            InternalNotes = null
        };

        try
        {
            await CompetitionEntryApiClient.CreateAsync(createRequest);
            CloseCompetitionModal();
            await LoadDashboardAsync();
            await ShowCompetitionSuccessAsync("Competition entry created successfully.");
        }
        catch(Exception ex)
        {
            CompetitionModalError = ex.Message;
            await ShowCompetitionErrorAsync(CompetitionModalError);
        }
    }

    private async Task DeleteCompetitionEntryAsync()
    {
        if (!DeletingCompetitionEntryId.HasValue)
        {
            CompetitionModalError = "Competition entry not found.";
            await ShowCompetitionErrorAsync(CompetitionModalError);
            return;
        }

        try
        {
            await CompetitionEntryApiClient.DeleteAsync(DeletingCompetitionEntryId.Value);
            CloseDeleteCompetitionModal();
            await LoadDashboardAsync();
            await ShowCompetitionSuccessAsync("Competition entry deleted successfully.");
        }
        catch
        {
            CompetitionModalError = "Competition entry could not be deleted.";
            await ShowCompetitionErrorAsync(CompetitionModalError);
        }
    }

    private string GetCompetitionName(Guid competitionId)
    {
        CompetitionDto? competition = AvailableCompetitions.FirstOrDefault(c => c.Id == competitionId);

        return competition?.Name ?? "-";
    }

    private string GetCompetitionLevel(CompetitionEntryDto competitionEntry)
    {
        CompetitionDto? competition = AvailableCompetitions.FirstOrDefault(c => c.Id == competitionEntry.CompetitionId);

        if (competition is null)
        {
            return "-";
        }

        // Data-driven, no longer based on Format: a competition with no Levels configured
        // simply has no level to show, regardless of whether it's Individual, Partnered or
        // Team (Individual competitions CAN have levels, e.g. Beginner/Advanced Solo Jazz).
        if (competition.Levels.Count == 0)
        {
            return "Open";
        }

        CompetitionCapacityDto? capacity = competition.Capacities.FirstOrDefault(c => c.Id == competitionEntry.CompetitionCapacityId);

        if (capacity is null || capacity.CompetitionLevelId is null)
        {
            return "-";
        }

        CompetitionLevelDto? level = competition.Levels.FirstOrDefault(l => l.Id == capacity.CompetitionLevelId);

        return level?.Name ?? "-";
    }

    private DanceRole? ParseDanceRole(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        bool parsed = Enum.TryParse(value, out DanceRole role);

        return parsed ? role : null;
    }
}

