    private Guid GetSelectedCompetitionCapacityId()
    {
        if (!SelectedCompetitionRequiresRole)
        {
            CompetitionCapacityDto? capacity = SelectedCompetition?.Capacities?.FirstOrDefault(c => c.IsActive);

            return capacity?.Id ?? Guid.Empty;
        }

        bool parsed = Enum.TryParse(CompetitionFormDanceRole, out DanceRole selectedRole);

        if (!parsed)
        {
            return Guid.Empty;
        }

        Guid? requiredLevelId = SelectedCompetitionHasLevels && CompetitionFormLevelId != Guid.Empty
            ? CompetitionFormLevelId
            : null;

        CompetitionCapacityDto? capacityByRole = SelectedCompetition?.Capacities?
            .FirstOrDefault(c => c.IsActive && c.CompetitionLevelId == requiredLevelId && c.DanceRole == selectedRole);

        return capacityByRole?.Id ?? Guid.Empty;
    }

