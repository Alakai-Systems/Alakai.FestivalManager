@page "/user-panel/dashboard"
@layout UserPanelLayout

@using Alakai.FestivalManager.Admin.Components.Layout
@using Alakai.FestivalManager.Admin.Contracts.UserPanel.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Accommodations.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Accommodations.Requests
@using Alakai.FestivalManager.Admin.Contracts.Buses.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Buses.Requests
@using Alakai.FestivalManager.Admin.Contracts.Meals.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Meals.Requests
@using Alakai.FestivalManager.Admin.Services.Api

@inject UserPanelApiClient UserPanelApiClient
@inject RegistrationApiClient RegistrationApiClient
@inject CompetitionEntryApiClient CompetitionEntryApiClient
@inject AccommodationApiClient AccommodationApiClient
@inject FestivalModuleApiClient FestivalModuleApiClient
@inject BusApiClient BusApiClient
@inject MealPreferenceApiClient MealPreferenceApiClient
@inject NavigationManager Navigation
@inject IAuthApiClient AuthApiClient

<PageHeader Title="User Panel" pTitle="Dashboard"></PageHeader>

@if (IsLoading)
{
    <div class="card">
        Loading dashboard...
    </div>

    return;
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="card text-danger">
        @ErrorMessage
    </div>

    return;
}

<!-- Start All Card -->
<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)] rounded-xl bg-light/60 p-4 dark:bg-dark/40">

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="card shadow-sm">
            <div class="flex items-center gap-4">
                <div class="flex items-center justify-center w-12 h-12 rounded bg-purple/10 text-purple">
                    <i class="ri-user-line text-2xl"></i>
                </div>
                <div>
                    <MudText Class="text-muted dark:text-darkmuted">Registration</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@RegistrationStatus</MudText>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="flex items-center gap-4">
                <div class="flex items-center justify-center w-12 h-12 rounded bg-warning/10 text-warning">
                    <i class="ri-bank-card-line text-2xl"></i>
                </div>
                <div>
                    <MudText Class="text-muted dark:text-darkmuted">Payment</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@PaymentStatus</MudText>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="flex items-center gap-4">
                <div class="flex items-center justify-center w-12 h-12 rounded bg-success/10 text-success">
                    <i class="ri-trophy-line text-2xl"></i>
                </div>
                <div>
                    <MudText Class="text-muted dark:text-darkmuted">Competitions</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@Competitions.Count</MudText>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="flex items-center gap-4">
                <div class="flex items-center justify-center w-12 h-12 rounded bg-info/10 text-info">
                    <i class="ri-file-list-3-line text-2xl"></i>
                </div>
                <div>
                    <MudText Class="text-muted dark:text-darkmuted">Invoices</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@Invoices.Count</MudText>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
        <div class="card shadow-sm">
            <div class="mb-5" id="personal-data">
                <h2 class="text-lg font-bold text-black dark:text-white">My personal details</h2>
                <p class="mt-1 text-sm text-muted dark:text-darkmuted">Update your personal details.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(ProfileSuccessMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">
                    @ProfileSuccessMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(ProfileErrorMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">
                    @ProfileErrorMessage
                </div>
            }

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <div class="space-y-2">
                    <MudText>First Name</MudText>
                    <input type="text" class="form-input" placeholder="First Name" @bind="FirstName">
                </div>

                <div class="space-y-2">
                    <MudText>Last Name</MudText>
                    <input type="text" class="form-input" placeholder="Last Name" @bind="LastName">
                </div>

                <div class="space-y-2 md:col-span-2">
                    <MudText>Your email</MudText>
                    <input type="email" class="form-input" placeholder="Email" @bind="Email">
                </div>

                <div class="space-y-2">
                    <MudText>Phone</MudText>
                    <input type="text" class="form-input" placeholder="Phone" @bind="Phone">
                </div>

                <div class="space-y-2">
                    <MudText>Country</MudText>
                    <input type="text" class="form-input" placeholder="Country" @bind="Country">
                </div>

                <div class="space-y-2">
                    <MudText>City</MudText>
                    <input type="text" class="form-input" placeholder="City" @bind="City">
                </div>

                <div class="space-y-2">
                    <MudText>Document Number</MudText>
                    <input type="text" class="form-input" placeholder="Document Number" @bind="DocumentNumber">
                </div>

                <div class="flex flex-wrap gap-3 md:col-span-2">
                    <button type="button"
                            class="btn bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85]"
                            @onclick="SaveProfileAsync">
                        Save
                    </button>

                    <button type="button"
                            class="btn bg-light border-light text-black hover:bg-light/[0.85] hover:border-light/[0.85]"
                            @onclick="LoadDashboardAsync">
                        Discard
                    </button>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="mb-5" id="registration-data">
                <h2 class="text-lg font-bold text-black dark:text-white">My Registration details</h2>
            </div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <div class="p-4 rounded bg-light/20 dark:bg-white/5">
                    <MudText Class="text-muted dark:text-darkmuted">Pass</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@PassTypeName</MudText>
                </div>

                <div class="p-4 rounded bg-light/20 dark:bg-white/5">
                    <MudText Class="text-muted dark:text-darkmuted">Level</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@LevelName</MudText>
                </div>

                <div class="p-4 rounded bg-light/20 dark:bg-white/5">
                    <MudText Class="text-muted dark:text-darkmuted">Role</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@RegistrationDanceRole</MudText>
                </div>

                <div class="p-4 rounded bg-light/20 dark:bg-white/5">
                    <MudText Class="text-muted dark:text-darkmuted">Partner</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@PartnerText</MudText>
                </div>

                <div class="p-4 rounded bg-light/20 dark:bg-white/5">
                    <MudText Class="text-muted dark:text-darkmuted">Discount Code</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@DiscountCode</MudText>
                </div>

                <div class="p-4 rounded bg-light/20 dark:bg-white/5">
                    <MudText Class="text-muted dark:text-darkmuted">Final Price</MudText>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@FinalPrice.ToString("0.00") €</MudText>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="flex items-center justify-between gap-4 mb-4">
                <div class="mb-5" id="payments">
                    <h2 class="text-lg font-bold text-black dark:text-white">Payments</h2>
                    <p class="mt-1 text-sm text-muted dark:text-darkmuted">Pay your registration.</p>
                </div>
                <button type="button" class="btn bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85]">Pay now</button>
            </div>

            <div class="flex items-center justify-between gap-4 p-4 rounded bg-light/20 dark:bg-white/5">
                <div>
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">Registration Payment</MudText>
                    <MudText Class="text-muted mt-0.5 dark:text-darkmuted">Status of your payment.</MudText>
                </div>

                <div class="text-right">
                    <MudText Typo="Typo.h5" Class="text-lg font-bold dark:text-white">@FinalPrice.ToString("0.00") €</MudText>
                    <MudText Class="text-warning">@PaymentStatus</MudText>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="flex items-center justify-between gap-4 mb-4">
                <div class="mb-5" id="invoices">
                    <h2 class="text-lg font-bold text-black dark:text-white">Invoices</h2>
                </div>
                <button type="button" class="btn bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85]" @onclick="OpenInvoiceModal">Create invoice</button>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full table-hover">
                    <thead class="bg-gray-50 dark:bg-dark">
                        <tr class="text-left">
                            <th class="px-4 py-3 font-semibold">Invoice</th>
                            <th class="px-4 py-3 font-semibold">Date</th>
                            <th class="px-4 py-3 font-semibold">Amount</th>
                            <th class="px-4 py-3 font-semibold text-right">Accions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Invoices.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="px-4 py-6 text-center text-black/50 dark:text-white/40">There are no invoices available yet.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (UserPanelInvoiceDto invoice in Invoices)
                            {
                                <tr class="border-b border-black/10 dark:border-darkborder">
                                    <td class="px-4 py-3">@invoice.Number</td>
                                    <td class="px-4 py-3">@invoice.Date.ToString("dd/MM/yyyy")</td>
                                    <td class="px-4 py-3">@invoice.Amount.ToString("0.00") €</td>
                                    <td class="px-4 py-3 text-right">
                                        <a href="@invoice.PdfUrl" target="_blank" class="text-black dark:text-white/80">
                                            <i class="ri-download-line text-lg"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="flex items-center justify-between gap-4 mb-4">
                <div class="mb-5" id="competitions">
                    <h2 class="text-lg font-bold text-black dark:text-white">Competitions</h2>
                </div>
                <button type="button" class="btn bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85]" @onclick="OpenCreateCompetitionModal">
                    Register
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(CompetitionSuccessMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">
                    @CompetitionSuccessMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(CompetitionErrorMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">
                    @CompetitionErrorMessage
                </div>
            }

            <div class="overflow-x-auto">
                <table class="w-full table-hover">
                    <thead class="bg-gray-50 dark:bg-dark">
                        <tr class="text-left">
                            <th class="px-4 py-3 font-semibold">Competition</th>
                            <th class="px-4 py-3 font-semibold">Level</th>
                            <th class="px-4 py-3 font-semibold">Role</th>
                            <th class="px-4 py-3 font-semibold">Status</th>
                            <th class="px-4 py-3 font-semibold text-right">Accions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (CompetitionEntryDto competition in Competitions)
                        {
                            <tr class="border-b border-black/10 dark:border-darkborder">
                                <td class="px-4 py-3">@GetCompetitionName(competition.CompetitionId)</td>
                                <td class="px-4 py-3">@GetCompetitionLevel(competition)</td>
                                <td class="px-4 py-3">@competition.DanceRole.ToString()</td>
                                <td class="px-4 py-3">
                                    <span class="@GetCompetitionStatusClass(@competition.Status.ToString())">
                                        @competition.Status
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-right">
                                    <button type="button" class="text-black dark:text-white/80" 
                                        @onclick="() => OpenEditCompetitionModal(competition)">
                                        <i class="ri-pencil-line text-lg"></i>
                                    </button>
                                    <button type="button" class="text-danger"
                                        @onclick="() => OpenDeleteCompetitionModal(competition)">
                                        <i class="ri-delete-bin-line text-lg"></i>
                                    </button>
                                </td>
                            </tr>
                        }

                        @if (Competitions.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="px-4 py-6 text-center text-black/50 dark:text-white/40">You are not registered to any competition.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

@if (HasAccommodationModule)
{
<div class="card shadow-sm">
            <div class="mb-5" id="accommodation">
                <h2 class="text-lg font-bold text-black dark:text-white">Accommodation</h2>
            </div>

            @if (!string.IsNullOrWhiteSpace(AccommodationSuccessMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">@AccommodationSuccessMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(AccommodationErrorMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">@AccommodationErrorMessage</div>
            }

            @if (IsLoadingAccommodation)
            {
                <p class="text-sm text-muted dark:text-darkmuted">Loading...</p>
            }
            else if (ExistingReservation is not null)
            {
                <p class="mb-3 text-sm text-muted dark:text-darkmuted">
                    You are booked in <strong>@ExistingReservation.BuildingName</strong>.
                </p>

                <div class="overflow-x-auto">
                    <table class="w-full table-hover">
                        <thead class="bg-gray-50 dark:bg-dark">
                            <tr class="text-left">
                                <th class="px-4 py-3 font-semibold">Occupant</th>
                                <th class="px-4 py-3 font-semibold">Unit</th>
                                <th class="px-4 py-3 font-semibold text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (AccommodationReservationOccupantDto occupant in ExistingReservation.Occupants)
                            {
                                <tr class="border-b border-black/10 dark:border-darkborder">
                                    <td class="px-4 py-3">
                                        @occupant.Email
                                        @if (occupant.IsResponsible)
                                        {
                                            <span class="ml-2 text-xs text-purple">(responsible)</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3">@occupant.ZoneName - @occupant.AccommodationName</td>
                                    <td class="px-4 py-3 text-right">
                                        @if (occupant.IsResponsible && IsResponsibleForExistingReservation)
                                        {
                                            <button type="button" class="text-black dark:text-white/80" title="Edit" @onclick="OpenEditAccommodationModal"><i class="ri-pencil-line text-lg"></i></button>
                                            <button type="button" class="ml-2 text-danger" title="Cancel" @onclick="OpenCancelAccommodationModal"><i class="ri-delete-bin-line text-lg"></i></button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!IsResponsibleForExistingReservation)
                {
                    <p class="mt-3 text-xs text-muted dark:text-darkmuted">To modify this reservation, contact the person responsible for it.</p>
                }
            }
            else if (AvailableAccommodationBuildings.Count == 0)
            {
                <p class="text-sm text-muted dark:text-darkmuted">No accommodation is available for your pass right now.</p>
            }
            else
            {
                <div class="space-y-4">
                    <div>
                        <label class="block mb-1 text-sm text-muted dark:text-darkmuted">Choose your accommodation</label>
                        <select class="form-select" @bind="SelectedAccommodationBuildingId" @bind:after="OnAccommodationBuildingChangedAsync">
                            <option value="@Guid.Empty">-</option>
                            @foreach (AccommodationBuildingSummaryDto building in AvailableAccommodationBuildings)
                            {
                                <option value="@building.Id">@building.Name</option>
                            }
                        </select>
                    </div>

                    @if (SelectedAccommodationBuildingId != Guid.Empty && SelectedBuildingType == 1)
                    {
                        <div>
                            <label class="block mb-1 text-sm text-muted dark:text-darkmuted">Number of occupants (max 12)</label>
                            <input type="number" min="1" max="12" class="form-input" @bind="OccupantCount" @bind:after="RebuildOccupantRows" />
                        </div>
                    }

                    @if (SelectedAccommodationBuildingId != Guid.Empty && SelectedBuildingType != 1)
                    {
                        <div>
                            <label class="block mb-1 text-sm text-muted dark:text-darkmuted">Number of occupants</label>
                            @if (AvailableCapacities.Count == 0)
                            {
                                <p class="text-sm text-danger">No units available right now for this accommodation.</p>
                            }
                            else
                            {
                                <select class="form-select" @bind="OccupantCount" @bind:after="RebuildOccupantRows">
                                    <option value="0">-</option>
                                    @foreach (int capacity in AvailableCapacities)
                                    {
                                        <option value="@capacity">@capacity</option>
                                    }
                                </select>
                            }
                        </div>
                    }

                    @if (OccupantRows.Count > 0)
                    {
                        <div class="space-y-3">
                            <h3 class="text-sm font-semibold text-black dark:text-white">Data of the occupants</h3>

                            @for (int i = 0; i < OccupantRows.Count; i++)
                            {
                                int rowIndex = i;
                                <div class="grid grid-cols-1 gap-3 p-3 border rounded-md border-black/10 dark:border-darkborder md:grid-cols-3">
                                    <div>
                                        <label class="block mb-1 text-xs text-muted dark:text-darkmuted">
                                            Email @(rowIndex == 0 ? "(you)" : $"(occupant {rowIndex + 1})")
                                        </label>
                                        <input class="form-input" @bind="OccupantRows[rowIndex].Email" disabled="@(rowIndex == 0)" />
                                    </div>

                                    @if (SelectedBuildingType != 1)
                                    {
                                        <div>
                                            <label class="block mb-1 text-xs text-muted dark:text-darkmuted">Birth date</label>
                                            <input type="date" class="form-input" @bind="OccupantRows[rowIndex].BirthDate" />
                                        </div>
                                        <div>
                                            <label class="block mb-1 text-xs text-muted dark:text-darkmuted">ID/Passport expiry date</label>
                                            <input type="date" class="form-input" @bind="OccupantRows[rowIndex].DocumentExpiryDate" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="flex justify-end">
                            <button type="button" class="btn bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85] disabled:opacity-50" disabled="@IsSavingAccommodation" @onclick="SaveAccommodationReservationAsync">
                                @(IsSavingAccommodation ? "Saving..." : "Save")
                            </button>
                        </div>
                    }
                </div>
            }
        </div>

        @if (ShowEditAccommodationModal)
        {
            <div class="fixed inset-0 z-[999] flex items-center justify-center bg-black/60 px-4 py-8">
                <div class="relative w-full overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder" style="width: min(95vw, 600px); max-height: 90vh;">
                    <div class="overflow-y-auto" style="max-height: 90vh;">
                        <div class="flex items-center justify-between px-5 py-3 border-b border-black/10 dark:border-darkborder">
                            <h3 class="text-lg font-semibold text-black dark:text-white">Edit Accommodation</h3>
                            <button type="button" class="text-black/50 hover:text-black dark:text-white/60" @onclick="CloseEditAccommodationModal"><i class="ri-close-line text-2xl"></i></button>
                        </div>
                        <div class="p-5 space-y-4">
                            @if (SelectedBuildingType == 1)
                            {
                                <div>
                                    <label class="block mb-1 text-sm text-muted dark:text-darkmuted">Number of occupants (max 12)</label>
                                    <input type="number" min="1" max="12" class="form-input" @bind="OccupantCount" @bind:after="RebuildOccupantRows" />
                                </div>
                            }

                            @for (int i = 0; i < OccupantRows.Count; i++)
                            {
                                int rowIndex = i;
                                <div class="grid grid-cols-1 gap-3 p-3 border rounded-md border-black/10 dark:border-darkborder md:grid-cols-3">
                                    <div>
                                        <label class="block mb-1 text-xs text-muted dark:text-darkmuted">
                                            Email @(rowIndex == 0 ? "(you)" : $"(occupant {rowIndex + 1})")
                                        </label>
                                        <input class="form-input" @bind="OccupantRows[rowIndex].Email" disabled="@(rowIndex == 0)" />
                                    </div>

                                    @if (SelectedBuildingType != 1)
                                    {
                                        <div>
                                            <label class="block mb-1 text-xs text-muted dark:text-darkmuted">Birth date</label>
                                            <input type="date" class="form-input" @bind="OccupantRows[rowIndex].BirthDate" />
                                        </div>
                                        <div>
                                            <label class="block mb-1 text-xs text-muted dark:text-darkmuted">ID/Passport expiry date</label>
                                            <input type="date" class="form-input" @bind="OccupantRows[rowIndex].DocumentExpiryDate" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                            <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10" @onclick="CloseEditAccommodationModal">Cancel</button>
                            <button type="button" class="px-4 py-2 text-sm text-white rounded-md bg-purple disabled:opacity-50" disabled="@IsSavingAccommodation" @onclick="SaveEditedAccommodationReservationAsync">
                                @(IsSavingAccommodation ? "Saving..." : "Save changes")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (ShowCancelAccommodationModal)
        {
            <div class="fixed inset-0 z-[999] flex items-center justify-center bg-black/60 px-4 py-8">
                <div class="relative w-[92vw] md:w-[420px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                    <div class="px-5 py-4">
                        <h3 class="text-lg font-semibold text-black dark:text-white">Cancel reservation</h3>
                        <p class="mt-2 text-sm text-muted dark:text-darkmuted">Are you sure you want to cancel this accommodation reservation? This cannot be undone.</p>
                    </div>
                    <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
