    private void RebuildOccupantRows()
    {
        List<AccommodationOccupantFormRow> newRows = [];

        for (int i = 0; i < OccupantCount; i++)
        {
            if (i < OccupantRows.Count)
            {
                newRows.Add(OccupantRows[i]);
            }
            else if (i == 0)
            {
                newRows.Add(new AccommodationOccupantFormRow { Email = Dashboard?.User.Email ?? string.Empty });
            }
            else
            {
                newRows.Add(new AccommodationOccupantFormRow());
            }
        }

        OccupantRows = newRows;
    }

