@code {
    // ==================== Meals ====================
    private const int MealsModuleFlag = 8;
    private bool HasMealsModule => (EnabledFestivalModules & MealsModuleFlag) != 0;

    private int MealMenuType { get; set; } = 1;
    private bool MealIsCeliac { get; set; }
    private string? MealAllergiesNotes { get; set; }
    private bool IsLoadingMeal { get; set; } = true;
    private bool IsSavingMeal { get; set; }
    private string? MealSuccessMessage { get; set; }
    private string? MealErrorMessage { get; set; }

    private void ShowMealSuccess(string message)
    {
        MealSuccessMessage = message;
        MealErrorMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            MealSuccessMessage = null;
            StateHasChanged();
        });
    }

    private void ShowMealError(string message)
    {
        MealErrorMessage = message;
        MealSuccessMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            MealErrorMessage = null;
            StateHasChanged();
        });
    }

    private async Task LoadMealDataAsync()
    {
        if (Dashboard?.Registration is null)
        {
            IsLoadingMeal = false;
            return;
        }

        IsLoadingMeal = true;

        try
        {
            MealPreferenceDto? preference = await MealPreferenceApiClient.GetByRegistrationAsync(Dashboard.Registration.Id);

            if (preference is not null && preference.HasPreference)
            {
                MealMenuType = preference.MenuType;
                MealIsCeliac = preference.IsCeliacOrGlutenIntolerant;
                MealAllergiesNotes = preference.AllergiesNotes;
            }
        }
        catch
        {
            // Non-critical: the meals section just stays at defaults if this fails.
        }
        finally
        {
            IsLoadingMeal = false;
        }
    }

    private async Task SaveMealPreferenceAsync()
    {
        if (Dashboard?.Registration is null)
        {
            return;
        }

        IsSavingMeal = true;

        try
        {
            SaveMealPreferenceRequest request = new()
            {
                RegistrationId = Dashboard.Registration.Id,
                MenuType = MealMenuType,
                IsCeliacOrGlutenIntolerant = MealIsCeliac,
                AllergiesNotes = MealAllergiesNotes
            };

            await MealPreferenceApiClient.SaveAsync(request);
            ShowMealSuccess("Meal preference saved successfully.");
        }
        catch (ApiClientException ex)
        {
            ShowMealError(ex.Message);
        }
        catch (Exception ex)
        {
            ShowMealError(ex.Message);
        }
        finally
        {
            IsSavingMeal = false;
        }
    }

    // ==================== Buses ====================
    private const int TransportModuleFlag = 4;
    private bool HasTransportModule => (EnabledFestivalModules & TransportModuleFlag) != 0;

    private List<BusDto> AvailableBuses { get; set; } = [];
    private List<BusReservationDto> BusReservations { get; set; } = [];
    private Dictionary<int, Guid> PendingBusSelection { get; set; } = new() { [1] = Guid.Empty, [2] = Guid.Empty };
    private bool IsLoadingBuses { get; set; } = true;
    private bool IsSavingBus { get; set; }
    private string? BusSuccessMessage { get; set; }
    private string? BusErrorMessage { get; set; }

    private BusReservationDto? editingBusReservation;
    private Guid editBusNewId;
    private BusReservationDto? cancellingBusReservation;

    private bool HasPendingBusSelection =>
        PendingBusSelection.Any(kv => kv.Value != Guid.Empty && !BusReservations.Any(r => r.Direction == kv.Key));

    private static string GetDirectionLabel(int direction) => direction switch
    {
        1 => "Departure",
        2 => "Return",
        _ => "-"
    };

    private static string GetMapsUrl(string location)
    {
        return $"https://www.google.com/maps/search/?api=1&query={Uri.EscapeDataString(location)}";
    }

    private void ShowBusSuccess(string message)
    {
        BusSuccessMessage = message;
        BusErrorMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            BusSuccessMessage = null;
            StateHasChanged();
        });
    }

    private void ShowBusError(string message)
    {
        BusErrorMessage = message;
        BusSuccessMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            BusErrorMessage = null;
            StateHasChanged();
        });
    }

    private async Task LoadBusDataAsync()
    {
        if (Dashboard?.Registration is null)
        {
            IsLoadingBuses = false;
            return;
        }

        IsLoadingBuses = true;

        try
        {
            BusReservations = (await BusApiClient.GetReservationsByRegistrationAsync(Dashboard.Registration.Id)).ToList();
            AvailableBuses = (await BusApiClient.GetAvailableForRegistrationAsync(Dashboard.Registration.Id)).ToList();
            PendingBusSelection = new() { [1] = Guid.Empty, [2] = Guid.Empty };
        }
        catch
        {
            // Non-critical: the buses section just stays empty if this fails.
        }
        finally
        {
            IsLoadingBuses = false;
        }
    }

    private async Task SaveBusSelectionAsync()
    {
        if (Dashboard?.Registration is null)
        {
            return;
        }

        List<Guid> busIds = PendingBusSelection
            .Where(kv => kv.Value != Guid.Empty && !BusReservations.Any(r => r.Direction == kv.Key))
            .Select(kv => kv.Value)
            .ToList();

        if (busIds.Count == 0)
        {
            return;
        }

        IsSavingBus = true;

