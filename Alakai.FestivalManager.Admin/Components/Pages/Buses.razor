@page "/buses"
@using Alakai.FestivalManager.Admin.Contracts.Editions.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Festivals.DTOs
@using Alakai.FestivalManager.Admin.Contracts.PassTypes.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Buses.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Buses.Requests

@inject BusApiClient BusApiClient
@inject EditionApiClient EditionApiClient
@inject FestivalApiClient FestivalApiClient
@inject PassTypeApiClient PassTypeApiClient
@inject ActiveFestivalState ActiveFestivalState

<PageHeader Title="Event Setup" pTitle="Buses"></PageHeader>

<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)]">
    <div class="card">
        <div class="flex flex-col gap-4 mb-5 xl:flex-row xl:items-center xl:justify-between">
            <div class="flex flex-col gap-3 md:flex-row md:items-center">
                <select class="form-select md:w-56" @bind="selectedFestivalId" @bind:after="OnFestivalChangedAsync">
                    @foreach (FestivalDto festival in festivals)
                    {
                        <option value="@festival.Id">@festival.Name</option>
                    }
                </select>
                <select class="form-select md:w-64" @bind="selectedEditionId" @bind:after="OnEditionChangedAsync">
                    @foreach (EditionDto edition in editionsForSelectedFestival)
                    {
                        <option value="@edition.Id">@edition.Name</option>
                    }
                </select>
                <select class="form-select md:w-40" @bind="directionFilter" @bind:after="ResetPage">
                    <option value="0">All directions</option>
                    <option value="1">Outbound</option>
                    <option value="2">Return</option>
                </select>
                <select class="form-select md:w-32" @bind="pageSize" @bind:after="ResetPage">
                    <option value="10">10 rows</option>
                    <option value="25">25 rows</option>
                    <option value="50">50 rows</option>
                </select>
                <button type="button" class="transition-all duration-300 border rounded-md btn text-purple border-purple hover:bg-purple hover:text-white whitespace-nowrap" @onclick="OpenCreateModal" disabled="@(selectedEditionId == Guid.Empty)">
                    <i class="ri-add-line ltr:mr-1 rtl:ml-1"></i>
                    New Bus
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">@successMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">@errorMessage</div>
        }

        @if (isLoading)
        {
            <p class="text-sm text-black/50 dark:text-white/40">Loading buses...</p>
        }
        else if (PagedBuses.Count == 0)
        {
            <p class="text-sm text-black/50 dark:text-white/40">No buses for this edition yet.</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full table-hover">
                    <thead class="bg-gray-50 dark:bg-dark">
                        <tr class="text-left">
                            <th class="px-3 py-3 font-semibold cursor-pointer select-none" @onclick='() => SortBy("Direction")'>Direction @GetSortIcon("Direction")</th>
                            <th class="px-3 py-3 font-semibold cursor-pointer select-none" @onclick='() => SortBy("Departure")'>Departure @GetSortIcon("Departure")</th>
                            <th class="px-3 py-3 font-semibold">Pickup</th>
                            <th class="px-3 py-3 font-semibold">Destination</th>
                            <th class="px-3 py-3 font-semibold">Price</th>
                            <th class="px-3 py-3 font-semibold">Seats</th>
                            <th class="px-3 py-3 font-semibold">Active</th>
                            <th class="px-3 py-3 font-semibold text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (BusDto bus in PagedBuses)
                        {
                            <tr class="border-b border-black/10 dark:border-darkborder">
                                <td class="px-4 py-3">
                                    <span class="inline-block rounded text-xs px-2 py-1 @(bus.Direction == 1 ? "bg-purple/10 text-purple" : "bg-warning/10 text-warning")">@GetDirectionLabel(bus.Direction)</span>
                                </td>
                                <td class="px-3 py-3">@bus.DepartureTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-3 py-3"><a href="@GetMapsUrl(bus.PickupLocation)" target="_blank" class="text-purple hover:underline">@bus.PickupLocation</a></td>
                                <td class="px-3 py-3"><a href="@GetMapsUrl(bus.DestinationLocation)" target="_blank" class="text-purple hover:underline">@bus.DestinationLocation</a></td>
                                <td class="px-3 py-3">@(bus.Price > 0 ? bus.Price.ToString("0.00") + " €" : "-")</td>
                                <td class="px-3 py-3">@bus.OccupiedCount / @bus.Capacity</td>
                                <td class="px-3 py-3"><span class="@GetStatusClass(bus.IsActive)">@(bus.IsActive ? "Active" : "Inactive")</span></td>
                                <td class="px-3 py-3">
                                    <div class="flex items-center justify-end gap-2">
                                        <button type="button" class="text-black dark:text-white/80" title="Edit" @onclick="() => OpenEditModal(bus)"><i class="ri-pencil-line text-lg"></i></button>
                                        <button type="button" class="text-danger" title="Delete" @onclick="() => OpenDeleteModal(bus)"><i class="ri-delete-bin-line text-lg"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between mt-4">
                <p class="text-sm text-black/50 dark:text-white/40">Showing @StartRow to @EndRow of @FilteredBuses.Count buses</p>
                <div class="flex items-center gap-2">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                    <span class="flex items-center justify-center w-10 h-10 text-sm rounded-md bg-purple/10 text-purple">@currentPage</span>
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage >= TotalPages)" @onclick="NextPage">Next</button>
                </div>
            </div>
        }
    </div>
</div>

@if (showModal)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative mx-auto overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder" style="width: min(95vw, 600px);">
                <div class="flex items-center justify-between px-5 py-3 border-b border-black/10 dark:border-darkborder">
                    <h3 class="text-lg font-semibold text-black dark:text-white">@(editingBus is null ? "New Bus" : "Edit Bus")</h3>
                    <button type="button" class="text-black/50 hover:text-black dark:text-white/60" @onclick="CloseModal"><i class="ri-close-line text-2xl"></i></button>
                </div>

                <div class="p-5 space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Direction</label>
                            <select class="form-select" @bind="formDirection">
                                <option value="1">Outbound</option>
                                <option value="2">Return</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Departure</label>
                            <input type="datetime-local" class="form-input" @bind="formDepartureTime" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm text-black/60 dark:text-white/60">Pickup location</label>
                        <div class="flex items-center gap-2">
                            <input class="form-input" @bind="formPickupLocation" />
                            <a href="@GetMapsUrl(formPickupLocation)" target="_blank" class="text-black/50 hover:text-purple shrink-0" title="View on map"><i class="ri-map-pin-line text-xl"></i></a>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm text-black/60 dark:text-white/60">Destination</label>
                        <div class="flex items-center gap-2">
                            <input class="form-input" @bind="formDestinationLocation" />
                            <a href="@GetMapsUrl(formDestinationLocation)" target="_blank" class="text-black/50 hover:text-purple shrink-0" title="View on map"><i class="ri-map-pin-line text-xl"></i></a>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Capacity</label>
                            <input type="number" min="1" class="form-input" @bind="formCapacity" />
                        </div>
                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Price (informational)</label>
                            <input type="number" step="0.01" min="0" class="form-input" @bind="formPrice" />
                        </div>
                    </div>

                    @if (editingBus is not null)
                    {
                        <label class="inline-flex items-center gap-2 text-sm text-black dark:text-white">
                            <input type="checkbox" @bind="formIsActive" />
                            Active
                        </label>
                    }

                    <div>
                        <label class="block mb-2 text-sm text-black/60 dark:text-white/60">Allowed pass types</label>
                        <div class="flex flex-wrap gap-3">
                            @foreach (PassTypeDto passType in passTypes)
                            {
                                <label class="inline-flex items-center gap-2 text-sm text-black dark:text-white">
                                    <input type="checkbox" checked="@formAllowedPassTypeIds.Contains(passType.Id)" @onchange="e => TogglePassType(passType.Id, (bool)e.Value!)" />
                                    @passType.Name
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="px-4 py-2 text-sm text-white rounded-md bg-purple" @onclick="SaveAsync">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (deletingBus is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-[92vw] md:w-[480px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="px-5 py-4">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Delete Bus</h3>
                    <p class="mt-2 text-sm text-black/60 dark:text-white/60">Delete this @GetDirectionLabel(deletingBus.Direction) bus (@deletingBus.PickupLocation → @deletingBus.DestinationLocation)? This also removes its reservations.</p>
                </div>
                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10" @onclick="CloseDeleteModal">Cancel</button>
                    <button type="button" class="btn border border-danger text-danger hover:bg-danger hover:text-white disabled:opacity-50" disabled="@isSaving" @onclick="DeleteAsync">@(isSaving ? "Deleting..." : "Delete")</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<EditionDto> editions = [];
    private List<PassTypeDto> passTypes = [];
    private List<FestivalDto> festivals = [];
    private List<BusDto> buses = [];
    private Guid selectedFestivalId;
    private Guid selectedEditionId;
    private int directionFilter;
    private int pageSize = 10;
    private int currentPage = 1;

    private bool isLoading = true;
    private bool isSaving;
    private bool showModal;
    private string? successMessage;
    private string? errorMessage;

    private BusDto? editingBus;
    private BusDto? deletingBus;

    private int formDirection = 1;
    private DateTime formDepartureTime = DateTime.Today.AddHours(9);
    private string formPickupLocation = string.Empty;
    private string formDestinationLocation = string.Empty;
    private int formCapacity = 50;
    private decimal formPrice;
    private bool formIsActive = true;
    private List<Guid> formAllowedPassTypeIds = [];

    private List<EditionDto> editionsForSelectedFestival =>
        editions.Where(e => e.FestivalId == selectedFestivalId).OrderByDescending(e => e.Year).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            festivals = (await FestivalApiClient.GetAllAsync()).Where(f => f.IsActive).ToList();
            editions = (await EditionApiClient.GetAllAsync()).ToList();

            FestivalDto? preferredFestival = ActiveFestivalState.Active is not null
                ? festivals.FirstOrDefault(f => f.Id == ActiveFestivalState.Active.Id)
                : null;

            selectedFestivalId = preferredFestival?.Id
                ?? editions.FirstOrDefault(e => e.IsActive)?.FestivalId
                ?? festivals.FirstOrDefault()?.Id
                ?? Guid.Empty;

            EditionDto? preferredEdition = editionsForSelectedFestival.FirstOrDefault(e => e.IsActive)
                ?? editionsForSelectedFestival.FirstOrDefault();

            selectedEditionId = preferredEdition?.Id ?? Guid.Empty;

            if (selectedEditionId != Guid.Empty)
            {
                await LoadDataAsync();
            }
            else
            {
                isLoading = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isLoading = false;
        }
    }

    private async Task OnFestivalChangedAsync()
    {
        EditionDto? preferredEdition = editionsForSelectedFestival.FirstOrDefault(e => e.IsActive)
            ?? editionsForSelectedFestival.FirstOrDefault();

        selectedEditionId = preferredEdition?.Id ?? Guid.Empty;

        if (selectedEditionId != Guid.Empty)
        {
            await LoadDataAsync();
        }
        else
        {
            buses = [];
        }
    }

    private async Task OnEditionChangedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            buses = (await BusApiClient.GetAllAsync(selectedEditionId)).ToList();
            passTypes = (await PassTypeApiClient.GetByEditionIdAsync(selectedEditionId)).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<BusDto> FilteredBuses =>
        directionFilter == 0 ? buses : buses.Where(b => b.Direction == directionFilter).ToList();

    private string sortColumn = "Departure";
    private bool sortAscending = true;

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }

        ResetPage();
    }

    private string GetSortIcon(string column)
    {
        if (sortColumn != column)
        {
            return string.Empty;
        }

        return sortAscending ? "▲" : "▼";
    }

    private List<BusDto> SortedFilteredBuses
    {
        get
        {
            IEnumerable<BusDto> query = FilteredBuses;

            query = sortColumn switch
            {
                "Direction" => sortAscending ? query.OrderBy(b => b.Direction) : query.OrderByDescending(b => b.Direction),
                _ => sortAscending ? query.OrderBy(b => b.DepartureTime) : query.OrderByDescending(b => b.DepartureTime)
            };

            return query.ToList();
        }
    }

    private List<BusDto> PagedBuses => SortedFilteredBuses.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredBuses.Count / (double)pageSize));
    private int StartRow => FilteredBuses.Count == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int EndRow => Math.Min(currentPage * pageSize, FilteredBuses.Count);

    private void ResetPage()
    {
        currentPage = 1;
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
        }
    }

    private void OpenCreateModal()
    {
        editingBus = null;
        formDirection = 1;
        formDepartureTime = DateTime.Today.AddHours(9);
        formPickupLocation = string.Empty;
        formDestinationLocation = string.Empty;
        formCapacity = 50;
        formPrice = 0;
        formIsActive = true;
        formAllowedPassTypeIds = [];
        showModal = true;
    }

    private void OpenEditModal(BusDto bus)
    {
        editingBus = bus;
        formDirection = bus.Direction;
        formDepartureTime = bus.DepartureTime;
        formPickupLocation = bus.PickupLocation;
        formDestinationLocation = bus.DestinationLocation;
        formCapacity = bus.Capacity;
        formPrice = bus.Price;
        formIsActive = bus.IsActive;
        formAllowedPassTypeIds = bus.AllowedPassTypeIds.ToList();
        showModal = true;
    }

    private void TogglePassType(Guid passTypeId, bool isChecked)
    {
        if (isChecked && !formAllowedPassTypeIds.Contains(passTypeId))
        {
            formAllowedPassTypeIds.Add(passTypeId);
        }
        else if (!isChecked)
        {
            formAllowedPassTypeIds.Remove(passTypeId);
        }
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private void ShowSuccess(string message)
    {
        successMessage = message;
        errorMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            successMessage = null;
            StateHasChanged();
        });
    }

    private void ShowError(string message)
    {
        errorMessage = message;
        successMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            errorMessage = null;
            StateHasChanged();
        });
    }

    private async Task SaveAsync()
    {
        try
        {
            if (editingBus is null)
            {
                CreateBusRequest request = new()
                {
                    EditionId = selectedEditionId,
                    Direction = formDirection,
                    DepartureTime = formDepartureTime,
                    PickupLocation = formPickupLocation,
                    DestinationLocation = formDestinationLocation,
                    Capacity = formCapacity,
                    Price = formPrice,
                    AllowedPassTypeIds = formAllowedPassTypeIds
                };

                await BusApiClient.CreateAsync(request);
                ShowSuccess("Bus created successfully.");
            }
            else
            {
                UpdateBusRequest request = new()
                {
                    Direction = formDirection,
                    DepartureTime = formDepartureTime,
                    PickupLocation = formPickupLocation,
                    DestinationLocation = formDestinationLocation,
                    Capacity = formCapacity,
                    Price = formPrice,
                    IsActive = formIsActive,
                    AllowedPassTypeIds = formAllowedPassTypeIds
                };

                await BusApiClient.UpdateAsync(editingBus.Id, request);
                ShowSuccess("Bus updated successfully.");
            }

            showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
    }

    private void OpenDeleteModal(BusDto bus)
    {
        deletingBus = bus;
    }

    private void CloseDeleteModal()
    {
        deletingBus = null;
    }

    private async Task DeleteAsync()
    {
        if (deletingBus is null)
        {
            return;
        }

        isSaving = true;

        try
        {
            await BusApiClient.DeleteAsync(deletingBus.Id);
            ShowSuccess("Bus deleted successfully.");
            deletingBus = null;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private static string GetMapsUrl(string location)
    {
        return $"https://www.google.com/maps/search/?api=1&query={Uri.EscapeDataString(location)}";
    }

    private static string GetDirectionLabel(int direction) => direction switch
    {
        1 => "Departure",
        2 => "Return",
        _ => "-"
    };

    private static string GetStatusClass(bool isActive)
    {
        return isActive ? "inline-block rounded text-xs px-2 py-1 bg-success/10 text-success" : "inline-block rounded text-xs px-2 py-1 bg-danger/10 text-danger";
    }
}