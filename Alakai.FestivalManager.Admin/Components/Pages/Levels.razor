@if (showDeleteModal && selectedLevel is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-[92vw] md:w-[380px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="px-5 py-4">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Delete Level</h3>
                    <p class="mt-2 text-sm text-black/60 dark:text-white/50">Are you sure you want to delete <strong>@selectedLevel.Name</strong>?</p>

                    @if (!string.IsNullOrWhiteSpace(modalErrorMessage))
                    {
                        <div class="p-3 mt-4 text-sm rounded bg-danger/10 text-danger">@modalErrorMessage</div>
                    }
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="btn border border-black/10" disabled="@isSaving" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="btn border border-danger text-danger hover:bg-danger hover:text-white disabled:opacity-50" disabled="@isSaving" @onclick="DeleteLevelAsync">
                        @(isSaving ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<LevelDto> allLevels = [];
    private List<PassTypeDto> passTypes = new();
    private List<EditionDto> editions = new();
    private bool showDeleteModal;
    private LevelDto? selectedLevel;
    private CreateLevelRequest createRequest = new();
    private UpdateLevelRequest updateRequest = new();
    private Guid modalSelectedEdition = Guid.Empty;
    private List<PassTypeDto> passTypesForModal = new();

    private string searchText = string.Empty;
    private Guid? editionFilter;
    private Guid? passTypeFilter;
    private string statusFilter = "All";
    private int pageSize = 10;
    private int currentPage = 1;

    private bool isLoading = true;
    private bool isSaving;
    private bool showCreateModal;
    private bool showEditModal;

    private string? successMessage;
    private string? errorMessage;
    private string? modalErrorMessage;

    private string sortColumn = "Name";
    private bool sortAscending = true;

    private IReadOnlyList<LevelDto> FilteredLevels
    {
        get
        {
            IEnumerable<LevelDto> query = allLevels;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(l =>
                    l.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    (!string.IsNullOrWhiteSpace(l.Description) && l.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase)));
            }

            if (passTypeFilter is not null && passTypeFilter != Guid.Empty)
            {
                query = query.Where(l => l.PassTypeId == passTypeFilter);
            }

            if (editionFilter is not null && editionFilter != Guid.Empty)
            {
                query = query.Where(l => passTypes.Any(pt => pt.Id == l.PassTypeId && pt.EditionId == editionFilter));
            }

            query = statusFilter switch
            {
                "Active" => query.Where(l => l.IsActive),
                "Inactive" => query.Where(l => !l.IsActive),
                _ => query
            };

            query = sortColumn switch
            {
                "Name" => sortAscending ? query.OrderBy(l => l.Name) : query.OrderByDescending(l => l.Name),
                // Sort by pass type name via lookup in passTypes list
                "PassType" => sortAscending
                    ? query.OrderBy(l => passTypes.FirstOrDefault(pt => pt.Id == l.PassTypeId)?.Name ?? string.Empty)
                    : query.OrderByDescending(l => passTypes.FirstOrDefault(pt => pt.Id == l.PassTypeId)?.Name ?? string.Empty),
                "SortOrder" => sortAscending ? query.OrderBy(l => l.SortOrder) : query.OrderByDescending(l => l.SortOrder),
                "Status" => sortAscending ? query.OrderBy(l => l.IsActive) : query.OrderByDescending(l => l.IsActive),
                _ => query
            };

            return query.ToList();
        }
    }


    private IReadOnlyList<LevelDto> PagedLevels => FilteredLevels.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredLevels.Count / pageSize));
    private int ShowingFrom => FilteredLevels.Count == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int ShowingTo => Math.Min(currentPage * pageSize, FilteredLevels.Count);

    protected override async Task OnInitializedAsync()
    {
        await LoadPassTypesAsync();
        await LoadEditionsAsync();
        await LoadLevelsAsync();
    }

    private async Task LoadPassTypesAsync()
    {
        try
        {
            passTypes = (await PassTypeApiClient.GetAllAsync()).ToList();
        }
        catch
        {
            passTypes = new List<PassTypeDto>();
        }
    }

    private async Task LoadEditionsAsync()
    {
        try
        {
            // use injected instance (EditionApiClient) rather than the type name
            editions = (await EditionApiClient.GetAllAsync()).ToList();
        }
        catch
        {
            editions = new List<EditionDto>();
        }
    }

    private async Task LoadLevelsAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            allLevels = await LevelApiClient.GetAllAsync();
            NormalizePage();
        }
        catch (ApiClientException ex)
        {
            errorMessage = BuildErrorMessage(ex);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetPage()
    {
        currentPage = 1;
        NormalizePage();
    }

    private void NormalizePage()
    {
        if (currentPage > TotalPages)
        {
            currentPage = TotalPages;
        }

        if (currentPage < 1)
        {
            currentPage = 1;
        }
    }

    private void PreviousPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < TotalPages) currentPage++; }

    private void OnModalEditionChanged()
    {
        if (modalSelectedEdition == Guid.Empty)
        {
            passTypesForModal = new List<PassTypeDto>();
        }
        else
        {
            passTypesForModal = passTypes.Where(pt => pt.EditionId == modalSelectedEdition).ToList();
        }

        // Reset selection for create/update when necessary
        if (showCreateModal)
        {
            createRequest.PassTypeId = passTypesForModal.FirstOrDefault()?.Id ?? Guid.Empty;
        }
        else if (showEditModal)
        {
            if (!passTypesForModal.Any(pt => pt.Id == updateRequest.PassTypeId))
            {
                updateRequest.PassTypeId = Guid.Empty;
            }
        }
    }

    private void OpenCreateModal()
    {
        modalErrorMessage = null;

        // default modal edition to page filter (if any)
        modalSelectedEdition = editionFilter ?? Guid.Empty;
        OnModalEditionChanged();

        createRequest = new CreateLevelRequest
        {
            PassTypeId = Guid.Empty,
            Name = string.Empty,
            Description = string.Empty,
            EarlyBirdPrice = 0m,
            GroupPrice = 0m,
            RegularPrice = 0m,
            LeaderCapacity = null,
            FollowerCapacity = null,
            IndividualCapacity = null,
            MaxLeaderDifference = null,
            MaxFollowerDifference = null,
            SortOrder = 0
        };

        showCreateModal = true;
    }

    private void OpenEditModal(LevelDto level)
    {
        selectedLevel = level;
        modalErrorMessage = null;

        // set modal edition based on level's pass type -> edition
        modalSelectedEdition = passTypes.FirstOrDefault(pt => pt.Id == level.PassTypeId)?.EditionId ?? Guid.Empty;
        OnModalEditionChanged();

        updateRequest = new UpdateLevelRequest
        {
            PassTypeId = level.PassTypeId,
            Name = level.Name,
            Description = level.Description,
            EarlyBirdPrice = level.EarlyBirdPrice,
            GroupPrice = level.GroupPrice,
            RegularPrice = level.RegularPrice,
            LeaderCapacity = level.LeaderCapacity,
            FollowerCapacity = level.FollowerCapacity,
            IndividualCapacity = level.IndividualCapacity,
            MaxLeaderDifference = level.MaxLeaderDifference,
            MaxFollowerDifference = level.MaxFollowerDifference,
            SortOrder = level.SortOrder,
            IsActive = level.IsActive
        };

        showEditModal = true;
    }

    private void OpenDeleteModal(LevelDto level)
    {
        selectedLevel = level;
        modalErrorMessage = null;
        showDeleteModal = true;
    }

    private void CloseModals()
    {
        showCreateModal = false;
        showDeleteModal = false;
        showEditModal = false;
        modalErrorMessage = null;
        isSaving = false;
    }

    private async Task CreateLevelAsync()
    {
        if (isSaving) return;

        try
        {
            isSaving = true;
            modalErrorMessage = null;
            await LevelApiClient.CreateAsync(createRequest);
            CloseModals();
            successMessage = "Level created successfully.";
            _ = ClearMessagesAfterDelayAsync();
            await LoadLevelsAsync();
        }
        catch (ApiClientException ex)
        {
            modalErrorMessage = BuildErrorMessage(ex);
        }
        catch (Exception ex)
        {
            modalErrorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task UpdateLevelAsync()
    {
        if (isSaving || selectedLevel is null) return;

        try
        {
            isSaving = true;
            await LevelApiClient.UpdateAsync(selectedLevel.Id, updateRequest);
            CloseModals();
            successMessage = "Level updated successfully.";
            _ = ClearMessagesAfterDelayAsync();
            await LoadLevelsAsync();
        }
        catch (ApiClientException ex)
        {
            modalErrorMessage = BuildErrorMessage(ex);
        }
        catch (Exception ex)
        {
            modalErrorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }


    private bool ConfirmDelete(string name) => true;

    private async Task DeleteLevelAsync()
    {
        if (isSaving || selectedLevel is null) return;

        try
        {
            isSaving = true;
            await LevelApiClient.DeleteAsync(selectedLevel.Id);
            CloseModals();
            successMessage = "Level deleted successfully.";
            _ = ClearMessagesAfterDelayAsync();
            await LoadLevelsAsync();
        }
        catch (ApiClientException ex)
        {
            errorMessage = BuildErrorMessage(ex);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetPassTypeName(Guid passTypeId)
    {
        PassTypeDto? pt = passTypes.FirstOrDefault(p => p.Id == passTypeId);
        return pt is null ? passTypeId.ToString() : pt.Name;
    }

    private void SortBy(string column)
    {
        if (sortColumn == column) sortAscending = !sortAscending;
        else { sortColumn = column; sortAscending = true; }
        ResetPage();
    }

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column) return new MarkupString("<i class=\"ri-arrow-up-down-fill text-xs text-black/30\"></i>");
        string icon = sortAscending ? "ri-arrow-up-fill" : "ri-arrow-down-fill";
        return new MarkupString($"<i class=\"{icon} text-xs text-purple\"></i>");
    }

    private async Task ClearMessagesAfterDelayAsync()
    {
        await Task.Delay(3500);
        successMessage = null;
        errorMessage = null;
        modalErrorMessage = null;
        await InvokeAsync(StateHasChanged);
    }

    private static string BuildErrorMessage(ApiClientException exception)
    {
        if (exception.Errors.Count == 0) return exception.Message;
        return $"{exception.Message} {string.Join(" ", exception.Errors)}";
    }
}