@page "/levels"
@using Alakai.FestivalManager.Admin.Components.Layout
@using Alakai.FestivalManager.Admin.Contracts.Editions.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Levels
@using Alakai.FestivalManager.Admin.Contracts.Levels.Requests
@using Alakai.FestivalManager.Admin.Contracts.Levels.Responses
@using Alakai.FestivalManager.Admin.Contracts.PassTypes
@using Alakai.FestivalManager.Admin.Contracts.Editions
@using Alakai.FestivalManager.Admin.Services.Api
@inject LevelApiClient LevelApiClient
@inject PassTypeApiClient PassTypeApiClient
@inject EditionApiClient EditionApiClient

<PageHeader Title="Configuration" pTitle="Levels"></PageHeader>

<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)]">
    <div class="grid grid-cols-1 gap-4">
        <div class="card">
            <div class="flex flex-col gap-4 mb-5 xl:flex-row xl:items-center xl:justify-between">
                <div>
                    <h2 class="text-base font-semibold text-black capitalize dark:text-white">Levels</h2>
                    <p class="text-sm text-black/50 dark:text-white/40">Manage level configuration.</p>
                </div>

                <div class="flex flex-col gap-3 md:flex-row md:items-center">
                    <div class="relative w-full md:w-72">
                        <input class="form-input" placeholder="Search levels..." @bind="searchText" @bind:event="oninput" @bind:after="ResetPage" />
                    </div>

                    <select class="form-select w-full md:w-44" @bind="editionFilter" @bind:after="ResetPage">
                        <option value="@Guid.Empty">All editions</option>
                        @foreach (EditionDto ed in editions)
                        {
                            <option value="@ed.Id">@($"{ed.Year} - {ed.Name}")</option>
                        }
                    </select>

                    <select class="form-select w-full md:w-44" @bind="passTypeFilter" @bind:after="ResetPage">
                        <option value="@Guid.Empty">All pass types</option>
                        @foreach (PassTypeDto pt in passTypes)
                        {
                            <option value="@pt.Id">@pt.Name</option>
                        }
                    </select>

                    <select class="form-select w-full md:w-32" @bind="statusFilter" @bind:after="ResetPage">
                        <option value="All">All statuses</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>

                    <select class="form-select w-full md:w-32" @bind="pageSize" @bind:after="ResetPage">
                        <option value="5">5 rows</option>
                        <option value="10">10 rows</option>
                        <option value="25">25 rows</option>
                        <option value="50">50 rows</option>
                    </select>

                    <button type="button" class="transition-all duration-300 border rounded-md btn text-purple border-purple hover:bg-purple hover:text-white whitespace-nowrap" @onclick="OpenCreateModal">
                        <i class="ri-add-line ltr:mr-1 rtl:ml-1"></i>
                        New Level
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">
                    @successMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">
                    @errorMessage
                </div>
            }

            @if (isLoading)
            {
                <p class="text-sm text-black/50 dark:text-white/40">Loading levels...</p>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full table-hover">
                        <thead class="bg-gray-50 dark:bg-dark">
                            <tr class="text-left">
                                <th class="px-4 py-3 font-semibold">
                                    <button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Name")'>
                                        Name
                                        @SortIcon("Name")
                                    </button>
                                </th>
                                <th class="px-4 py-3 font-semibold">
                                    <button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("PassType")'>
                                        Pass Type
                                        @SortIcon("PassType")
                                    </button>
                                </th>
                                <th class="px-4 py-3 font-semibold">Early</th>
                                <th class="px-4 py-3 font-semibold">Group</th>
                                <th class="px-4 py-3 font-semibold">Regular</th>
                                <th class="px-4 py-3 font-semibold">
                                    <button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("SortOrder")'>
                                        Sort
                                        @SortIcon("SortOrder")
                                    </button>
                                </th>
                                <th class="px-4 py-3 font-semibold">
                                    <button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Status")'>
                                        Status
                                        @SortIcon("Status")
                                    </button>
                                </th>
                                <th class="px-4 py-3 font-semibold text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (PagedLevels.Count == 0)
                            {
                                <tr>
                                    <td colspan="8" class="px-4 py-6 text-center text-black/50 dark:text-white/40">No levels found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (LevelDto level in PagedLevels)
                                {
                                    <tr class="border-b border-black/10 dark:border-darkborder">
                                        <td class="px-4 py-3">@level.Name</td>
                                        <td class="px-4 py-3">@GetPassTypeName(level.PassTypeId)</td>
                                        <td class="px-4 py-3">@level.EarlyBirdPrice.ToString("0.00")</td>
                                        <td class="px-4 py-3">@level.GroupPrice.ToString("0.00")</td>
                                        <td class="px-4 py-3">@level.RegularPrice.ToString("0.00")</td>
                                        <td class="px-4 py-3">@level.SortOrder</td>
                                        <td class="px-4 py-3">
                                            @if (level.IsActive)
                                            {
                                                <span class="inline-block rounded text-xs px-2 py-1 bg-success/10 text-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="inline-block rounded text-xs px-2 py-1 bg-danger/10 text-danger">Inactive</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3">
                                            <div class="flex items-center justify-end gap-3">
                                                <button type="button" class="text-black dark:text-white/80" title="Edit" @onclick="() => OpenEditModal(level)">
                                                    <i class="ri-pencil-line text-lg"></i>
                                                </button>
                                                <button type="button" class="text-danger" title="Delete" @onclick="() => OpenDeleteModal(level)">
                                                    <i class="ri-delete-bin-line text-lg"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="flex items-center justify-between mt-4">
                    <p class="text-sm text-black/50 dark:text-white/40">
                        Showing @ShowingFrom to @ShowingTo of @FilteredLevels.Count levels
                    </p>

                    <div class="flex items-center gap-2">
                        <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                        <span class="flex items-center justify-center w-10 h-10 text-sm rounded-md bg-purple/10 text-purple">@currentPage</span>
                        <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage >= TotalPages)" @onclick="NextPage">Next</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (showCreateModal)
{
