        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <!-- Create modal container: replace the existing 'relative w-full max-w-xl ...' div with this -->
            <div class="relative mx-auto overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder" style="width: min(95vw, 720px);">
                <div class="flex items-center justify-between px-5 py-3 border-b border-black/10 dark:border-darkborder">
                    <h3 class="text-lg font-semibold text-black dark:text-white">New Level</h3>
