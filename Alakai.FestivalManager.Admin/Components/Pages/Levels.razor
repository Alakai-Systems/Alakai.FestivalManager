                        <div class="p-3 text-sm rounded bg-danger/10 text-danger">@modalErrorMessage</div>
                    }

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Edition</label>
                            <select class="form-select" @bind="modalSelectedEdition" @bind:after="OnModalEditionChanged">
                                <option value="@Guid.Empty">Select edition</option>
                                @foreach (EditionDto ed in editions)
                                {
                                    <option value="@ed.Id">@($"{ed.Year} - {ed.Name}")</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Pass Type</label>
                            <select class="form-select" @bind="createRequest.PassTypeId">
                                <option value="@Guid.Empty">Select pass type</option>
                                @foreach (PassTypeDto pt in passTypesForModal)
                                {
                                    <option value="@pt.Id">@pt.Name</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Name</label>
                            <input class="form-input" placeholder="Name" @bind="createRequest.Name" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm text-black/60 dark:text-white/60">Description</label>
                            <textarea class="form-input" placeholder="Description" rows="2" @bind="createRequest.Description"></textarea>
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Early bird price</label>
                            <input class="form-input" placeholder="Early bird price" type="number" step="0.01" @bind="createRequest.EarlyBirdPrice" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Group price</label>
                            <input class="form-input" placeholder="Group price" type="number" step="0.01" @bind="createRequest.GroupPrice" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Regular price</label>
                            <input class="form-input" placeholder="Regular price" type="number" step="0.01" @bind="createRequest.RegularPrice" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Leader capacity</label>
                            <input class="form-input" placeholder="Leader capacity" type="number" @bind="createRequest.LeaderCapacity" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Follower capacity</label>
                            <input class="form-input" placeholder="Follower capacity" type="number" @bind="createRequest.FollowerCapacity" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Max leader difference</label>
                            <input class="form-input" placeholder="Max leader difference" type="number" @bind="createRequest.MaxLeaderDifference" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Max follower difference</label>
                            <input class="form-input" placeholder="Max follower difference" type="number" @bind="createRequest.MaxFollowerDifference" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Individual capacity</label>
                            <input class="form-input" placeholder="Individual capacity" type="number" @bind="createRequest.IndividualCapacity" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Sort order</label>
                            <input class="form-input" placeholder="Sort order" type="number" @bind="createRequest.SortOrder" />
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="btn border border-black/10" disabled="@isSaving" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="btn border border-purple text-purple hover:bg-purple hover:text-white disabled:opacity-50" disabled="@isSaving" @onclick="CreateLevelAsync">
                        @(isSaving ? "Creating..." : "Create")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

