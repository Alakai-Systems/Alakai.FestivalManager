@page "/competition-entries"
@inject CompetitionEntryApiClient CompetitionEntryApiClient
@inject CompetitionApiClient CompetitionApiClient
@inject RegistrationApiClient RegistrationApiClient
@inject EditionApiClient EditionApiClient
@inject FestivalApiClient FestivalApiClient
@inject ActiveFestivalState ActiveFestivalState

<PageHeader Title="Operations" pTitle="Competition Entries"></PageHeader>

<div class="grid grid-cols-1 gap-4 min-h-[calc(100vh-212px)]">
    <div class="card">
        <div class="flex flex-col gap-4 mb-5 xl:flex-row xl:items-center xl:justify-between">

            <div class="flex flex-col gap-3 md:flex-row md:items-center">
                <input class="form-input w-full md:w-64" placeholder="Search name or email..." @bind="searchText" @bind:event="oninput" @bind:after="ResetPage" />

                <select class="form-select w-full md:w-56" @bind="festivalFilter" @bind:after="OnFestivalFilterChanged">
                    <option value="@Guid.Empty">All festivals</option>
                    @foreach (FestivalDto f in festivals)
                    {
                        <option value="@f.Id">@f.Name</option>
                    }
                </select>

                <select class="form-select w-full md:w-56" @bind="editionFilter" @bind:after="ResetPage">
                    <option value="@Guid.Empty">All editions</option>
                    @foreach (EditionDto ed in EditionsForSelectedFestival)
                    {
                        <option value="@ed.Id">@ed.Name</option>
                    }
                </select>

                <select class="form-select w-full md:w-56" @bind="competitionFilter" @bind:after="ResetPage">
                    <option value="@Guid.Empty">All competitions</option>
                    @foreach (CompetitionDto competition in competitions)
                    {
                        <option value="@competition.Id">@competition.Name</option>
                    }
                </select>

                <select class="form-select w-full md:w-44" @bind="danceRoleFilter" @bind:after="ResetPage">
                    <option value="">All Roles</option>
                    <option value="Individual">Individual</option>
                    <option value="Follower">Follower</option>
                    <option value="Leader">Leader</option>
                </select>

                <select class="form-select w-full md:w-44" @bind="statusFilter" @bind:after="ResetPage">
                    <option value="">All statuses</option>
                    <option value="@CompetitionEntryStatus.Confirmed">Confirmed</option>
                    <option value="@CompetitionEntryStatus.WaitingPartner">Waiting Partner</option>
                    <option value="@CompetitionEntryStatus.Cancelled">Cancelled</option>
                </select>

                <select class="form-select w-full md:w-32" @bind="pageSize" @bind:after="ResetPage">
                    <option value="50">50 rows</option>
                    <option value="100">100 rows</option>
                    <option value="200">200 rows</option>
                </select>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">@successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">@errorMessage</div>
        }

        @if (isLoading)
        {
            <p class="text-sm text-black/50 dark:text-white/60">Loading competition entries...</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full table-hover">
                    <thead class="bg-gray-50 dark:bg-dark">
                        <tr class="text-left">
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Registration")'>Registration @SortIcon("Registration")</button></th>
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Competition")'>Competition @SortIcon("Competition")</button></th>
                            <th class="px-4 py-3 font-semibold">Partner</th>
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Role")'>Role @SortIcon("Role")</button></th>
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Status")'>Status @SortIcon("Status")</button></th>
                            <th class="px-4 py-3 font-semibold">Date</th>
                            <th class="px-4 py-3 font-semibold text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="text-black dark:text-white/80">
                        @if (PagedEntries.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="px-4 py-6 text-center text-black/50 dark:text-white/60">No competition entries found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (CompetitionEntryDto entry in PagedEntries)
                            {
                                <tr class="border-b border-black/10 dark:border-darkborder">
                                    <td class="px-4 py-3">@GetRegistrationName(entry.RegistrationId)</td>
                                    <td class="px-4 py-3">@GetCompetitionName(entry.CompetitionId)</td>
                                    <td class="px-4 py-3">@FormatPartner(entry)</td>
                                    <td class="px-4 py-3">@entry.DanceRole</td>
                                    <td class="px-4 py-3"><span class="@GetStatusClass(entry.Status)">@entry.Status</span></td>
                                    <td class="px-4 py-3">@entry.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center justify-end gap-3">
                                            <button type="button" class="text-black dark:text-white/80" title="Edit" @onclick="() => OpenEditModal(entry)"><i class="ri-pencil-line text-lg"></i></button>
                                            <button type="button" class="text-danger" title="Delete" @onclick="() => OpenDeleteModal(entry)"><i class="ri-delete-bin-line text-lg"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="flex items-center justify-between mt-4">
                <p class="text-sm text-black/50 dark:text-white/60">
                    Showing @StartRow to @EndRow of @FilteredEntries.Count entries
                </p>

                <div class="flex items-center gap-2">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                    <span class="flex items-center justify-center w-10 h-10 text-sm rounded-md bg-purple/10 text-purple">@currentPage</span>
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage >= TotalPages)" @onclick="NextPage">Next</button>
                </div>
            </div>
        }
    </div>
</div>

@if (editingEntry is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-full max-w-xl mx-auto overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="flex items-center justify-between px-5 py-3 border-b border-black/10 dark:border-darkborder">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Edit Competition Entry</h3>
                    <button type="button" class="text-black/50 hover:text-black dark:text-white/60" @onclick="CloseEditModal"><i class="ri-close-line text-2xl"></i></button>
                </div>

                <div class="p-5 space-y-4">
                    <div>
                        <label class="block text-sm text-black/60 dark:text-white/60">Competition</label>
                        <select class="form-select" @bind="editModel.CompetitionId" @bind:after="OnEditCompetitionChanged">
                            @foreach (CompetitionDto competition in competitions)
                            {
                                <option value="@competition.Id">@competition.Name</option>
                            }
                        </select>
                    </div>

                    @if (EditSelectedCompetitionHasLevels)
                    {
                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Level</label>
                            <select class="form-select" @bind="editModel.SelectedLevelId">
                                <option value="@Guid.Empty">Select level</option>
                                @foreach (CompetitionLevelDto level in EditSelectedCompetitionLevels)
                                {
                                    <option value="@level.Id">@level.Name</option>
                                }
                            </select>
                        </div>
                    }

                    @if (EditSelectedCompetitionRequiresRole)
                    {
                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Role</label>
                            <select class="form-select" @bind="editModel.DanceRole">
                                <option value="@DanceRole.Leader">Leader</option>
                                <option value="@DanceRole.Follower">Follower</option>
                                <option value="@DanceRole.Individual">Individual</option>
                            </select>
                        </div>
                    }

                    <div>
                        <label class="block text-sm text-black/60 dark:text-white/60">Status</label>
                        <select class="form-select" @bind="editModel.Status">
                            <option value="@CompetitionEntryStatus.Confirmed">Confirmed</option>
                            <option value="@CompetitionEntryStatus.WaitingPartner">Waiting Partner</option>
                            <option value="@CompetitionEntryStatus.Cancelled">Cancelled</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm text-black/60 dark:text-white/60">Notes</label>
                        <InputTextArea class="form-input" rows="2" @bind-Value="editModel.Notes" />
                    </div>

                    <div>
                        <label class="block text-sm text-black/60 dark:text-white/60">Internal Notes</label>
                        <InputTextArea class="form-input" rows="2" @bind-Value="editModel.InternalNotes" />
                    </div>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10" @onclick="CloseEditModal">Cancel</button>
                    <button type="button" class="px-4 py-2 text-sm text-white rounded-md bg-purple" @onclick="SaveEditAsync">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (deletingEntry is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-[92vw] md:w-[380px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="px-5 py-4">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Delete Competition Entry</h3>
                    <p class="mt-2 text-sm text-black/60 dark:text-white/60">Are you sure you want to delete <strong>@GetCompetitionName(@deletingEntry.CompetitionId)</strong> for<strong>@GetRegistrationName(@deletingEntry.RegistrationId)</strong>?</p>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10" @onclick="CloseDeleteModal">Cancel</button>
                    <button type="button" class="px-4 py-2 text-sm text-white rounded-md bg-danger" @onclick="DeleteAsync">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@implements IDisposable
@code {
    private List<CompetitionEntryDto> entries = [];
    private List<CompetitionDto> competitions = [];
    private List<RegistrationDto> registrations = [];
    private List<EditionDto> editions = [];
    private List<FestivalDto> festivals = [];
    private Guid festivalFilter = Guid.Empty;
    private Guid editionFilter = Guid.Empty;

    private List<EditionDto> EditionsForSelectedFestival =>
        festivalFilter == Guid.Empty
            ? editions
            : editions.Where(e => e.FestivalId == festivalFilter).ToList();

    private void OnFestivalFilterChanged()
    {
        editionFilter = Guid.Empty;
        ResetPage();
    }
    private CompetitionEntryDto? editingEntry;
    private CompetitionEntryDto? deletingEntry;
    private CompetitionEntryEditModel editModel = new();
    private Guid competitionFilter = Guid.Empty;
    private Guid registrationFilter = Guid.Empty;
    private string statusFilter = string.Empty;
    private string danceRoleFilter = string.Empty;
    private string activeFilter = string.Empty;
    private bool isLoading = true;
    private string searchText = string.Empty;
    private string? successMessage;
    private string? errorMessage;
    private int currentPage = 1;
    private int pageSize = 50;
    private bool sortAscending = true;
    private string sortColumn = "Name";

    protected override async Task OnInitializedAsync()
    {
        ActiveFestivalState.OnChange += HandleFestivalStateChanged;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            entries = (await CompetitionEntryApiClient.GetAllAsync()).ToList();
            competitions = (await CompetitionApiClient.GetAllAsync()).ToList();
            registrations = (await RegistrationApiClient.GetAllAsync()).ToList();
            editions = (await EditionApiClient.GetAllAsync()).ToList();
            festivals = (await FestivalApiClient.GetAllAsync()).ToList();

            if (ActiveFestivalState.Active is not null)
            {
                festivalFilter = ActiveFestivalState.Active.Id;

                EditionDto? preferred = editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id && e.IsActive)
                    ?? editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id);

                editionFilter = preferred?.Id ?? Guid.Empty;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<CompetitionEntryDto> FilteredEntries
    {
        get
        {
            IEnumerable<CompetitionEntryDto> query = entries;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(e => (e.FirstName + " " + e.LastName).Contains(searchText, StringComparison.OrdinalIgnoreCase) || e.Email.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            if (competitionFilter != Guid.Empty)
            {
                query = query.Where(e => e.CompetitionId == competitionFilter);
            }
            else if (editionFilter != Guid.Empty)
            {
                HashSet<Guid> competitionIds = competitions.Where(c => c.EditionId == editionFilter).Select(c => c.Id).ToHashSet();
                query = query.Where(e => competitionIds.Contains(e.CompetitionId));
            }
            else if (festivalFilter != Guid.Empty)
            {
                HashSet<Guid> editionIds = editions.Where(e => e.FestivalId == festivalFilter).Select(e => e.Id).ToHashSet();
                HashSet<Guid> competitionIds = competitions.Where(c => editionIds.Contains(c.EditionId)).Select(c => c.Id).ToHashSet();
                query = query.Where(e => competitionIds.Contains(e.CompetitionId));
            }

            if (registrationFilter != Guid.Empty)
            {
                query = query.Where(e => e.RegistrationId == registrationFilter);
            }

            if (Enum.TryParse(danceRoleFilter, out DanceRole danceRole))
            {
                query = query.Where(e => e.DanceRole == danceRole);
            }

            if (Enum.TryParse(statusFilter, out CompetitionEntryStatus status))
            {
                query = query.Where(e => e.Status == status);
            }

            query = sortColumn switch
            {
                "Competition" => sortAscending ? query.OrderBy(r => GetCompetitionName(r.CompetitionId)) : query.OrderByDescending(r => GetCompetitionName(r.CompetitionId)),
                "Registration" => sortAscending ? query.OrderBy(r => r.DanceRole) : query.OrderByDescending(r => r.DanceRole),
                "Role" => sortAscending ? query.OrderBy(r => r.DanceRole) : query.OrderByDescending(r => r.DanceRole),
                "Status" => sortAscending ? query.OrderBy(r => r.Status) : query.OrderByDescending(r => r.Status),
                _ => sortAscending ? query.OrderBy(r => r.RegistrationId) : query.OrderByDescending(r => r.RegistrationId)
            };

            return query.ToList();
        }
    }

    private List<CompetitionEntryDto> PagedEntries => FilteredEntries.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();

    private void ResetPage()
    {
        currentPage = 1;
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column)
        {
            return new MarkupString("<i class=\"ri-arrow-up-down-line text-xs opacity-40\"></i>");
        }

        return new MarkupString(sortAscending ? "<i class=\"ri-arrow-up-s-fill text-xs text-purple\"></i>" : "<i class=\"ri-arrow-down-s-fill text-xs text-purple\"></i>");
    }

    private IEnumerable<CompetitionEntryDto> PagedRegistrations => FilteredEntries.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredEntries.Count / (double)pageSize));
    private int StartRow => FilteredEntries.Count == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int EndRow => Math.Min(currentPage * pageSize, FilteredEntries.Count);

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }
    private void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
        }
    }

    private string GetCompetitionName(Guid competitionId)
    {
        return competitions.FirstOrDefault(c => c.Id == competitionId)?.Name ?? competitionId.ToString();
    }

    private string GetRegistrationName(Guid registrationId)
    {
        string firstName = registrations.FirstOrDefault(c => c.Id == registrationId)?.FirstName ?? registrationId.ToString();
        string lastName = registrations.FirstOrDefault(c => c.Id == registrationId)?.LastName ?? registrationId.ToString();
        string registrationName = $"{firstName} {lastName}";

        return registrationName;
    }

    private string FormatPartner(CompetitionEntryDto entry)
    {
        string firstName = registrations.FirstOrDefault(c => c.Id == entry.PartnerRegistrationId)?.FirstName ?? string.Empty;
        string lastName = registrations.FirstOrDefault(c => c.Id == entry.PartnerRegistrationId)?.LastName ?? string.Empty;
        string registrationName = firstName + lastName;

        return entry.PartnerRegistrationId.HasValue ? registrationName : "-";
    }

    private static string GetStatusClass(CompetitionEntryStatus status)
    {
        return status switch
        {
            CompetitionEntryStatus.Confirmed => "inline-block rounded text-xs px-2 py-1 bg-success/10 text-success",
            CompetitionEntryStatus.WaitingPartner => "inline-block rounded text-xs px-2 py-1 bg-warning/10 text-warning",
            CompetitionEntryStatus.Cancelled => "inline-block rounded text-xs px-2 py-1 bg-danger/10 text-danger",
            _ => "inline-block rounded text-xs px-2 py-1 bg-black/10 text-black dark:bg-white/10 dark:text-white"
        };
    }

    private CompetitionDto? EditSelectedCompetition =>
        competitions.FirstOrDefault(c => c.Id == editModel.CompetitionId);

    private bool EditSelectedCompetitionRequiresRole =>
        EditSelectedCompetition?.RequiresRole ?? false;

    private IReadOnlyList<CompetitionLevelDto> EditSelectedCompetitionLevels =>
        EditSelectedCompetition?.Levels.OrderBy(l => l.SortOrder).ToList() ?? [];

    private bool EditSelectedCompetitionHasLevels =>
        EditSelectedCompetitionLevels.Count > 0;

    private void OnEditCompetitionChanged()
    {
        editModel.SelectedLevelId = Guid.Empty;
        editModel.DanceRole = null;
        ResolveEditCapacityId();
    }

    private void ResolveEditCapacityId()
    {
        CompetitionDto? comp = EditSelectedCompetition;

        if (comp is null)
        {
            editModel.CompetitionCapacityId = Guid.Empty;
            return;
        }

        Guid? levelId = editModel.SelectedLevelId != Guid.Empty ? editModel.SelectedLevelId : null;

        CompetitionCapacityDto? cap = comp.Capacities.FirstOrDefault(c =>
            c.IsActive &&
            c.CompetitionLevelId == levelId &&
            (!comp.RequiresRole || c.DanceRole == editModel.DanceRole));

        editModel.CompetitionCapacityId = cap?.Id ?? Guid.Empty;
    }

    private void OpenEditModal(CompetitionEntryDto entry)
    {
        editingEntry = entry;

        CompetitionDto? comp = competitions.FirstOrDefault(c => c.Id == entry.CompetitionId);
        CompetitionCapacityDto? cap = comp?.Capacities.FirstOrDefault(c => c.Id == entry.CompetitionCapacityId);
        Guid levelId = cap?.CompetitionLevelId ?? Guid.Empty;

        editModel = new CompetitionEntryEditModel
        {
            CompetitionId = entry.CompetitionId,
            RegistrationId = entry.RegistrationId,
            PartnerRegistrationId = entry.PartnerRegistrationId,
            CompetitionCapacityId = entry.CompetitionCapacityId,
            SelectedLevelId = levelId,
            DanceRole = entry.DanceRole,
            Notes = entry.Notes,
            InternalNotes = entry.InternalNotes,
            Status = entry.Status,
            CancelledAt = entry.CancelledAt,
            IsActive = entry.IsActive
        };
    }

    private void CloseEditModal()
    {
        editingEntry = null;
    }

    private void ShowSuccess(string message)
    {
        successMessage = message;
        errorMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            successMessage = null;
            StateHasChanged();
        });
    }

    private void ShowError(string message)
    {
        errorMessage = message;
        successMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            errorMessage = null;
            StateHasChanged();
        });
    }

    private async Task SaveEditAsync()
    {
        if (editingEntry is null)
        {
            return;
        }

        try
        {
            // Resolve the correct capacity from the selected level + role before saving
            ResolveEditCapacityId();

            if (editModel.CompetitionCapacityId == Guid.Empty)
            {
                ShowError("Could not find a matching capacity for the selected level/role. Please check the competition configuration.");
                return;
            }

            UpdateCompetitionEntryRequest request = new()
            {
                CompetitionId = editModel.CompetitionId,
                RegistrationId = editModel.RegistrationId,
                PartnerRegistrationId = editModel.PartnerRegistrationId,
                CompetitionCapacityId = editModel.CompetitionCapacityId,
                DanceRole = editModel.DanceRole,
                Notes = editModel.Notes,
                InternalNotes = editModel.InternalNotes,
                Status = editModel.Status,
                CancelledAt = editModel.CancelledAt,
                IsActive = editModel.IsActive
            };

            await CompetitionEntryApiClient.UpdateAsync(editingEntry.Id, request);
            successMessage = "Competition entry updated successfully.";
            editingEntry = null;

            ShowSuccess(successMessage);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            ShowError(errorMessage);
        }
    }

    private void OpenDeleteModal(CompetitionEntryDto entry)
    {
        deletingEntry = entry;
    }

    private void CloseDeleteModal()
    {
        deletingEntry = null;
    }

    private async Task DeleteAsync()
    {
        if (deletingEntry is null)
        {
            return;
        }

        try
        {
            await CompetitionEntryApiClient.DeleteAsync(deletingEntry.Id);
            successMessage = "Competition entry deleted successfully.";
            deletingEntry = null;

            ShowSuccess(successMessage);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            ShowError(errorMessage);
        }
    }

    private class CompetitionEntryEditModel
    {
        public Guid CompetitionId { get; set; }
        public Guid RegistrationId { get; set; }
        public Guid? PartnerRegistrationId { get; set; }
        public Guid CompetitionCapacityId { get; set; }
        public Guid SelectedLevelId { get; set; }
        public DanceRole? DanceRole { get; set; }
        public string? Notes { get; set; }
        public string? InternalNotes { get; set; }
        public CompetitionEntryStatus Status { get; set; }
        public DateTime? CancelledAt { get; set; }
        public bool IsActive { get; set; }
    }
    private void HandleFestivalStateChanged()
    {
        InvokeAsync(async () =>
        {
            festivalFilter = Guid.Empty;
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ActiveFestivalState.OnChange -= HandleFestivalStateChanged;
    }
}
