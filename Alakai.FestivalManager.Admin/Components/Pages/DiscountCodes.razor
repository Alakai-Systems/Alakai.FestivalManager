@page "/discount-codes"
@using Alakai.FestivalManager.Admin.Components.Layout
@using Alakai.FestivalManager.Admin.Contracts.Editions.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Festivals.DTOs

@inject DiscountCodeApiClient DiscountCodeApiClient
@inject EditionApiClient EditionApiClient
@inject FestivalApiClient FestivalApiClient
@inject ActiveFestivalState ActiveFestivalState

<PageHeader Title="Event Setup" pTitle="Discount Codes"></PageHeader>

<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)]">
    <div class="card">
        <div class="flex flex-col gap-4 mb-5 xl:flex-row xl:items-center xl:justify-between">

            <div class="flex flex-col gap-3 md:flex-row md:items-center">
                <input class="form-input md:w-72" placeholder="Search discount codes..." @bind="searchText" @bind:event="oninput" @bind:after="ResetPage" />

                <select class="form-select md:w-50" @bind="festivalFilter" @bind:after="OnFestivalFilterChanged">
                    <option value="">All festivals</option>
                    @foreach (FestivalDto f in festivals)
                    {
                        <option value="@f.Id">@f.Name</option>
                    }
                </select>

                <select class="form-select md:w-50" @bind="editionFilter" @bind:after="ResetPage">
                    <option value="">All editions</option>
                    @foreach (EditionDto edition in EditionsForSelectedFestival)
                    {
                        <option value="@edition.Id">@edition.Name</option>
                    }
                </select>

                <select class="form-select md:w-50" @bind="typeFilter" @bind:after="ResetPage">
                    <option value="">All types</option>
                    @foreach (var t in Enum.GetValues(typeof(DiscountType)))
                    {
                        <option value="@t.ToString()">@t</option>
                    }
                </select>

                <select class="form-select md:w-50" @bind="activationFilter" @bind:after="ResetPage">
                    <option value="">All activations</option>
                    @foreach (var t in Enum.GetValues(typeof(DiscountActivationType)))
                    {
                        <option value="@t.ToString()">@t</option>
                    }
                </select>

                <select class="form-select md:w-50" @bind="statusFilter" @bind:after="ResetPage">
                    <option value="">All statuses</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>

                <select class="form-select md:w-32" @bind="pageSize" @bind:after="ResetPage">
                    <option value="10">10 rows</option>
                    <option value="25">25 rows</option>
                    <option value="50">50 rows</option>
                </select>

                <button type="button" class="transition-all duration-300 border rounded-md btn text-purple border-purple hover:bg-purple hover:text-white whitespace-nowrap" @onclick="OpenCreateModal">
                    <i class="ri-add-line ltr:mr-1 rtl:ml-1"></i>
                    New Code
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">@successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">@errorMessage</div>
        }

        @if (isLoading)
        {
            <p class="text-sm text-black/50 dark:text-white/40">Loading discount codes...</p>
        }
        else
        {
            <div class="w-full max-w-full overflow-x-auto">
                <table class="w-full table-hover">
                    <thead class="bg-gray-50 dark:bg-dark">
                        <tr class="text-left">
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Code")'>Code @SortIcon("Code")</button></th>
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Name")'>Name @SortIcon("Name")</button></th>
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Type")'>Type @SortIcon("Type")</button></th>
                            <th class="px-4 py-3 font-semibold">Value</th>
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Activation")'>Activation @SortIcon("Activation")</button></th>
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Uses")'>Uses @SortIcon("Uses")</button></th>
                            <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Status")'>Status @SortIcon("Status")</button></th>
                            <th class="px-4 py-3 font-semibold text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (DiscountCodeDto item in PagedCodes)
                        {
                            <tr>
                                <td class="px-4 py-3 font-medium">@item.Code</td>
                                <td class="px-4 py-3">@item.Name</td>
                                <td class="px-4 py-3">@item.DiscountType</td>
                                <td class="px-4 py-3">@FormatDiscountValue(item)</td>
                                <td class="px-4 py-3">@FormatActivation(item)</td>
                                <td class="px-4 py-3">@item.CurrentUses</td>
                                <td class="px-4 py-3"><span class="@GetStatusClass(item.IsActive)">@(item.IsActive ? "Active" : "Inactive")</span></td>
                                <td class="px-4 py-3">
                                    <div class="flex justify-end gap-3">
                                        <button type="button" class="text-black hover:text-purple" title="Edit" @onclick="() => OpenEditModal(item)"><i class="ri-pencil-line"></i></button>
                                        <button type="button" class="text-danger hover:text-danger/70" title="Delete" @onclick="() => OpenDeleteModal(item)"><i class="ri-delete-bin-line"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between mt-4">
                <p class="text-sm text-black/50 dark:text-white/40">
                    Showing @StartRow to @EndRow of @FilteredCodes.Count discount codes
                </p>

                <div class="flex items-center gap-2">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                    <span class="flex items-center justify-center w-10 h-10 text-sm rounded-md bg-purple/10 text-purple">@currentPage</span>
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage >= TotalPages)" @onclick="NextPage">Next</button>
                </div>
            </div>
        }
    </div>
</div>

@if (isModalOpen)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-full max-w-lg overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="flex items-center justify-between px-5 py-3 border-b border-black/10 dark:border-darkborder">
                    <h3 class="text-lg font-semibold">@(editingCode is null ? "New Discount Code" : "Edit Discount Code")</h3>
                    <button type="button" @onclick="CloseModal"><i class="ri-close-line text-2xl"></i></button>
            </div>

            <EditForm Model="formModel" OnValidSubmit="SaveAsync">
                <div class="grid grid-cols-1 gap-4 p-5 md:grid-cols-2">
                    <div>
                        <label class="form-label">Edition</label>
                        <select class="form-select" @bind="formModel.EditionId">
                            @foreach (EditionDto edition in editions)
                            {
                                <option value="@edition.Id">@edition.Name</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Code</label>
                        <InputText class="form-input" @bind-Value="formModel.Code" />
                    </div>

                    <div>
                        <label class="form-label">Name</label>
                        <InputText class="form-input" @bind-Value="formModel.Name" />
                    </div>

                    <div>
                        <label class="form-label">Discount Value</label>
                        <InputNumber class="form-input" @bind-Value="formModel.DiscountValue" />
                    </div>

                    <div>
                        <label class="form-label">Discount Type</label>
                        <select class="form-select" @bind="formModel.DiscountType">
                            <option value="@DiscountType.FixedAmount">Fixed amount</option>
                            <option value="@DiscountType.Percentage">Percentage</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Activation</label>
                            <select class="form-select" @bind="formModel.ActivationType" @bind:after="OnActivationTypeChanged">
                                <option value="@DiscountActivationType.Immediate">Immediate</option>
                                <option value="@DiscountActivationType.AfterThreshold">After threshold</option>
                            </select>
                    </div>

                    <div>
                        <label class="form-label">Threshold</label>
                        <InputNumber class="form-input" @bind-Value="formModel.ActivationThreshold" />
                    </div>

                    <div>
                        <label class="form-label">Max Uses</label>
                        <InputNumber class="form-input" @bind-Value="formModel.MaxUses" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="form-label">Description</label>
                        <InputTextArea class="form-input" rows="3" @bind-Value="formModel.Description" />
                    </div>

                    @if (editingCode is not null)
                    {
                        <div>
                            <label class="form-label">Current Uses</label>
                            <InputNumber class="form-input" @bind-Value="formModel.CurrentUses" />
                        </div>

                        <div class="flex items-center gap-2 mt-7">
                            <InputCheckbox @bind-Value="formModel.IsActive" />
                            <span>Active</span>
                        </div>
                    }
                </div>

                <div class="flex justify-end gap-3 p-5 border-t">
                    <button type="button" class="btn border" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="btn bg-purple text-white">Save</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>
}

@if (deleteCode is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-[92vw] md:w-[380px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="px-5 py-4">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Delete Discount Code</h3>
                    <p class="mt-2 text-sm text-black/60 dark:text-white/50">Are you sure you want to delete <strong>@deleteCode.Code</strong>?</p>
                </div>
             <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                <button type="button" class="btn border border-black/10" disabled="@isSaving" @onclick="CloseDeleteModal">Cancel</button>
                    <button type="button" class="btn border border-danger text-danger hover:bg-danger hover:text-white disabled:opacity-50" disabled="@isSaving" @onclick="DeleteAsync">@(isSaving ? "Deleting..." : "Delete")</button>
             </div>
        </div>
    </div>
</div>
}

@code {
    private List<DiscountCodeDto> codes = [];
    private List<EditionDto> editions = [];
    private List<FestivalDto> festivals = [];
    private DiscountCodeFormModel formModel = new();
    private DiscountCodeDto? editingCode;
    private DiscountCodeDto? deleteCode;
    private string searchText = string.Empty;
    private string festivalFilter = string.Empty;
    private string editionFilter = string.Empty;

    private List<EditionDto> EditionsForSelectedFestival =>
        string.IsNullOrWhiteSpace(festivalFilter) || !Guid.TryParse(festivalFilter, out Guid fid)
            ? editions
            : editions.Where(e => e.FestivalId == fid).ToList();

    private void OnFestivalFilterChanged()
    {
        editionFilter = string.Empty;
        ResetPage();
    }
    private string sortColumn = "Code";
    private bool sortAscending = true;
    private bool isLoading = true;
    private bool isModalOpen;
    private string? successMessage;
    private string? errorMessage;
    private int pageSize = 10;
    private int currentPage = 1;
    private bool isSaving = default!;
    private string? typeFilter;
    private string? statusFilter;
    private string? activationFilter;


    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            editions = (await EditionApiClient.GetAllAsync()).ToList();
            festivals = (await FestivalApiClient.GetAllAsync()).ToList();

            if (ActiveFestivalState.Active is not null && string.IsNullOrWhiteSpace(festivalFilter))
            {
                festivalFilter = ActiveFestivalState.Active.Id.ToString();
            }

            if (ActiveFestivalState.Active is not null && string.IsNullOrWhiteSpace(editionFilter))
            {
                EditionDto? preferred = editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id && e.IsActive)
                    ?? editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id);

                if (preferred is not null)
                {
                    editionFilter = preferred.Id.ToString();
                }
            }

            codes = (await DiscountCodeApiClient.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowSuccess(string message)
    {
        successMessage = message;
        errorMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            successMessage = null;
            StateHasChanged();
        });
    }

    private void ShowError(string message)
    {
        errorMessage = message;
        successMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            errorMessage = null;
            StateHasChanged();
        });
    }

    private void OnActivationTypeChanged()
    {
        if (formModel.ActivationType == DiscountActivationType.Immediate)
        {
            formModel.ActivationThreshold = null;
        }

        if (formModel.ActivationType == DiscountActivationType.AfterThreshold && !formModel.ActivationThreshold.HasValue)
        {
            formModel.ActivationThreshold = 10;
        }
    }

    private List<DiscountCodeDto> FilteredCodes
    {
        get
        {
            IEnumerable<DiscountCodeDto> query = codes;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(c => c.Code.Contains(searchText, StringComparison.OrdinalIgnoreCase) || c.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            if (Guid.TryParse(editionFilter, out Guid editionId))
            {
                query = query.Where(c => c.EditionId == editionId);
            }
            else if (Guid.TryParse(festivalFilter, out Guid fid))
            {
                HashSet<Guid> editionIds = editions.Where(e => e.FestivalId == fid).Select(e => e.Id).ToHashSet();
                query = query.Where(c => editionIds.Contains(c.EditionId));
            }

            if (!string.IsNullOrWhiteSpace(typeFilter))
            {
                query = query.Where(c => c.DiscountType.ToString() == typeFilter);
            }

            if (!string.IsNullOrWhiteSpace(activationFilter))
            {
                query = query.Where(c => c.ActivationType.ToString() == activationFilter);
            }

            if (!string.IsNullOrWhiteSpace(statusFilter))
            {
                query = query.Where(c =>
                    (statusFilter == "Active" && c.IsActive) ||
                    (statusFilter == "Inactive" && !c.IsActive)
                );
            }

            query = sortColumn switch
            {
                "Name" => sortAscending ? query.OrderBy(c => c.Name) : query.OrderByDescending(c => c.Name),
                "Uses" => sortAscending ? query.OrderBy(c => c.CurrentUses) : query.OrderByDescending(c => c.CurrentUses),
                "Type" => sortAscending ? query.OrderBy(c => c.DiscountType) : query.OrderByDescending(c => c.DiscountType),
                "Activation" => sortAscending ? query.OrderBy(c => c.ActivationType) : query.OrderByDescending(c => c.ActivationType),
                "Status" => sortAscending
                    ? query.OrderBy(c => c.IsActive ? 0 : 1)
                    : query.OrderByDescending(c => c.IsActive ? 0 : 1),

                _ => sortAscending ? query.OrderBy(c => c.Code) : query.OrderByDescending(c => c.Code)
            };

            return query.ToList();
        }
    }

    private IEnumerable<DiscountCodeDto> PagedCodes => FilteredCodes.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredCodes.Count / (double)pageSize));
    private int StartRow => FilteredCodes.Count == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int EndRow => Math.Min(currentPage * pageSize, FilteredCodes.Count);

    private void ResetPage()
    {
        currentPage = 1;
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column)
        {
            return new MarkupString("<i class=\"ri-arrow-up-down-line text-xs opacity-40\"></i>");
        }

        return new MarkupString(sortAscending ? "<i class=\"ri-arrow-up-s-fill text-xs text-purple\"></i>" : "<i class=\"ri-arrow-down-s-fill text-xs text-purple\"></i>");
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
        }
    }

    private void OpenCreateModal()
    {
        editingCode = null;
        formModel = new DiscountCodeFormModel
        {
            EditionId = editions.FirstOrDefault()?.Id ?? Guid.Empty,
            DiscountType = DiscountType.FixedAmount,
            DiscountValue = 20,
            ActivationType = DiscountActivationType.AfterThreshold,
            ActivationThreshold = 10,
            IsActive = true
        };
        isModalOpen = true;
    }

    private void OpenEditModal(DiscountCodeDto code)
    {
        editingCode = code;
        formModel = new DiscountCodeFormModel
        {
            EditionId = code.EditionId,
            Code = code.Code,
            Name = code.Name,
            Description = code.Description,
            DiscountType = code.DiscountType,
            DiscountValue = code.DiscountValue,
            ActivationType = code.ActivationType,
            ActivationThreshold = code.ActivationThreshold,
            MaxUses = code.MaxUses,
            CurrentUses = code.CurrentUses,
            IsActive = code.IsActive
        };
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
    }

    private async Task SaveAsync()
    {
        try
        {
            if (editingCode is null)
            {
                if (formModel.ActivationType == DiscountActivationType.Immediate)
                {
                    formModel.ActivationThreshold = null;
                }
                CreateDiscountCodeRequest request = new()
                {
                    EditionId = formModel.EditionId,
                    Code = formModel.Code,
                    Name = formModel.Name,
                    Description = formModel.Description,
                    DiscountType = formModel.DiscountType,
                    DiscountValue = formModel.DiscountValue,
                    ActivationType = formModel.ActivationType,
                    ActivationThreshold = formModel.ActivationType == DiscountActivationType.Immediate ? null : formModel.ActivationThreshold,
                    MaxUses = formModel.MaxUses
                };

                await DiscountCodeApiClient.CreateAsync(request);
                successMessage = "Discount code created.";
                ShowSuccess(successMessage);
            }
            else
            {
                if (formModel.ActivationType == DiscountActivationType.Immediate)
                {
                    formModel.ActivationThreshold = null;
                }

                UpdateDiscountCodeRequest request = new()
                {
                    EditionId = formModel.EditionId,
                    Code = formModel.Code,
                    Name = formModel.Name,
                    Description = formModel.Description,
                    DiscountType = formModel.DiscountType,
                    DiscountValue = formModel.DiscountValue,
                    ActivationType = formModel.ActivationType,
                    ActivationThreshold = formModel.ActivationType == DiscountActivationType.Immediate ? null : formModel.ActivationThreshold,
                    MaxUses = formModel.MaxUses,
                    CurrentUses = formModel.CurrentUses,
                    IsActive = formModel.IsActive
                };

                await DiscountCodeApiClient.UpdateAsync(editingCode.Id, request);
                successMessage = "Discount code updated.";
                ShowSuccess(successMessage);
            }

            CloseModal();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void OpenDeleteModal(DiscountCodeDto code)
    {
        deleteCode = code;
    }

    private void CloseDeleteModal()
    {
        deleteCode = null;
    }

    private async Task DeleteAsync()
    {
        if (deleteCode is null)
        {
            return;
        }

        try
        {
            await DiscountCodeApiClient.DeleteAsync(deleteCode.Id);
            successMessage = "Discount code deleted.";
            deleteCode = null;
            ShowSuccess(successMessage);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private static string FormatDiscountValue(DiscountCodeDto code)
    {
        return code.DiscountType == DiscountType.Percentage ? $"{code.DiscountValue:0.##}%" : $"{code.DiscountValue:0.##} €";
    }

    private static string FormatActivation(DiscountCodeDto code)
    {
        return code.ActivationType == DiscountActivationType.Immediate ? "Immediate" : $"After {code.ActivationThreshold}";
    }

    private static string GetStatusClass(bool isActive)
    {
        return isActive ? "px-2 py-1 text-xs rounded bg-success/10 text-success" : "px-2 py-1 text-xs rounded bg-danger/10 text-danger";
    }

    private class DiscountCodeFormModel
    {
        public Guid EditionId { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public DiscountType DiscountType { get; set; }
        public decimal DiscountValue { get; set; }
        public DiscountActivationType ActivationType { get; set; }
        public int? ActivationThreshold { get; set; }
        public int? MaxUses { get; set; }
        public int CurrentUses { get; set; }
        public bool IsActive { get; set; }
    }
}
