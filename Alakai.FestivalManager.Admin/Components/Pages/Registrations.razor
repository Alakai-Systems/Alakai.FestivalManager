@page "/registrations"

@inject EmailNotificationApiClient EmailNotificationApiClient
@inject RegistrationApiClient RegistrationApiClient
@inject PassTypeApiClient PassTypeApiClient
@inject LevelApiClient LevelApiClient
@inject EditionApiClient EditionApiClient
@inject FestivalApiClient FestivalApiClient
@inject ActiveFestivalState ActiveFestivalState
@inject Alakai.FestivalManager.Admin.Services.Api.ImpersonationApiClient ImpersonationApiClient
@inject IJSRuntime JsRuntime
@using Microsoft.AspNetCore.Components.Authorization

<PageHeader Title="Operations" pTitle="Registrations"></PageHeader>

<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)]">
    <div class="grid grid-cols-1 gap-4">
        <div class="card">
            <div class="flex flex-col gap-3 mb-5 md:flex-row md:items-center md:flex-wrap">

                <div class="relative w-full md:w-50">
                    <input class="form-input" placeholder="Search by name or email..."
                           @bind="searchText" @bind:event="oninput" @bind:after="ResetPage" />
                </div>

                <select class="form-select w-full md:w-44" @bind="festivalFilter" @bind:after="OnFestivalFilterChanged">
                    <option value="@Guid.Empty">All festivals</option>
                    @foreach (FestivalDto f in festivals)
                    {
                        <option value="@f.Id">@f.Name</option>
                    }
                </select>

                <select class="form-select w-full md:w-44" @bind="editionFilter" @bind:after="ResetPage">
                    <option value="@Guid.Empty">All editions</option>
                    @foreach (EditionDto ed in EditionsForSelectedFestival)
                    {
                        <option value="@ed.Id">@ed.Name</option>
                    }
                </select>

                <select class="form-select w-full md:w-40" @bind="paymentFilter" @bind:after="ResetPage">
                    <option value="">All payment statuses</option>
                    <option value="@PaymentStatus.Paid">Paid</option>
                    <option value="@PaymentStatus.Unpaid">Unpaid</option>
                    <option value="@PaymentStatus.Pending">Pending</option>
                    <option value="@PaymentStatus.Failed">Failed</option>
                    <option value="@PaymentStatus.Refunded">Refunded</option>
                </select>

                <select class="form-select w-full md:w-40" @bind="partnerFilter" @bind:after="ResetPage">
                    <option value="">All partner statuses</option>
                    <option value="complete">Partner registered</option>
                    <option value="missing">Partner missing</option>
                    <option value="none">No partner</option>
                </select>

                <select class="form-select w-full md:w-40" @bind="passTypeFilter" @bind:after="ResetPage">
                    <option value="">All pass types</option>
                    @foreach (PassTypeDto passType in passTypes.Where(pt => editionFilter == Guid.Empty || pt.EditionId == editionFilter))
                    {
                        <option value="@passType.Id">@passType.Name</option>
                    }
                </select>

                <select class="form-select w-full md:w-40" @bind="levelFilter" @bind:after="ResetPage">
                    <option value="">All levels</option>
                    @foreach (LevelDto level in levels.Where(l =>
                        (string.IsNullOrEmpty(passTypeFilter) || l.PassTypeId.ToString() == passTypeFilter) &&
                        (editionFilter == Guid.Empty || passTypes.Any(pt => pt.Id == l.PassTypeId && pt.EditionId == editionFilter))))
                    {
                        <option value="@level.Id">@level.Name</option>
                    }
                </select>

                <select class="form-select w-full md:w-44" @bind="groupFilter" @bind:after="ResetPage">
                    <option value="">All groups</option>
                    @foreach (string group in Groups)
                    {
                        <option value="@group">@group</option>
                    }
                </select>

                <select class="form-select w-full md:w-32" @bind="pageSize" @bind:after="ResetPage">
                    <option value="50">50 rows</option>
                    <option value="100">100 rows</option>
                    <option value="200">200 rows</option>
                </select>

            </div>


            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">@successMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">@errorMessage</div>
            }

            @if (isLoading)
            {
                <p class="text-sm text-black/50 dark:text-white/60">Loading registrations...</p>
            }
            else
            {
                <div class="overflow-x-auto" style="max-width: 100%;">
                    <table class="table-hover w-full text-sm">
                        <thead class="bg-gray-50 dark:bg-dark">
                            <tr class="text-left">
                                <th class="px-2 py-2 max-w-[140px] font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Name")'>Name @SortIcon("Name")</button></th>
                                <th class="px-2 py-2 max-w-[140px] font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Pass")'>Pass @SortIcon("Pass")</button></th>
                                <th class="px-2 py-2 max-w-[140px] font-semibold">Level</th>
                                <th class="px-2 py-2 max-w-[140px] font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Role")'>Role @SortIcon("Role")</button></th>
                                <th class="px-2 py-2 max-w-[140px] font-semibold">Price</th>
                                <th class="px-2 py-2 max-w-[140px] font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Group")'>Group @SortIcon("Group")</button></th>
                                <th class="px-2 py-2 max-w-[140px] font-semibold">Partner</th>
                                <th class="px-2 py-2 max-w-[140px] font-semibold">Payment</th>
                                <th class="px-2 py-2 max-w-[140px] font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Date")'>Date @SortIcon("Date")</button></th>
                                <th class="px-2 py-2 max-w-[140px] font-semibold text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="text-black dark:text-white/80">
                            @foreach (RegistrationDto registration in PagedRegistrations)
                            {
                                <tr class="@GetRowClass(registration, DateTime.UtcNow)">
                                    <td class="px-2 py-2 max-w-[180px]">
                                        <div class="font-medium truncate">@registration.FullName</div>
                                        <div class="text-xs text-black/50 dark:text-white/60 truncate">@registration.Email</div>
                                    </td>
                                    <td class="px-2 py-2 whitespace-nowrap">@GetPassTypeName(registration.PassTypeId)</td>
                                    <td class="px-2 py-2 whitespace-nowrap">@GetLevelName(registration.LevelId)</td>
                                    <td class="px-2 py-2 whitespace-nowrap">@FormatRole(registration.DanceRole)</td>
                                    <td class="px-2 py-2 whitespace-nowrap">
                                        <div>@registration.FinalPrice.ToString("0.##") €</div>
                                        @if (registration.FinalPrice != registration.BasePrice)
                                        {
                                            <div class="text-xs text-black/50 dark:text-white/60">Base @registration.BasePrice.ToString("0.##") €</div>
                                        }
                                    </td>
                                    <td class="px-2 py-2 whitespace-nowrap">@registration.DiscountCodeValue</td>
                                    <td class="px-2 py-2 max-w-[140px] truncate">@FormatPartner(registration)</td>
                                    <td class="px-2 py-2 whitespace-nowrap">
                                        <span class="@GetPaymentClass(registration.PaymentStatus)">@registration.PaymentStatus</span>
                                        @if (!string.IsNullOrEmpty(registration.PaymentAuthCodes))
                                        {
                                            <div class="text-xs text-black/40 dark:text-white/60 mt-1 font-mono">@(string.Join(" | ", registration.PaymentAuthCodes.Split('|').Select(e => e.Contains(':') ? e.Split(':')[1] : e)))</div>
                                        }
                                    </td>
                                    <td class="px-2 py-2 whitespace-nowrap">@FormatDate(registration.CreatedAt)</td>
                                    <td class="px-2 py-2">
                                        <div class="flex justify-end gap-1">
                                            <button type="button" class="text-black dark:text-white/80 hover:text-purple" title="Registration confirmation email" @onclick='() => OpenEmailConfirmModal("registration confirmation", registration)'><i class="ri-mail-send-line"></i></button>
                                            <button type="button" class="text-black dark:text-white/80 hover:text-purple" title="Payment confirmation email" @onclick='() => OpenEmailConfirmModal("payment confirmation", registration)'><i class="ri-bank-card-line"></i></button>
                                            <button type="button" class="text-black dark:text-white/80 hover:text-purple" title="Unpaid reminder email" @onclick='() => OpenEmailConfirmModal("unpaid reminder", registration)'><i class="ri-error-warning-line"></i></button>
                                            <button type="button" class="text-black dark:text-white/80 hover:text-purple" title="Missing partner email" @onclick='() => OpenEmailConfirmModal("missing partner", registration)'><i class="ri-user-follow-line"></i></button>
                                            @if (IsSuperAdmin)
                                            {
                                                <button type="button" class="text-black dark:text-white/80 hover:text-purple" title="View user panel" @onclick="() => ImpersonateAsync(registration.Id)"><i class="ri-key-2-line"></i></button>
                                            }
                                            <button type="button" class="text-black dark:text-white/80 hover:text-purple" title="Edit" @onclick="() => OpenEditModal(registration)"><i class="ri-pencil-line"></i></button>
                                            <button type="button" class="text-danger hover:text-danger/70" title="Delete and send cancellation email" @onclick="() => OpenDeleteModal(registration)"><i class="ri-delete-bin-line"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="flex items-center justify-between mt-4">
                    <p class="text-sm text-black/50 dark:text-white/60">
                        Showing @StartRow to @EndRow of @FilteredRegistrations.Count registrations
                    </p>

                    <div class="flex items-center gap-2">
                        <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                        <span class="flex items-center justify-center w-10 h-10 text-sm rounded-md bg-purple/10 text-purple">@currentPage</span>
                        <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage >= TotalPages)" @onclick="NextPage">Next</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="px-5 py-4">
        <div class="flex items-center justify-between mb-2">
            <h3 class="text-sm font-semibold text-black dark:text-white">
                Emails (@FilteredRegistrations.Count)
            </h3>
            <span class="text-xs text-black/40 dark:text-white/60">Filtered by current selection — click to select all</span>
        </div>
        <textarea readonly class="w-full text-xs font-mono text-black/70 dark:text-white/70 bg-transparent border border-black/10 dark:border-darkborder rounded-md px-3 py-2 resize-none focus:outline-none focus:border-purple/50" rows="3"
                  onclick="this.select()">@(string.Join(", ", FilteredRegistrations.Select(r => r.Email)))</textarea>
    </div>
</div>

@if (editingRegistration is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative mx-auto overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder" style="width: min(95vw, 760px);">
                <div class="flex items-center justify-between px-5 py-3 border-b border-black/10 dark:border-darkborder">
                    <h3 class="text-lg font-semibold">Edit Registration</h3>
                    <button type="button" @onclick="CloseEditModal"><i class="ri-close-line text-2xl"></i></button>
                </div>

                <EditForm Model="editingRegistration" OnValidSubmit="SaveEditAsync">
                    <div class="grid grid-cols-1 gap-4 p-5 md:grid-cols-2">
                        <div>
                            <label class="form-label">First Name</label>
                            <InputText class="form-input" @bind-Value="editingRegistration.FirstName" />
                        </div>

                        <div>
                            <label class="form-label">Last Name</label>
                            <InputText class="form-input" @bind-Value="editingRegistration.LastName" />
                        </div>

                        <div>
                            <label class="form-label">Email</label>
                            <InputText class="form-input" @bind-Value="editingRegistration.Email" />
                        </div>

                        <div>
                            <label class="form-label">Phone</label>
                            <InputText class="form-input" @bind-Value="editingRegistration.Phone" />
                        </div>

                        <div>
                            <label class="form-label">Document</label>
                            <InputText class="form-input" @bind-Value="editingRegistration.DocumentNumber" />
                        </div>

                        <div>
                            <label class="form-label">Pass Type</label>
                            <select class="form-select" @bind="editingRegistration.PassTypeId">
                                @foreach (PassTypeDto passType in passTypes)
                                {
                                    <option value="@passType.Id">@passType.Name</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="form-label">Level</label>
                            <select class="form-select" @bind="editingRegistration.LevelId">
                                <option value="">No level</option>
                                @foreach (LevelDto level in levels)
                                {
                                    <option value="@level.Id">@level.Name</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="form-label">Dance Role</label>
                            <select class="form-select" @bind="editingRegistration.DanceRole">
                                <option value="">No role</option>
                                <option value="@DanceRole.Leader">Leader</option>
                                <option value="@DanceRole.Follower">Follower</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">Partner Email</label>
                            <InputText class="form-input" @bind-Value="editingRegistration.PartnerEmail" />
                        </div>

                        <div>
                            <label class="form-label">Payment Status</label>
                            <select class="form-select" @bind="editingRegistration.PaymentStatus">
                                <option value="@PaymentStatus.Unpaid">Unpaid</option>
                                <option value="@PaymentStatus.Pending">Pending</option>
                                <option value="@PaymentStatus.PartiallyPaid">Partially Paid</option>
                                <option value="@PaymentStatus.Paid">Paid</option>
                                <option value="@PaymentStatus.Failed">Failed</option>
                                <option value="@PaymentStatus.Refunded">Refunded</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">Registration Status</label>
                            <select class="form-select" @bind="editingRegistration.Status">
                                <option value="@RegistrationStatus.Registered">Registered</option>
                                <option value="@RegistrationStatus.PendingPayment">Pending Payment</option>
                                <option value="@RegistrationStatus.Confirmed">Confirmed</option>
                                <option value="@RegistrationStatus.WaitingPartner">Waiting Partner</option>
                                <option value="@RegistrationStatus.Cancelled">Cancelled</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">Base Price</label>
                            <InputNumber class="form-input" @bind-Value="editingRegistration.BasePrice" />
                        </div>

                        <div>
                            <label class="form-label">Group Code</label>
                            <InputText class="form-input" @bind-Value="editingRegistration.DiscountCodeValue" />
                        </div>

                        <div class="md:col-span-2">
                            <label class="form-label">Internal Notes</label>
                            <InputTextArea class="form-input" rows="3" @bind-Value="editingRegistration.InternalNotes" />
                        </div>
                    </div>

                    <div class="flex justify-end gap-3 p-5 border-t">
                        <button type="button" class="btn border" @onclick="CloseEditModal">Cancel</button>
                        <button type="submit" class="btn bg-purple text-white">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (emailConfirmRegistration is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-[92vw] md:w-[420px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="px-5 py-4">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Send Email</h3>
                    <p class="mt-2 text-sm text-black/60 dark:text-white/60">
                        Send <strong>@emailConfirmAction</strong> email to <strong>@emailConfirmRegistration.FullName</strong>?
                    </p>
                    <p class="mt-1 text-xs text-black/40 dark:text-white/60">@emailConfirmRegistration.Email</p>
                </div>
                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="btn border border-black/10 dark:border-darkborder dark:text-white/80" disabled="@isSaving" @onclick="CloseEmailConfirmModal">Cancel</button>
                    <button type="button" class="btn border border-purple text-purple hover:bg-purple hover:text-white disabled:opacity-50" disabled="@isSaving" @onclick="ConfirmEmailAsync">@(isSaving ? "Sending..." : "Send")</button>
                </div>
            </div>
        </div>
    </div>
}

@if (deleteRegistration is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-[92vw] md:w-[380px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="px-5 py-4">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Delete Registration</h3>
                    <p class="mt-2 text-sm text-black/60 dark:text-white/60">Are you sure you want to delete <strong>@deleteRegistration.FullName</strong>?</p>
                </div>
                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="btn border border-black/10" disabled="@isSaving" @onclick="CloseDeleteModal">Cancel</button>
                    <button type="button" class="btn border border-danger text-danger hover:bg-danger hover:text-white disabled:opacity-50" disabled="@isSaving" @onclick="ConfirmDeleteAsync">@(isSaving ? "Deleting..." : "Delete")</button>
                </div>
            </div>
        </div>
    </div>
}

@implements IDisposable
@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool IsSuperAdmin { get; set; }

    private async Task ImpersonateAsync(Guid registrationId)
    {
        try
        {
            string? token = await ImpersonationApiClient.GetTokenForRegistrationAsync(registrationId);

            if (!string.IsNullOrWhiteSpace(token))
            {
                await JsRuntime.InvokeVoidAsync("open", $"/impersonate?token={Uri.EscapeDataString(token)}", "_blank");
            }
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
    }

    private List<RegistrationDto> registrations = [];
    private List<PassTypeDto> passTypes = [];
    private List<LevelDto> levels = [];
    private List<EditionDto> editions = [];
    private List<FestivalDto> festivals = [];
    private RegistrationDto? editingRegistration;
    private RegistrationDto? deleteRegistration;
    private RegistrationDto? emailConfirmRegistration;
    private string emailConfirmAction = string.Empty;
    private string searchText = string.Empty;
    private string paymentFilter = string.Empty;
    private string partnerFilter = string.Empty;
    private Guid festivalFilter = Guid.Empty;
    private Guid editionFilter = Guid.Empty;

    private List<EditionDto> EditionsForSelectedFestival =>
        festivalFilter == Guid.Empty
            ? editions
            : editions.Where(e => e.FestivalId == festivalFilter).ToList();

    private void OnFestivalFilterChanged()
    {
        editionFilter = Guid.Empty;
        ResetPage();
    }
    private string passTypeFilter = string.Empty;
    private string levelFilter = string.Empty;
    private string groupFilter = string.Empty;
    private string sortColumn = "Name";
    private bool sortAscending = true;
    private bool isLoading = true;
    private bool isSaving;
    private string? successMessage;
    private string? errorMessage;
    private int pageSize = 50;
    private int currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is not null)
        {
            AuthenticationState authState = await AuthenticationStateTask;
            IsSuperAdmin = authState.User.IsInRole("SuperAdmin");
        }

        ActiveFestivalState.OnChange += HandleFestivalStateChanged;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            registrations = (await RegistrationApiClient.GetAllAsync()).ToList();
            passTypes = (await PassTypeApiClient.GetAllAsync()).ToList();
            levels = (await LevelApiClient.GetAllAsync()).ToList();
            editions = (await EditionApiClient.GetAllAsync()).ToList();
            festivals = (await FestivalApiClient.GetAllAsync()).ToList();

            if (ActiveFestivalState.Active is not null)
            {
                festivalFilter = ActiveFestivalState.Active.Id;

                EditionDto? preferred = editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id && e.IsActive)
                    ?? editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id);

                editionFilter = preferred?.Id ?? Guid.Empty;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<string?> Groups => registrations
        .Where(r => !string.IsNullOrWhiteSpace(r.DiscountCodeValue) && (editionFilter == Guid.Empty || r.EditionId == editionFilter))
        .Select(r => r.DiscountCodeValue)
        .Distinct()
        .OrderBy(g => g)
        .ToList();

    private List<RegistrationDto> FilteredRegistrations
    {
        get
        {
            IEnumerable<RegistrationDto> query = registrations;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(r => r.FullName.Contains(searchText, StringComparison.OrdinalIgnoreCase) || r.Email.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            if (Enum.TryParse(paymentFilter, out PaymentStatus paymentStatus))
            {
                query = query.Where(r => r.PaymentStatus == paymentStatus);
            }

            if (editionFilter != Guid.Empty)
            {
                query = query.Where(r => r.EditionId == editionFilter);
            }
            else if (festivalFilter != Guid.Empty)
            {
                HashSet<Guid> editionIds = editions.Where(e => e.FestivalId == festivalFilter).Select(e => e.Id).ToHashSet();
                query = query.Where(r => editionIds.Contains(r.EditionId));
            }

            if (partnerFilter == "complete")
            {
                query = query.Where(r => !string.IsNullOrWhiteSpace(r.PartnerEmail) && r.PartnerRegistrationId.HasValue);
            }
            else if (partnerFilter == "missing")
            {
                query = query.Where(r => !string.IsNullOrWhiteSpace(r.PartnerEmail) && !r.PartnerRegistrationId.HasValue);
            }
            else if (partnerFilter == "none")
            {
                query = query.Where(r => string.IsNullOrWhiteSpace(r.PartnerEmail));
            }

            if (Guid.TryParse(passTypeFilter, out Guid passTypeId))
            {
                query = query.Where(r => r.PassTypeId == passTypeId);
            }

            if (Guid.TryParse(levelFilter, out Guid levelId))
            {
                query = query.Where(r => r.LevelId == levelId);
            }

            if (!string.IsNullOrWhiteSpace(groupFilter))
            {
                query = query.Where(r => r.DiscountCodeValue == groupFilter);
            }

            query = sortColumn switch
            {
                "Pass" => sortAscending ? query.OrderBy(r => GetPassTypeName(r.PassTypeId)) : query.OrderByDescending(r => GetPassTypeName(r.PassTypeId)),
                "Role" => sortAscending ? query.OrderBy(r => r.DanceRole) : query.OrderByDescending(r => r.DanceRole),
                "Group" => sortAscending ? query.OrderBy(r => r.DiscountCodeValue) : query.OrderByDescending(r => r.DiscountCodeValue),
                "Date" => sortAscending ? query.OrderBy(r => r.CreatedAt) : query.OrderByDescending(r => r.CreatedAt),
                _ => sortAscending ? query.OrderBy(r => r.FullName) : query.OrderByDescending(r => r.FullName)
            };

            return query.ToList();
        }
    }

    private IEnumerable<RegistrationDto> PagedRegistrations => FilteredRegistrations.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredRegistrations.Count / (double)pageSize));
    private int StartRow => FilteredRegistrations.Count == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int EndRow => Math.Min(currentPage * pageSize, FilteredRegistrations.Count);

    private void ResetPage()
    {
        currentPage = 1;
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column)
        {
            return new MarkupString("<i class=\"ri-arrow-up-down-line text-xs opacity-40\"></i>");
        }

        return new MarkupString(sortAscending ? "<i class=\"ri-arrow-up-s-fill text-xs text-purple\"></i>" : "<i class=\"ri-arrow-down-s-fill text-xs text-purple\"></i>");
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
        }
    }

    private void NormalizeGuids()
    {
        if (editingRegistration?.PartnerRegistrationId == Guid.Empty)
            editingRegistration.PartnerRegistrationId = null;
    }

    private void ShowSuccess(string message)
    {
        successMessage = message;
        errorMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            successMessage = null;
            StateHasChanged();
        });
    }

    private void ShowError(string message)
    {
        errorMessage = message;
        successMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            errorMessage = null;
            StateHasChanged();
        });
    }

    private string GetPassTypeName(Guid passTypeId)
    {
        return passTypes.FirstOrDefault(p => p.Id == passTypeId)?.Name ?? "-";
    }

    private string GetLevelName(Guid? levelId)
    {
        if (!levelId.HasValue)
        {
            return "-";
        }

        return levels.FirstOrDefault(l => l.Id == levelId.Value)?.Name ?? "-";
    }

    private static string FormatRole(DanceRole? danceRole)
    {
        return danceRole.HasValue ? danceRole.Value.ToString() : "-";
    }

    private static string FormatPartner(RegistrationDto registration)
    {
        if (string.IsNullOrWhiteSpace(registration.PartnerEmail))
        {
            return "-";
        }

        if (!string.IsNullOrWhiteSpace(registration.PartnerName))
        {
            return registration.PartnerName;
        }

        return $"Missing: {registration.PartnerName}";
    }

    private static string FormatDate(DateTime date)
    {
        if (date == DateTime.MinValue)
        {
            return "-";
        }

        return date.ToString("dd/MM/yyyy");
    }

    private static string GetRowClass(RegistrationDto registration, DateTime now)
    {
        if (registration.PaymentStatus == PaymentStatus.Unpaid || registration.PaymentStatus == PaymentStatus.Failed)
        {
            return "bg-danger/5";
        }

        bool isOverdue = registration.PaymentDueAt.HasValue && registration.PaymentDueAt.Value < now;

        if (isOverdue &&
            ((registration.PaymentPlan == PaymentPlan.DeferredTenDays && registration.PaymentStatus != PaymentStatus.Paid) ||
             (registration.PaymentPlan == PaymentPlan.SplitFiftyFifty && registration.PaymentStatus == PaymentStatus.PartiallyPaid)))
        {
            return "bg-danger/10";
        }

        if (!string.IsNullOrWhiteSpace(registration.PartnerEmail) && !registration.PartnerRegistrationId.HasValue)
        {
            return "bg-warning/10";
        }

        return string.Empty;
    }

    private static string GetPaymentClass(PaymentStatus paymentStatus)
    {
        return paymentStatus switch
        {
            PaymentStatus.Paid => "px-2 py-1 text-xs rounded bg-success/10 text-success",
            PaymentStatus.Pending => "px-2 py-1 text-xs rounded bg-warning/10 text-warning",
            PaymentStatus.Unpaid => "px-2 py-1 text-xs rounded bg-danger/10 text-danger",
            PaymentStatus.Failed => "px-2 py-1 text-xs rounded bg-danger/10 text-danger",
            _ => "px-2 py-1 text-xs rounded bg-black/10 text-black dark:bg-white/10 dark:text-white"
        };
    }

    private void OpenEmailConfirmModal(string action, RegistrationDto registration)
    {
        emailConfirmAction = action;
        emailConfirmRegistration = registration;
    }

    private void CloseEmailConfirmModal()
    {
        emailConfirmRegistration = null;
        emailConfirmAction = string.Empty;
    }

    private async Task ConfirmEmailAsync()
    {
        if (emailConfirmRegistration is null) return;
        RegistrationDto registration = emailConfirmRegistration;
        string action = emailConfirmAction;
        CloseEmailConfirmModal();
        await EmailAction(action, registration);
    }

    private async Task EmailAction(string action, RegistrationDto registration)
    {
        try
        {
            switch (action)
            {
                case "registration confirmation":
                    await EmailNotificationApiClient.SendRegistrationConfirmationAsync(registration.Id);
                    break;

                case "payment confirmation":
                    await EmailNotificationApiClient.SendPaymentConfirmationAsync(registration.Id);
                    break;

                case "unpaid reminder":
                    await EmailNotificationApiClient.SendPaymentReminderAsync(registration.Id);
                    break;

                case "missing partner":
                    await EmailNotificationApiClient.SendMissingPartnerReminderAsync(registration.Id);
                    break;

                case "cancellation":
                    await EmailNotificationApiClient.SendCancellationAsync(registration.Id);
                    break;

                default:
                    throw new InvalidOperationException("Unknown email action.");
            }

            ShowSuccess("Email sent successfully.");
        }
        catch (Exception ex)
        {
           ShowError(ex.Message);
        }
    }

    private void OpenEditModal(RegistrationDto registration)
    {
        editingRegistration = registration;
        editingRegistration.PaymentStatus = registration.PaymentStatus;
        editingRegistration.DocumentNumber = registration.DocumentNumber;
    }

    private void CloseEditModal()
    {
        editingRegistration = null;
    }

    private async Task SaveEditAsync()
    {
        NormalizeGuids();

        if (editingRegistration is null)
        {
            return;
        }

        try
        {
            UpdateRegistrationRequest request = new()
            {
                Id = editingRegistration.Id,
                EditionId = editingRegistration.EditionId,
                PassTypeId = editingRegistration.PassTypeId,
                LevelId = editingRegistration.LevelId,
                FirstName = editingRegistration.FirstName,
                LastName = editingRegistration.LastName,
                Email = editingRegistration.Email,
                Phone = editingRegistration.Phone,
                Country = editingRegistration.Country,
                City = editingRegistration.City,
                DocumentNumber = editingRegistration.DocumentNumber,
                DocumentCountry = editingRegistration.DocumentCountry,
                DanceRole = editingRegistration.DanceRole,
                PartnerEmail = editingRegistration.PartnerEmail,
                BasePrice = editingRegistration.BasePrice,
                DiscountCodeValue = editingRegistration.DiscountCodeValue,
                Notes = editingRegistration.Notes,
                InternalNotes = editingRegistration.InternalNotes,
                Status = editingRegistration.Status,
                PaymentStatus = editingRegistration.PaymentStatus,
                IsActive = editingRegistration.IsActive
            };

            await RegistrationApiClient.UpdateAsync(editingRegistration.Id, request);
            successMessage = "Registration updated.";
            editingRegistration = null;

            ShowSuccess(successMessage);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            ShowError(errorMessage);
        }
    }

    private void OpenDeleteModal(RegistrationDto registration)
    {
        deleteRegistration = registration;
    }

    private void CloseDeleteModal()
    {
        deleteRegistration = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (deleteRegistration is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            await EmailNotificationApiClient.SendRegistrationEmailAsync(deleteRegistration.Id, EmailTemplateKey.RegistrationCancelled);

            await RegistrationApiClient.DeleteAsync(deleteRegistration.Id);

            CloseDeleteModal();

            deleteRegistration = null;

            await LoadDataAsync();

            ShowSuccess("Registration deleted and cancellation email sent successfully.");
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }
    private void HandleFestivalStateChanged()
    {
        InvokeAsync(async () =>
        {
            festivalFilter = Guid.Empty;
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ActiveFestivalState.OnChange -= HandleFestivalStateChanged;
    }
}
