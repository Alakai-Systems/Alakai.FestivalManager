    private async Task SaveNewCapacityAsync()
    {
        try
        {
            if (editingCompetitionForCapacity is null || editingCapacity is null)
            {
                ShowError("No competition selected.");
                return;
            }

            var updatedCapacities =
                editingCompetitionForCapacity.Capacities
                .Select(c => new UpdateCompetitionCapacityRequest
                {
                    MixAndMatchLevel = c.MixAndMatchLevel,
                    DanceRole = c.DanceRole,
                    Capacity = c.Capacity,
                    SortOrder = c.SortOrder
                })
                .ToList();

            updatedCapacities.Add(new UpdateCompetitionCapacityRequest
            {
                MixAndMatchLevel = editingCapacity.MixAndMatchLevel,
                DanceRole = editingCapacity.DanceRole,
                Capacity = editingCapacity.Capacity,
                SortOrder = editingCapacity.SortOrder
            });

            var request = new UpdateCompetitionRequest
            {
                EditionId = editingCompetitionForCapacity.EditionId,
                Name = editingCompetitionForCapacity.Name,
                Description = editingCompetitionForCapacity.Description,
                Format = editingCompetitionForCapacity.Format,
                RequiresPartner = editingCompetitionForCapacity.RequiresPartner,
                RequiresRole = editingCompetitionForCapacity.RequiresRole,
                Price = editingCompetitionForCapacity.Price,
                RegistrationOpenAt = editingCompetitionForCapacity.RegistrationOpenAt,
                RegistrationCloseAt = editingCompetitionForCapacity.RegistrationCloseAt,
                SortOrder = editingCompetitionForCapacity.SortOrder,
                IsActive = editingCompetitionForCapacity.IsActive,
                Capacities = updatedCapacities
            };

            await CompetitionApiClient.UpdateAsync(editingCompetitionForCapacity.Id, request);

            showCreateCapacityModal = false;
            ShowSuccess("Capacity created successfully.");

            await LoadDataAsync();
        }
        catch
        {
            ShowError("Error creating capacity.");
        }
    }


