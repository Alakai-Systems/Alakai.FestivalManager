@page "/competitions"
@using Alakai.FestivalManager.Admin.Components.Layout
@using Alakai.FestivalManager.Admin.Contracts.Editions.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Festivals.DTOs
@inject CompetitionApiClient CompetitionApiClient
@inject EditionApiClient EditionApiClient
@inject FestivalApiClient FestivalApiClient
@inject ActiveFestivalState ActiveFestivalState

<PageHeader Title="Event Setup" pTitle="Competitions"></PageHeader>

<div class="flex flex-col gap-4 min-h-[calc(100vh-212px)]">
    <div class="grid grid-cols-1 gap-4">
        <div class="card">
            <div class="flex flex-col gap-4 mb-5 xl:flex-row xl:items-center xl:justify-between">

                <div class="flex flex-col gap-3 md:flex-row md:items-center">
                    <input class="form-input md:w-64" placeholder="Search competitions..." @bind="searchText" @bind:event="oninput" @bind:after="ResetPage" />

                    <select class="form-select md:w-48" @bind="festivalFilter" @bind:after="OnFestivalFilterChanged">
                        <option value="@Guid.Empty">All festivals</option>
                        @foreach (FestivalDto f in festivals)
                        {
                            <option value="@f.Id">@f.Name</option>
                        }
                    </select>

                    <select class="form-select md:w-56" @bind="editionFilter" @bind:after="ResetPage">
                        <option value="@Guid.Empty">All editions</option>
                        @foreach (EditionDto edition in EditionsForSelectedFestival)
                        {
                            <option value="@edition.Id">@edition.Name</option>
                        }
                    </select>

                    <select class="form-select md:w-64" @bind="competitionNameFilter" @bind:after="ResetPage">
                        <option value="@Guid.Empty">All competitions</option>
                        @foreach (CompetitionDto competition in competitions.OrderBy(c => c.Name))
                        {
                            <option value="@competition.Id">@competition.Name</option>
                        }
                    </select>

                    <select class="form-select md:w-32" @bind="pageSize" @bind:after="ResetPage">
                        <option value="10">10 rows</option>
                        <option value="25">25 rows</option>
                        <option value="50">50 rows</option>
                    </select>

                    <button type="button" class="transition-all duration-300 border rounded-md btn text-purple border-purple hover:bg-purple hover:text-white whitespace-nowrap" @onclick="OpenCreateModal">
                        <i class="ri-add-line ltr:mr-1 rtl:ml-1"></i>
                        New Competition
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">@successMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">@errorMessage</div>
            }

            @if (isLoading)
            {
                <p class="text-sm text-black/50 dark:text-white/60">Loading competitions...</p>
            }
            else if (SelectedCompetitionForDetail is not null)
            {
                <!-- VISTA 2: desglose de capacidades de la competicion filtrada (solo lectura) -->
                <div class="flex items-center justify-between mb-4">
                    <div>
                        <h2 class="text-lg font-bold text-black dark:text-white">@SelectedCompetitionForDetail.Name</h2>
                        <p class="text-sm text-black/50 dark:text-white/60">@SelectedCompetitionForDetail.Format &middot; @SelectedCompetitionForDetail.Price.ToString("0.00") &euro;</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <button type="button" class="btn border border-black/10" @onclick="ClearCompetitionFilter">
                            <i class="ri-arrow-left-line ltr:mr-1 rtl:ml-1"></i>
                            Back to all competitions
                        </button>
                        <button type="button" class="transition-all duration-300 border rounded-md btn text-purple border-purple hover:bg-purple hover:text-white whitespace-nowrap" @onclick="() => OpenEditModal(SelectedCompetitionForDetail)">
                            <i class="ri-pencil-line ltr:mr-1 rtl:ml-1"></i>
                            Edit Competition
                        </button>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full table-hover">
                        <thead class="bg-gray-50 dark:bg-dark">
                            <tr class="text-left">
                                <th class="px-4 py-3 font-semibold">Level</th>
                                <th class="px-4 py-3 font-semibold">Role</th>
                                <th class="px-4 py-3 font-semibold">Capacity</th>
                                <th class="px-4 py-3 font-semibold">Occupancy</th>
                                <th class="px-4 py-3 font-semibold">Status</th>
                            </tr>
                        </thead>
                        <tbody class="text-black dark:text-white/80">
                            @if (SelectedCompetitionForDetail.Capacities.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="px-4 py-6 text-center text-black/50 dark:text-white/60">
                                        No capacities defined yet. Use "Edit Competition" to add levels and capacities.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (CompetitionCapacityDto cap in SelectedCompetitionForDetail.Capacities.OrderBy(c => c.SortOrder))
                                {
                                    CompetitionLevelDto? level = SelectedCompetitionForDetail.Levels.FirstOrDefault(l => l.Id == cap.CompetitionLevelId);

                                    <tr @key="cap.Id" class="border-b border-black/10 dark:border-darkborder">
                                        <td class="px-4 py-3">@(level?.Name ?? "-")</td>
                                        <td class="px-4 py-3">@(SelectedCompetitionForDetail.RequiresRole ? cap.DanceRole.ToString() : "-")</td>
                                        <td class="px-4 py-3">@cap.Capacity</td>
                                        <td class="px-4 py-3">@cap.Current/@cap.Capacity</td>
                                        <td class="px-4 py-3"><span class="@GetStatusClass(cap.IsActive)">@(cap.IsActive ? "Active" : "Inactive")</span></td>
                                    </tr>
                                }
                                <tr class="font-semibold border-t-2 border-black/10 dark:border-darkborder">
                                    <td class="px-4 py-3" colspan="2">TOTAL</td>
                                    <td class="px-4 py-3">@SelectedCompetitionForDetail.Capacities.Sum(c => c.Capacity)</td>
                                    <td class="px-4 py-3">@SelectedCompetitionForDetail.Capacities.Sum(c => c.Current)/@SelectedCompetitionForDetail.Capacities.Sum(c => c.Capacity)</td>
                                    <td class="px-4 py-3"></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <!-- VISTA 1: lista simple de competiciones -->
                <div class="overflow-x-auto">
                    <table class="w-full table-hover">
                        <thead class="bg-gray-50 dark:bg-dark">
                            <tr class="text-left">
                                <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Name")'>Name @SortIcon("Name")</button></th>
                                <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Format")'>Format @SortIcon("Format")</button></th>
                                <th class="px-4 py-3 font-semibold">Price</th>
                                <th class="px-4 py-3 font-semibold">Capacity</th>
                                <th class="px-4 py-3 font-semibold">Occupancy</th>
                                <th class="px-4 py-3 font-semibold"><button type="button" class="flex items-center gap-1 w-full font-semibold" @onclick='() => SortBy("Status")'>Status @SortIcon("Status")</button></th>
                                <th class="px-4 py-3 font-semibold text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="text-black dark:text-white/80">
                            @if (PagedCompetitions.Count == 0)
                            {
                                <tr>
                                    <td colspan="7" class="px-4 py-6 text-center text-black/50 dark:text-white/60">No competitions found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (CompetitionDto competition in PagedCompetitions)
                                {
                                    <tr @key="competition.Id" class="border-b border-black/10 dark:border-darkborder">
                                        <td class="px-4 py-3">
                                            <div class="font-medium">@competition.Name</div>
                                            <div class="text-xs text-black/50 dark:text-white/60">@competition.Description</div>
                                        </td>
                                        <td class="px-4 py-3">@competition.Format</td>
                                        <td class="px-4 py-3">@competition.Price.ToString("0.00") &euro;</td>
                                        <td class="px-4 py-3">@TotalCapacity(competition)</td>
                                        <td class="px-4 py-3">@TotalOccupancy(competition)/@TotalCapacity(competition)</td>
                                        <td class="px-4 py-3"><span class="@GetStatusClass(competition.IsActive)">@(competition.IsActive ? "Active" : "Inactive")</span></td>
                                        <td class="px-4 py-3">
                                            <div class="flex items-center justify-end gap-3">
                                                <button type="button" class="text-black dark:text-white/80" title="Edit" @onclick="() => OpenEditModal(competition)"><i class="ri-pencil-line text-lg"></i></button>
                                                <button type="button" class="text-danger" title="Delete" @onclick="() => OpenDeleteModal(competition)"><i class="ri-delete-bin-line text-lg"></i></button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="flex items-center justify-between mt-4">
                    <p class="text-sm text-black/50 dark:text-white/60">
                        Showing @StartRow to @EndRow of @FilteredCompetitions.Count competitions
                    </p>
                    <div class="flex items-center gap-2">
                        <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage == 1)" @onclick="PreviousPage">Previous</button>
                        <span class="flex items-center justify-center w-10 h-10 text-sm rounded-md bg-purple/10 text-purple">@currentPage</span>
                        <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10 disabled:opacity-50" disabled="@(currentPage >= TotalPages)" @onclick="NextPage">Next</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative mx-auto overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder" style="width: min(95vw, 820px);">
                <div class="flex items-center justify-between px-5 py-3 border-b border-black/10 dark:border-darkborder">
                    <h3 class="text-lg font-semibold text-black dark:text-white">@(editingCompetition is null ? "New Competition" : "Edit Competition")</h3>
                    <button type="button" class="text-black/50 hover:text-black dark:text-white/60" @onclick="CloseModal"><i class="ri-close-line text-2xl"></i></button>
                </div>

                <div class="p-5 space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Edition</label>
                            <select class="form-select" @bind="formModel.EditionId">
                                @foreach (EditionDto edition in editions)
                                {
                                    <option value="@edition.Id">@edition.Name</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Format</label>
                            <select class="form-select" @bind="formModel.Format" @bind:after="OnFormatChanged">
                                <option value="@CompetitionFormat.Individual">Individual</option>
                                <option value="@CompetitionFormat.Partnered">Partnered</option>
                                <option value="@CompetitionFormat.Team">Team</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Name</label>
                            <InputText class="form-input" @bind-Value="formModel.Name" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Price</label>
                            <InputNumber class="form-input" @bind-Value="formModel.Price" />
                        </div>

                        <div>
                            <label class="block text-sm text-black/60 dark:text-white/60">Sort Order</label>
                            <InputNumber class="form-input" @bind-Value="formModel.SortOrder" />
                        </div>

                        <div class="flex items-center gap-4 pt-6">
                            @if (formModel.Format != CompetitionFormat.Team)
                            {
                                <label class="inline-flex items-center gap-2"><InputCheckbox @bind-Value="formModel.RequiresPartner" />Requires partner</label>
                                <label class="inline-flex items-center gap-2"><InputCheckbox @bind-Value="formModel.RequiresRole" />Requires role</label>
                            }
                            <label class="inline-flex items-center gap-2"><InputCheckbox @bind-Value="formModel.IsActive" />Active</label>
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm text-black/60 dark:text-white/60">Description</label>
                            <InputTextArea class="form-input" rows="3" @bind-Value="formModel.Description" />
                        </div>
                    </div>
                        <div class="border rounded-lg border-black/10 dark:border-darkborder p-4">
                            <div class="flex items-center justify-between mb-3">
                                <h4 class="text-sm font-semibold text-black dark:text-white">Levels (optional)</h4>
                                <button type="button" class="transition-all duration-300 border rounded-md btn text-purple border-purple hover:bg-purple hover:text-white whitespace-nowrap" @onclick="AddLevel">
                                    <i class="ri-add-line ltr:mr-1 rtl:ml-1"></i>
                                    New Level
                                </button>
                            </div>

                            @if (formModel.LevelNames.Count == 0)
                            {
                                <p class="text-xs text-black/40 dark:text-white/60">No levels defined. This competition will have a single capacity, with no level breakdown.</p>
                            }

                            @for (int i = 0; i < formModel.LevelNames.Count; i++)
                            {
                                int idx = i;

                                <div @key="idx" class="flex items-end gap-3 mb-2">
                                    <div class="flex-1">
                                        <label class="block text-xs text-black/50 dark:text-white/60">Level name</label>
                                        <input class="form-input" value="@formModel.LevelNames[idx]" @oninput="(ChangeEventArgs e) => UpdateLevelName(idx, e.Value?.ToString() ?? string.Empty)" placeholder="e.g. Open, Advanced, Beginner..." />
                                    </div>
                                    <button type="button" class="btn border text-danger" @onclick="() => RemoveLevel(idx)">Remove</button>
                                </div>
                            }
                        </div>

                        <div class="border rounded-lg border-black/10 dark:border-darkborder p-4">
                            <div class="flex items-center justify-between mb-3">
                                <h4 class="text-sm font-semibold text-black dark:text-white">Capacities</h4>
                                <button type="button" class="transition-all duration-300 border rounded-md btn text-purple border-purple hover:bg-purple hover:text-white whitespace-nowrap" @onclick="AddCapacity">
                                    <i class="ri-add-line ltr:mr-1 rtl:ml-1"></i>
                                    New Capacity
                                </button>
                            </div>

                            @if (formModel.Capacities.Count == 0)
                            {
                                <p class="text-xs text-black/40 dark:text-white/60">No capacities defined yet.</p>
                            }

                            @foreach (CompetitionCapacityFormModel capacity in formModel.Capacities)
                            {
                                <div @key="capacity" class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-3 p-3 border rounded-md border-black/10 dark:border-darkborder">
                                    <div>
                                        <label class="block text-xs text-black/50 dark:text-white/60">Level</label>
                                        <select class="form-select" @bind="capacity.LevelName">
                                            <option value="">No level</option>
                                            @foreach (string levelName in formModel.LevelNames.Where(n => !string.IsNullOrWhiteSpace(n)))
                                            {
                                                <option value="@levelName">@levelName</option>
                                            }
                                        </select>
                                    </div>

                                    <div>
                                        <label class="block text-xs text-black/50 dark:text-white/60">Role</label>
                                        <select class="form-select" @bind="capacity.DanceRole">
                                            <option value="@DanceRole.Leader">Leader</option>
                                            <option value="@DanceRole.Follower">Follower</option>
                                            <option value="@DanceRole.Individual">Individual</option>
                                        </select>
                                    </div>

                                    <div>
                                        <label class="block text-xs text-black/50 dark:text-white/60">Capacity</label>
                                        <InputNumber class="form-input" @bind-Value="capacity.Capacity" />
                                    </div>

                                    <div class="flex items-end gap-2">
                                        <div class="flex-1">
                                            <label class="block text-xs text-black/50 dark:text-white/60">Sort order</label>
                                            <InputNumber class="form-input" @bind-Value="capacity.SortOrder" />
                                        </div>
                                        <button type="button" class="btn border text-danger" @onclick="() => RemoveCapacity(capacity)">Remove</button>
                                    </div>
                                </div>
                            }
                        </div>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="px-4 py-2 text-sm text-white rounded-md bg-purple" @onclick="SaveAsync">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (showDeleteModal && deletingCompetition is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-[92vw] md:w-[380px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="px-5 py-4">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Delete Competition</h3>
                    <p class="mt-2 text-sm text-black/60 dark:text-white/60">Are you sure you want to delete <strong>@deletingCompetition.Name</strong>?</p>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="btn border border-black/10" disabled="@isSaving" @onclick="CloseDeleteModal">Cancel</button>
                    <button type="button" class="btn border border-danger text-danger hover:bg-danger hover:text-white disabled:opacity-50" disabled="@isSaving" @onclick="DeleteAsync">@(isSaving ? "Deleting..." : "Delete")</button>
                </div>
            </div>
        </div>
    </div>
}

@implements IDisposable
@code {
    private List<CompetitionDto> competitions = [];
    private List<EditionDto> editions = [];
    private List<FestivalDto> festivals = [];
    private CompetitionDto? editingCompetition;
    private CompetitionDto? deletingCompetition;
    private CompetitionFormModel formModel = new();

    private string searchText = string.Empty;
    private Guid festivalFilter = Guid.Empty;
    private Guid editionFilter = Guid.Empty;
    private List<EditionDto> EditionsForSelectedFestival =>
        festivalFilter == Guid.Empty
            ? editions
            : editions.Where(e => e.FestivalId == festivalFilter).ToList();

    private void OnFestivalFilterChanged()
    {
        editionFilter = Guid.Empty;
        ResetPage();
    }
    private Guid competitionNameFilter = Guid.Empty;

    private bool isLoading = true;
    private bool isSaving;
    private string? successMessage;
    private string? errorMessage;

    private int currentPage = 1;
    private int pageSize = 25;
    private bool sortAscending = true;
    private string sortColumn = "Name";

    private bool showModal;
    private bool showDeleteModal;

    // VISTA 2: cuando hay una competicion concreta seleccionada en el filtro,
    // mostramos su detalle de capacidades en vez de la lista.
    private CompetitionDto? SelectedCompetitionForDetail =>
        competitionNameFilter == Guid.Empty ? null : competitions.FirstOrDefault(c => c.Id == competitionNameFilter);

    private void ClearCompetitionFilter()
    {
        competitionNameFilter = Guid.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        ActiveFestivalState.OnChange += HandleFestivalStateChanged;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            editions = (await EditionApiClient.GetAllAsync()).ToList();
            festivals = (await FestivalApiClient.GetAllAsync()).ToList();

            if (ActiveFestivalState.Active is not null && festivalFilter == Guid.Empty)
            {
                festivalFilter = ActiveFestivalState.Active.Id;
            }

            if (ActiveFestivalState.Active is not null && editionFilter == Guid.Empty)
            {
                EditionDto? preferred = editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id && e.IsActive)
                    ?? editions.FirstOrDefault(e => e.FestivalId == ActiveFestivalState.Active.Id);
                editionFilter = preferred?.Id ?? Guid.Empty;
            }

            competitions = (await CompetitionApiClient.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static int TotalCapacity(CompetitionDto competition) =>
        competition.Capacities.Sum(c => c.Capacity);

    private static int TotalOccupancy(CompetitionDto competition) =>
        competition.Capacities.Sum(c => c.Current);

    private List<CompetitionDto> FilteredCompetitions
    {
        get
        {
            IEnumerable<CompetitionDto> query = competitions;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(c => c.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            if (editionFilter != Guid.Empty)
            {
                query = query.Where(c => c.EditionId == editionFilter);
            }
            else if (festivalFilter != Guid.Empty)
            {
                HashSet<Guid> editionIds = editions.Where(e => e.FestivalId == festivalFilter).Select(e => e.Id).ToHashSet();
                query = query.Where(c => editionIds.Contains(c.EditionId));
            }

            query = sortColumn switch
            {
                "Format" => sortAscending ? query.OrderBy(c => c.Format) : query.OrderByDescending(c => c.Format),
                "Status" => sortAscending ? query.OrderBy(c => c.IsActive) : query.OrderByDescending(c => c.IsActive),
                _ => sortAscending ? query.OrderBy(c => c.Name) : query.OrderByDescending(c => c.Name)
            };

            return query.ToList();
        }
    }

    private List<CompetitionDto> PagedCompetitions => FilteredCompetitions.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();

    private void ResetPage() => currentPage = 1;

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column)
        {
            return new MarkupString("<i class=\"ri-arrow-up-down-line text-xs opacity-40\"></i>");
        }

        return new MarkupString(sortAscending ? "<i class=\"ri-arrow-up-s-fill text-xs text-purple\"></i>" : "<i class=\"ri-arrow-down-s-fill text-xs text-purple\"></i>");
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredCompetitions.Count / (double)pageSize));
    private int StartRow => FilteredCompetitions.Count == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int EndRow => Math.Min(currentPage * pageSize, FilteredCompetitions.Count);

    private void PreviousPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < TotalPages) currentPage++; }

    private static string GetStatusClass(bool isActive) =>
        isActive ? "inline-block rounded text-xs px-2 py-1 bg-success/10 text-success" : "inline-block rounded text-xs px-2 py-1 bg-danger/10 text-danger";

    private void OpenCreateModal()
    {
        editingCompetition = null;
        formModel = new CompetitionFormModel
        {
            EditionId = editions.FirstOrDefault()?.Id ?? Guid.Empty,
            Format = CompetitionFormat.Individual,
            RequiresPartner = false,
            RequiresRole = false,
            IsActive = true
        };

        showModal = true;
    }

    private void OpenEditModal(CompetitionDto competition)
    {
        editingCompetition = competition;
        formModel = new CompetitionFormModel
        {
            EditionId = competition.EditionId,
            Name = competition.Name,
            Description = competition.Description,
            Format = competition.Format,
            RequiresPartner = competition.RequiresPartner,
            RequiresRole = competition.RequiresRole,
            Price = competition.Price,
            RegistrationOpenAt = competition.RegistrationOpenAt,
            RegistrationCloseAt = competition.RegistrationCloseAt,
            SortOrder = competition.SortOrder,
            IsActive = competition.IsActive,
            LevelNames = competition.Levels.OrderBy(l => l.SortOrder).Select(l => l.Name).ToList(),
            Capacities = competition.Capacities.Select(c => new CompetitionCapacityFormModel
            {
                LevelName = competition.Levels.FirstOrDefault(l => l.Id == c.CompetitionLevelId)?.Name,
                DanceRole = c.DanceRole,
                Capacity = c.Capacity,
                SortOrder = c.SortOrder
            }).ToList()
        };

        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private void OnFormatChanged()
    {
        // Format change does not auto-clear levels/capacities -- all formats support them.
    }

    private void AddLevel()
    {
        formModel.LevelNames.Add(string.Empty);
    }

    private void UpdateLevelName(int index, string value)
    {
        if (index >= 0 && index < formModel.LevelNames.Count)
        {
            formModel.LevelNames[index] = value;
        }
    }

    private void RemoveLevel(int index)
    {
        if (index < 0 || index >= formModel.LevelNames.Count)
        {
            return;
        }

        string removedName = formModel.LevelNames[index];
        formModel.LevelNames.RemoveAt(index);

        foreach (CompetitionCapacityFormModel capacity in formModel.Capacities)
        {
            if (string.Equals(capacity.LevelName, removedName, StringComparison.OrdinalIgnoreCase))
            {
                capacity.LevelName = null;
            }
        }
    }

    private void AddCapacity()
    {
        formModel.Capacities.Add(new CompetitionCapacityFormModel { DanceRole = DanceRole.Leader, Capacity = 10, SortOrder = formModel.Capacities.Count + 1 });
    }

    private void RemoveCapacity(CompetitionCapacityFormModel capacity)
    {
        formModel.Capacities.Remove(capacity);
    }

    private async Task SaveAsync()
    {
        try
        {
            List<string> levelNames = formModel.LevelNames.Where(n => !string.IsNullOrWhiteSpace(n)).ToList();

            if (editingCompetition is null)
            {
                CreateCompetitionRequest request = new()
                {
                    EditionId = formModel.EditionId,
                    Name = formModel.Name,
                    Description = formModel.Description,
                    Format = formModel.Format,
                    RequiresPartner = formModel.RequiresPartner,
                    RequiresRole = formModel.RequiresRole,
                    Price = formModel.Price,
                    RegistrationOpenAt = formModel.RegistrationOpenAt,
                    RegistrationCloseAt = formModel.RegistrationCloseAt,
                    SortOrder = formModel.SortOrder,
                    LevelNames = levelNames,
                    Capacities = formModel.Capacities.Select(c => new CreateCompetitionCapacityRequest
                    {
                        LevelName = c.LevelName,
                        DanceRole = c.DanceRole,
                        Capacity = c.Capacity,
                        SortOrder = c.SortOrder
                    }).ToList()
                };

                await CompetitionApiClient.CreateAsync(request);
                showModal = false;
                await LoadDataAsync();
                await ShowSuccessAsync("Competition created successfully.");
            }
            else
            {
                UpdateCompetitionRequest request = new()
                {
                    EditionId = formModel.EditionId,
                    Name = formModel.Name,
                    Description = formModel.Description,
                    Format = formModel.Format,
                    RequiresPartner = formModel.RequiresPartner,
                    RequiresRole = formModel.RequiresRole,
                    Price = formModel.Price,
                    RegistrationOpenAt = formModel.RegistrationOpenAt,
                    RegistrationCloseAt = formModel.RegistrationCloseAt,
                    SortOrder = formModel.SortOrder,
                    IsActive = formModel.IsActive,
                    LevelNames = levelNames,
                    Capacities = formModel.Capacities.Select(c => new UpdateCompetitionCapacityRequest
                    {
                        LevelName = c.LevelName,
                        DanceRole = c.DanceRole,
                        Capacity = c.Capacity,
                        SortOrder = c.SortOrder
                    }).ToList()
                };

                await CompetitionApiClient.UpdateAsync(editingCompetition.Id, request);
                showModal = false;
                await LoadDataAsync();
                await ShowSuccessAsync("Competition updated successfully.");
            }
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex.Message);
        }
    }

    private void OpenDeleteModal(CompetitionDto competition)
    {
        deletingCompetition = competition;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        deletingCompetition = null;
        showDeleteModal = false;
    }

    private async Task DeleteAsync()
    {
        if (deletingCompetition is null)
        {
            return;
        }

        try
        {
            isSaving = true;
            await CompetitionApiClient.DeleteAsync(deletingCompetition.Id);
            deletingCompetition = null;
            showDeleteModal = false;
            competitionNameFilter = Guid.Empty;
            await LoadDataAsync();
            await ShowSuccessAsync("Competition deleted successfully.");
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ShowSuccessAsync(string message)
    {
        successMessage = message;
        errorMessage = null;

        StateHasChanged();
        await Task.Delay(3500);

        successMessage = null;
        StateHasChanged();
    }

    private async Task ShowErrorAsync(string message)
    {
        errorMessage = message;
        successMessage = null;

        StateHasChanged();
        await Task.Delay(3500);

        errorMessage = null;
        StateHasChanged();
    }

    private class CompetitionFormModel
    {
        public Guid EditionId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public CompetitionFormat Format { get; set; }
        public bool RequiresPartner { get; set; }
        public bool RequiresRole { get; set; }
        public decimal Price { get; set; }
        public DateTime? RegistrationOpenAt { get; set; }
        public DateTime? RegistrationCloseAt { get; set; }
        public int SortOrder { get; set; }
        public bool IsActive { get; set; }
        public List<string> LevelNames { get; set; } = [];
        public List<CompetitionCapacityFormModel> Capacities { get; set; } = [];
    }

    private class CompetitionCapacityFormModel
    {
        public string? LevelName { get; set; }
        public DanceRole DanceRole { get; set; }
        public int Capacity { get; set; }
        public int SortOrder { get; set; }
    }
    private void HandleFestivalStateChanged()
    {
        InvokeAsync(async () =>
        {
            festivalFilter = Guid.Empty;
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ActiveFestivalState.OnChange -= HandleFestivalStateChanged;
    }
}
