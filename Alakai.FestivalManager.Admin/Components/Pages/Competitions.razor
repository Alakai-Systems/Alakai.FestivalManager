                    </div>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="px-4 py-2 text-sm border rounded-md border-black/10"
                            @onclick="() => showCreateCapacityModal = false">
                        Cancel
                    </button>

                    <button type="button" class="px-4 py-2 text-sm text-white rounded-md bg-purple"
                            @onclick="SaveNewCapacityAsync">
                        Save
                    </button>
                </div>

            </div>
