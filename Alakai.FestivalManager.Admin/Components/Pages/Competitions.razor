    private void ResetDefaultCapacities()
    {
        if (formModel.Format == CompetitionFormat.SoloJazz)
        {
            formModel.Capacities =
            [
                new CompetitionCapacityFormModel { MixAndMatchLevel = null, DanceRole = DanceRole.Individual, Capacity = 50, SortOrder = 1 }
            ];
        }
        else
        {
            formModel.Capacities =
            [
                new CompetitionCapacityFormModel { MixAndMatchLevel = MixAndMatchLevel.Open, DanceRole = DanceRole.Leader, Capacity = 20, SortOrder = 1 },
                new CompetitionCapacityFormModel { MixAndMatchLevel = MixAndMatchLevel.Open, DanceRole = DanceRole.Follower, Capacity = 20, SortOrder = 2 },
                new CompetitionCapacityFormModel { MixAndMatchLevel = MixAndMatchLevel.Advanced, DanceRole = DanceRole.Leader, Capacity = 15, SortOrder = 3 },
                new CompetitionCapacityFormModel { MixAndMatchLevel = MixAndMatchLevel.Advanced, DanceRole = DanceRole.Follower, Capacity = 15, SortOrder = 4 }
            ];
        }
    }

    private void AddCapacity()
    {
        formModel.Capacities.Add(new CompetitionCapacityFormModel { DanceRole = DanceRole.Leader, Capacity = 10, SortOrder = formModel.Capacities.Count + 1 });
    }

    private void RemoveCapacity(CompetitionCapacityFormModel capacity)
    {
        formModel.Capacities.Remove(capacity);
    }

    private async Task SaveAsync()
    {
        try
        {
            if (editingCompetition is null)
            {
                CreateCompetitionRequest request = new()
                {
                    EditionId = formModel.EditionId,
                    Name = formModel.Name,
                    Description = formModel.Description,
                    Format = formModel.Format,
                    RequiresPartner = formModel.RequiresPartner,
                    RequiresRole = formModel.RequiresRole,
                    Price = formModel.Price,
                    RegistrationOpenAt = formModel.RegistrationOpenAt,
                    RegistrationCloseAt = formModel.RegistrationCloseAt,
                    SortOrder = formModel.SortOrder,
                    Capacities = formModel.Capacities.Select(c => new CreateCompetitionCapacityRequest
                    {
                        MixAndMatchLevel = c.MixAndMatchLevel,
                        DanceRole = c.DanceRole,
                        Capacity = c.Capacity,
                        SortOrder = c.SortOrder
                    }).ToList()
                };

                await CompetitionApiClient.CreateAsync(request);
                successMessage = "Competition created successfully.";
            }
            else
            {
                UpdateCompetitionRequest request = new()
                {
                    EditionId = formModel.EditionId,
                    Name = formModel.Name,
                    Description = formModel.Description,
                    Format = formModel.Format,
                    RequiresPartner = formModel.RequiresPartner,
                    RequiresRole = formModel.RequiresRole,
                    Price = formModel.Price,
                    RegistrationOpenAt = formModel.RegistrationOpenAt,
                    RegistrationCloseAt = formModel.RegistrationCloseAt,
                    SortOrder = formModel.SortOrder,
                    IsActive = formModel.IsActive,
                    Capacities = formModel.Capacities.Select(c => new UpdateCompetitionCapacityRequest
                    {
                        MixAndMatchLevel = c.MixAndMatchLevel,
                        DanceRole = c.DanceRole,
                        Capacity = c.Capacity,
                        SortOrder = c.SortOrder
                    }).ToList()
                };

                await CompetitionApiClient.UpdateAsync(editingCompetition.Id, request);
                successMessage = "Competition updated successfully.";
            }

            showModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void OpenDeleteModal(CompetitionDto competition)
    {
        deletingCompetition = competition;
    }

    private void CloseDeleteModal()
    {
        deletingCompetition = null;
    }

    private async Task DeleteAsync()
    {
        if (deletingCompetition is null)
        {
            return;
        }

        try
        {
            await CompetitionApiClient.DeleteAsync(deletingCompetition.Id);
            successMessage = "Competition deleted successfully.";
            deletingCompetition = null;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private static string FormatCapacities(CompetitionDto competition)
    {
        if (competition.Capacities.Count == 0)
        {
            return "-";
        }

        return string.Join(", ", competition.Capacities.Select(c => $"{c.MixAndMatchLevel?.ToString() ?? "Solo"} {c.DanceRole}: {c.Capacity}"));
    }

    private static string GetStatusClass(bool isActive)
    {
        return isActive ? "inline-block rounded text-xs px-2 py-1 bg-success/10 text-success" : "inline-block rounded text-xs px-2 py-1 bg-danger/10 text-danger";
    }

