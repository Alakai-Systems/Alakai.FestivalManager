@if (showDeleteCapacityModal && editingCapacity is not null)
{
    <div class="fixed inset-0 bg-black/60 z-[999] overflow-y-auto">
        <div class="flex items-start justify-center min-h-screen px-4 py-10">
            <div class="relative w-[92vw] md:w-[380px] overflow-hidden bg-white border rounded-lg shadow-3xl border-black/10 dark:bg-darklight dark:border-darkborder">
                <div class="px-5 py-4">
                    <h3 class="text-lg font-semibold text-black dark:text-white">Delete Capacity</h3>
                    <p class="mt-2 text-sm text-black/60 dark:text-white/50">Are you sure you want to delete <strong>@editingCapacity.MixAndMatchLevel @editingCapacity.DanceRole?</strong>?</p>
                </div>

                <div class="flex justify-end gap-3 px-5 py-4 border-t border-black/10 dark:border-darkborder">
                    <button type="button" class="btn border border-black/10" disabled="@isSaving" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="btn border border-danger text-danger hover:bg-danger hover:text-white disabled:opacity-50" disabled="@isSaving" @onclick="DeleteCapacityAsync">
                        @(isSaving ? "Deleting..." : "Delete")
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private List<CompetitionDto> competitions = [];
    private List<EditionDto> editions = [];
    private CompetitionDto? editingCompetition;
    private CompetitionDto? deletingCompetition;
    private CompetitionFormModel formModel = new();
    private string searchText = string.Empty;
    private bool isSaving;
    private Guid editionFilter = Guid.Empty;
    private string formatFilter = string.Empty;
    private string sortColumn = "Name";
    private bool sortAscending = true;
    private bool isLoading = true;
    private bool showModal;
    private string? successMessage;
    private string? errorMessage;
    private int currentPage = 1;
    private int pageSize = 10;
    private CompetitionFormat? SelectedFormat
    {
        get
        {
            if (Enum.TryParse(formatFilter, out CompetitionFormat format))
            {
                return format;
            }

            return null;
        }
    }
    private string mixAndMatchLevelFilter = string.Empty;
    private string mixAndMatchRoleFilter = string.Empty;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredCompetitions.Count / pageSize));
    private int ShowingFrom => FilteredCompetitions.Count == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    private int ShowingTo => Math.Min(currentPage * pageSize, FilteredCompetitions.Count);
    private CompetitionDto? editingCompetitionForCapacity;
    private CompetitionCapacityDto? editingCapacity;
    private bool showCreateCapacityModal = false;
    private bool showEditCapacityModal = false;
    private bool showDeleteCapacityModal = false;
    private bool showDeleteModal = false;

    private void ShowSuccess(string message)
    {
        successMessage = message;
        errorMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            successMessage = null;
            StateHasChanged();
        });
    }

    private void ShowError(string message)
    {
        errorMessage = message;
        successMessage = null;
        InvokeAsync(async () =>
        {
            await Task.Delay(3500);
            errorMessage = null;
            StateHasChanged();
        });
    }


    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            editions = (await EditionApiClient.GetAllAsync()).ToList();
            competitions = (await CompetitionApiClient.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<CompetitionDto> FilteredCompetitions
    {
        get
        {
            IEnumerable<CompetitionDto> query = competitions;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(c => c.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            if (editionFilter != Guid.Empty)
            {
                query = query.Where(c => c.EditionId == editionFilter);
            }

            if (!string.IsNullOrWhiteSpace(formatFilter) &&
                Enum.TryParse(formatFilter, out CompetitionFormat format))
            {
                query = query.Where(c => c.Format == format);

                if (format == CompetitionFormat.MixAndMatch)
                {
                    if (!string.IsNullOrWhiteSpace(mixAndMatchLevelFilter) &&
                        Enum.TryParse(mixAndMatchLevelFilter, out MixAndMatchLevel level))
                    {
                        query = query.Where(c => c.Capacities.Any(cap => cap.MixAndMatchLevel == level));
                    }

                    if (!string.IsNullOrWhiteSpace(mixAndMatchRoleFilter) &&
                        Enum.TryParse(mixAndMatchRoleFilter, out DanceRole role))
                    {
                        query = query.Where(c => c.Capacities.Any(cap => cap.DanceRole == role));
                    }
                }
            }

            query = sortColumn switch
            {
                "Format" => sortAscending ? query.OrderBy(c => c.Format) : query.OrderByDescending(c => c.Format),
                "SortOrder" => sortAscending ? query.OrderBy(c => c.SortOrder) : query.OrderByDescending(c => c.SortOrder),
                "Status" => sortAscending ? query.OrderBy(c => c.IsActive) : query.OrderByDescending(c => c.IsActive),
                _ => sortAscending ? query.OrderBy(c => c.Name) : query.OrderByDescending(c => c.Name)
            };

            return query.ToList();
        }
    }


    private List<CompetitionDto> PagedCompetitions => FilteredCompetitions.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();

    private void ResetPage()
    {
        currentPage = 1;
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column)
        {
            return new MarkupString("<i class=\"ri-arrow-up-down-line text-xs opacity-40\"></i>");
        }

        return new MarkupString(sortAscending ? "<i class=\"ri-arrow-up-s-fill text-xs text-purple\"></i>" : "<i class=\"ri-arrow-down-s-fill text-xs text-purple\"></i>");
    }

