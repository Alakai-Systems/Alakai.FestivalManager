    private RenderFragment RenderMixAndMatchTable() => __builder =>
{
    <table class="w-full table-hover">
        <thead class="bg-gray-50 dark:bg-dark">
            <tr class="text-left">
                <th class="px-4 py-3 font-semibold">Name</th>
                <th class="px-4 py-3 font-semibold">Level</th>
                <th class="px-4 py-3 font-semibold">Role</th>
                <th class="px-4 py-3 font-semibold">Capacity</th>
                <th class="px-4 py-3 font-semibold">Ocupación</th>
                <th class="px-4 py-3 font-semibold">Status</th>
                <th class="px-4 py-3 font-semibold text-right">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var c in PagedCompetitions.Where(x => x.Format == CompetitionFormat.MixAndMatch))
            {
                // Aplicamos los filtros de nivel/rol sobre las capacities
                var caps = c.Capacities.AsEnumerable();

                if (!string.IsNullOrWhiteSpace(mixAndMatchLevelFilter) &&
                Enum.TryParse(mixAndMatchLevelFilter, out MixAndMatchLevel level))
                {
                    caps = caps.Where(cap => cap.MixAndMatchLevel == level);
                }

                if (!string.IsNullOrWhiteSpace(mixAndMatchRoleFilter) &&
                Enum.TryParse(mixAndMatchRoleFilter, out DanceRole role))
                {
                    caps = caps.Where(cap => cap.DanceRole == role);
                }

                var filteredCaps = caps.ToList();

                if (filteredCaps.Count == 0)
                {
                    // Si esta competición no tiene capacities que pasen el filtro, no pintamos nada
                    continue;
                }

                foreach (var cap in filteredCaps)
                {
                    <tr class="border-b border-black/10 dark:border-darkborder">
                        <td class="px-4 py-3">
                            <div class="font-medium">@c.Name</div>
                            <div class="text-xs text-black/50 dark:text-white/40">@c.Description</div>
                        </td>

                        <td class="px-4 py-3">@cap.MixAndMatchLevel</td>
                        <td class="px-4 py-3">@cap.DanceRole</td>
                        <td class="px-4 py-3">@cap.Capacity</td>
                        <td class="px-4 py-3">@($"{cap.Current}/{cap.Capacity}")</td>

                        <td class="px-4 py-3">
                            <span class="@GetStatusClass(c.IsActive)">
                                @(c.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>

                        <td class="px-4 py-3">
                            <div class="flex items-center justify-end gap-3">
                                <button type="button" class="text-black dark:text-white/80" @onclick="() => OpenEditCapacityModal(c, cap)">
                                    <i class="ri-pencil-line text-lg"></i>
                                </button>
                                <button type="button" class="text-danger" @onclick="() => OpenDeleteCapacityModal(c, cap)">
                                    <i class="ri-delete-bin-line text-lg"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
};

    private void OpenCreateModal()
