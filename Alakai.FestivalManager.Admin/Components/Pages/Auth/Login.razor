@page "/user-panel/login"
@layout AuthLayout

@using Alakai.FestivalManager.Admin.Contracts.Auth.DTOs
@using Alakai.FestivalManager.Admin.Contracts.Auth.Requests

@inject NavigationManager Navigation
@inject IAuthApiClient AuthApiClient
@inject ITokenStorageService TokenStorageService
@inject IConfiguration Configuration
@inject IJSRuntime JsRuntime

@implements IAsyncDisposable

@code {
    [CascadingParameter]
    public Alakai.FestivalManager.Admin.Services.Api.PublicFestivalBrandingDto? Branding { get; set; }
}

<!-- Start Main Content -->
<div class="min-h-[calc(100vh-134px)] py-4 px-4 sm:px-12 flex justify-center items-center max-w-[1440px] mx-auto bg-light/60 dark:bg-dark">
    <div class="max-w-[550px] flex-none w-full bg-white border border-black/10 p-6 sm:p-10 lg:px-10 lg:py-14 rounded-2xl loginform shadow-3xl shadow-black/10 dark:bg-darklight dark:border-darkborder">
        @if (!string.IsNullOrWhiteSpace(Branding?.LogoUrl))
        {
            <div class="flex items-center justify-center h-10 mb-6">
                <img src="@Branding.LogoUrl" alt="@Branding.Name" class="object-contain max-w-full max-h-10" />
            </div>
        }
        <MudText Typo="Typo.h1" Class="mb-2 text-2xl font-semibold text-center dark:text-white">Sign In</MudText>
        <MudText Class="text-center text-muted mb-7 dark:text-darkmuted">Enter your email and password to sign in!</MudText>

        @if (HasGoogleLogin || HasAppleLogin)
        {
            <div class="flex flex-wrap items-center gap-4 mb-7">
                @if (HasGoogleLogin)
                {

                    <button type="button"
                            disabled="@IsLoading"
                            @onclick="SignInWithGoogleAsync"
                            class="flex items-center justify-center w-full gap-3 px-4 py-3
                       bg-white border-2 border-black rounded-full
                       hover:bg-slate-50
                       transition-all duration-200">

                        <!-- Google "G" oficial -->
                        <svg width="20" height="20" viewBox="0 0 48 48">
                            <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.7 29.3 36 24 36c-6.6 0-12-5.4-12-12S17.4 12 24 12c3 0 5.7 1.1 7.8 2.9l5.7-5.7C34.1 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.2-.1-2.3-.4-3.5z" />
                            <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 15.1 19 12 24 12c3 0 5.7 1.1 7.8 2.9l5.7-5.7C34.1 6.1 29.3 4 24 4c-7.7 0-14.4 4.3-17.7 10.7z" />
                            <path fill="#4CAF50" d="M24 44c5.2 0 10-2 13.5-5.2l-6.2-5.2C29.2 35.1 26.7 36 24 36c-5.3 0-9.7-3.3-11.4-8l-6.5 5C9.4 39.6 16.1 44 24 44z" />
                            <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-1.1 3.1-3.3 5.5-6.1 6.9l6.2 5.2C39.1 36.6 44 31 44 24c0-1.2-.1-2.3-.4-3.5z" />
                        </svg>

                        <span class="font-medium text-slate-700">
                            Continue with Google
                        </span>

                    </button>
                }
                @if (HasAppleLogin)
                {
                    <button type="button" disabled="@IsLoading" @onclick="SignInWithAppleAsync" class="flex items-center flex-1 gap-1 text-black transition-all duration-300 border rounded-md btn border-light dark:text-white dark:hover:text-black hover:bg-light hover:text-black">
                                    <div class="flex items-center justify-center flex-none w-8 h-8">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-5">
                                            <path fill="currentColor" d="M15.778 8.20805C15.3053 8.17122 14.7974 8.28446 14.0197 8.58079C14.085 8.55589 13.2775 8.87185 13.0511 8.95089C12.5494 9.12605 12.1364 9.2221 11.6734 9.2221C11.2151 9.2221 10.7925 9.13054 10.3078 8.96695C10.1524 8.91453 9.99616 8.85652 9.80283 8.78102C9.71993 8.74864 9.41997 8.62959 9.3544 8.60391C8.70626 8.35008 8.34154 8.25446 8.03885 8.26194C6.88626 8.27662 5.79557 8.94222 5.16246 10.0443C3.87037 12.2876 4.58583 16.3429 6.47459 19.0751C7.4802 20.5191 8.03062 21.0351 8.25199 21.028C8.4743 21.0184 8.63777 20.9714 9.03567 20.8027C9.11485 20.769 9.11485 20.769 9.202 20.7318C10.2077 20.3033 10.9118 20.1141 11.9734 20.1141C12.9944 20.1141 13.6763 20.2999 14.6416 20.716C14.7302 20.7543 14.7302 20.7543 14.8097 20.7885C15.2074 20.9589 15.3509 20.9963 15.6016 20.9903C15.9591 20.9847 16.4003 20.5727 17.3791 19.1363C17.6471 18.7448 17.884 18.3334 18.0895 17.9169C17.9573 17.8078 17.826 17.6918 17.6975 17.5694C16.4086 16.3409 15.6114 14.6846 15.5895 12.6392C15.5756 11.0188 16.1057 9.61499 16.999 8.4581C16.6293 8.31432 16.2216 8.23817 15.778 8.20805ZM15.9334 6.2141C16.6414 6.2621 18.6694 6.4781 19.9894 8.4101C19.8814 8.4701 17.5654 9.8141 17.5894 12.6221C17.6254 15.9821 20.5294 17.0981 20.5654 17.1101C20.5414 17.1941 20.0974 18.7061 19.0294 20.2661C18.1054 21.6221 17.1454 22.9661 15.6334 22.9901C14.1454 23.0261 13.6654 22.1141 11.9734 22.1141C10.2694 22.1141 9.74138 22.9661 8.33738 23.0261C6.87338 23.0741 5.76938 21.5621 4.83338 20.2181C2.92538 17.4581 1.47338 12.4421 3.42938 9.0461C4.40138 7.3541 6.12938 6.2861 8.01338 6.2621C9.44138 6.2261 10.7974 7.2221 11.6734 7.2221C12.5374 7.2221 14.0854 6.0701 15.9334 6.2141ZM14.7934 4.3901C14.0134 5.3261 12.7414 6.0581 11.5054 5.9621C11.3374 4.6901 11.9614 3.3581 12.6814 2.5301C13.4854 1.5941 14.8294 0.898098 15.9454 0.850098C16.0894 2.1461 15.5734 3.4541 14.7934 4.3901Z"></path>
                                        </svg>
                                    </div>
                                    <MudText Class="whitespace-nowrap">Sign in with Apple</MudText>
                                </button>
                }
            </div>

            <div class="flex items-center mb-7">
                <div class="w-full h-[2px] bg-black/10 dark:bg-darkborder"></div>
                <div class="px-4 text-muted whitespace-nowrap dark:text-darkmuted">o</div>
                <div class="w-full h-[2px] bg-black/10 dark:bg-darkborder"></div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">
                @ErrorMessage
            </div>
        }

        <EditForm Model="@LoginModel" OnValidSubmit="@LoginAsync">
            <div class="space-y-4">
                <div>
                    <InputText @bind-Value="LoginModel.Email" placeholder="Email" class="form-input" />
                </div>

                <div style="position:relative;">
                    <InputText id="userPanelPassword" @bind-Value="LoginModel.Password" placeholder="Password" type="password" class="form-input" style="padding-right:44px;" />
                    <button type="button" onclick="const i=document.getElementById('userPanelPassword'); const isPw=i.type==='password'; i.type=isPw?'text':'password'; this.querySelector('i').className=isPw?'ri-eye-line':'ri-eye-off-line';" class="text-black/50 dark:text-white/60" style="position:absolute; top:50%; right:12px; transform:translateY(-50%); background:none; border:none; padding:0; cursor:pointer;">
                        <i class="ri-eye-off-line"></i>
                    </button>
                </div>

                <div class="ltr:text-right rtl:text-left">
                    <MudLink Href="/user-panel/forgot-password" Class="text-black dark:text-white">Forgot Password?</MudLink>
                </div>

                <button type="submit" disabled="@IsLoading" class="btn w-full py-3.5 text-base bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85]">
                    @(IsLoading ? "Signing in..." : "Sign In")
                </button>
            </div>
        </EditForm>

        <MudText Class="mt-5 text-center text-muted dark:text-darkmuted">Your account is created automatically when you register for the festival.</MudText>
    </div>
</div>
<!-- End Main Content -->

<script>
    window.externalAuth = {
        dotNetRef: null,
        googleClientId: null,
        appleClientId: null,
        appleRedirectUri: null,
        loadedScripts: {},

        init(dotNetRef, googleClientId, appleClientId, appleRedirectUri) {
            this.dotNetRef = dotNetRef;
            this.googleClientId = googleClientId;
            this.appleClientId = appleClientId;
            this.appleRedirectUri = appleRedirectUri;
        },

        loadScript(src) {
            if (this.loadedScripts[src]) {
                return this.loadedScripts[src];
            }

            this.loadedScripts[src] = new Promise((resolve, reject) => {
                const script = document.createElement('script');
                script.src = src;
                script.async = true;
                script.onload = () => resolve();
                script.onerror = () => reject(new Error('Failed to load ' + src));
                document.head.appendChild(script);
            });

            return this.loadedScripts[src];
        },

        reportError(message) {
            if (this.dotNetRef) {
                this.dotNetRef.invokeMethodAsync('OnExternalErrorAsync', message);
            }
        },

        reportToken(provider, token) {
            if (this.dotNetRef) {
                this.dotNetRef.invokeMethodAsync('OnExternalTokenAsync', provider, token);
            }
        },

        async signInWithGoogle() {
            if (!this.googleClientId) {
                this.reportError('Google sign-in is not configured.');
                return;
            }

            try {
                await this.loadScript('https://accounts.google.com/gsi/client');

                const self = this;
                const client = google.accounts.oauth2.initTokenClient({
                    client_id: this.googleClientId,
                    scope: 'openid email profile',
                    callback: (response) => {
                        if (response && response.access_token) {
                            self.reportToken('google', response.access_token);
                        } else {
                            self.reportError('Google sign-in was cancelled.');
                        }
                    },
                    error_callback: () => self.reportError('Google sign-in was cancelled.')
                });

                client.requestAccessToken();
            } catch (e) {
                this.reportError('Google sign-in failed to start.');
            }
        },

        async signInWithApple() {
            if (!this.appleClientId) {
                this.reportError('Apple sign-in is not configured.');
                return;
            }

            try {
                await this.loadScript('https://appleid.cdn-apple.com/appleauth/static/jsapi/appleid/1/en_US/appleid.auth.js');

                AppleID.auth.init({
                    clientId: this.appleClientId,
                    scope: 'email',
                    redirectURI: this.appleRedirectUri || (window.location.origin + '/user-panel/login'),
                    usePopup: true
                });

                const result = await AppleID.auth.signIn();
                const idToken = result && result.authorization ? result.authorization.id_token : null;

                if (idToken) {
                    this.reportToken('apple', idToken);
                } else {
                    this.reportError('Apple sign-in was cancelled.');
                }
            } catch (e) {
                this.reportError('Apple sign-in was cancelled.');
            }
        }
    };
</script>

@code {
    private LoginRequest LoginModel { get; set; } = new();

    private bool IsLoading { get; set; }

    private string? ErrorMessage { get; set; }

    private bool HasGoogleLogin => !string.IsNullOrWhiteSpace(Configuration["ExternalAuth:GoogleClientId"]);

    private bool HasAppleLogin => !string.IsNullOrWhiteSpace(Configuration["ExternalAuth:AppleClientId"]);

    private DotNetObjectReference<Login>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);

            await JsRuntime.InvokeVoidAsync("externalAuth.init", _dotNetRef,
                Configuration["ExternalAuth:GoogleClientId"],
                Configuration["ExternalAuth:AppleClientId"],
                Configuration["ExternalAuth:AppleRedirectUri"]);
        }
    }

    private async Task SignInWithGoogleAsync()
    {
        ErrorMessage = null;
        await JsRuntime.InvokeVoidAsync("externalAuth.signInWithGoogle");
    }

    private async Task SignInWithAppleAsync()
    {
        ErrorMessage = null;
        await JsRuntime.InvokeVoidAsync("externalAuth.signInWithApple");
    }

    [JSInvokable]
    public async Task OnExternalTokenAsync(string provider, string token)
    {
        ErrorMessage = null;
        IsLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            ExternalLoginRequest request = new() { Provider = provider, Token = token };
            LoginResponse? response = await AuthApiClient.ExternalLoginAsync(request);

            if (response is null || response.Auth is null || string.IsNullOrWhiteSpace(response.Auth.AccessToken))
            {
                ErrorMessage = "External sign-in failed.";
                return;
            }

            await TokenStorageService.SetTokenAsync(response.Auth.AccessToken);

            string lang = response.Language ?? "en";
            Navigation.NavigateTo($"/user-panel/dashboard/{lang}", true);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public async Task OnExternalErrorAsync(string message)
    {
        ErrorMessage = message;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoginAsync()
    {
        ErrorMessage = null;
        IsLoading = true;

        try
        {
            LoginResponse? response = await AuthApiClient.LoginAsync(LoginModel);

            if (response is null || response.Auth is null || string.IsNullOrWhiteSpace(response.Auth.AccessToken))
            {
                ErrorMessage = "Invalid email or password.";
                return;
            }

            await TokenStorageService.SetTokenAsync(response.Auth.AccessToken);

            string lang = response.Language ?? "en";
            Navigation.NavigateTo($"/user-panel/dashboard/{lang}", true);
        }
        catch (Exception ex)
        {
            ErrorMessage = "Invalid email or password.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    public ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();

        return ValueTask.CompletedTask;
    }
}
