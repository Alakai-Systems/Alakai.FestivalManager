@page "/user-panel/forgot-password"
@layout AuthLayout

@using Alakai.FestivalManager.Admin.Components.Layout
@using Alakai.FestivalManager.Admin.Services.Auth

@inject IAuthApiClient AuthApiClient

<!-- Start Main Content -->
<div class="min-h-[calc(100vh-134px)] py-4 px-4 sm:px-12 flex justify-center items-center max-w-[1440px] mx-auto bg-light/60 dark:bg-dark">
    <div class="max-w-[550px] flex-none w-full bg-white border border-black/10 p-6 sm:p-10 lg:px-10 lg:py-14 rounded-2xl shadow-3xl shadow-black/10 dark:bg-darklight dark:border-darkborder">
        <MudText Typo="Typo.h1" Class="mb-2 text-2xl font-semibold text-center dark:text-white">Forgot your password?</MudText>
        <MudText Class="text-center text-muted mb-7 dark:text-darkmuted">Enter your Email and instructions will be sent to you!</MudText>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="p-3 mb-4 text-sm rounded bg-success/10 text-success">
                @Message
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="p-3 mb-4 text-sm rounded bg-danger/10 text-danger">
                @ErrorMessage
            </div>
        }

        <EditForm Model="@ForgotPasswordModel" OnValidSubmit="@SendAsync">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="sm:col-span-2">
                    <InputText @bind-Value="ForgotPasswordModel.Email" placeholder="Email" class="form-input" />
                </div>

                <button type="submit" disabled="@IsLoading" class="btn sm:col-span-2 w-full py-3.5 text-base bg-purple border-purple text-white hover:bg-purple/[0.85] hover:border-purple/[0.85] disabled:opacity-70">
                    @(IsLoading ? "Sending..." : "Email password reset link")
                </button>
            </div>
        </EditForm>

        <MudText Class="mt-5 text-center">
            <MudLink Href="/user-panel/login" Class="flex items-center justify-center gap-1 leading-none text-black dark:text-white">
                <span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="inline-block size-5">
                        <path fill="currentColor" d="M19 21.0001H5C4.44772 21.0001 4 20.5524 4 20.0001V11.0001L1 11.0001L11.3273 1.61162C11.7087 1.26488 12.2913 1.26488 12.6727 1.61162L23 11.0001L20 11.0001V20.0001C20 20.5524 19.5523 21.0001 19 21.0001ZM6 19.0001H18V9.15757L12 3.70302L6 9.15757V19.0001ZM8 15.0001H16V17.0001H8V15.0001Z"></path>
                    </svg>
                </span>
                Back to login
            </MudLink>
        </MudText>
    </div>
</div>
<!-- End Main Content -->
@code {
    private ForgotPasswordFormModel ForgotPasswordModel { get; set; } = new();

    private bool IsLoading { get; set; }

    private string? Message { get; set; }

    private string? ErrorMessage { get; set; }

    private async Task SendAsync()
    {
        Message = null;
        ErrorMessage = null;
        IsLoading = true;

        try
        {
            await AuthApiClient.ForgotPasswordAsync(ForgotPasswordModel.Email);

            Message = "If the account exists, a reset email has been generated.";
        }
        catch
        {
            ErrorMessage = "The reset email could not be generated.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private class ForgotPasswordFormModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
