@using Radzen
@using Radzen.Blazor
@inject UploadsApiClient UploadsApiClient
@inject IJSRuntime JsRuntime
@inject ActiveFestivalState ActiveFestivalState

<div class="email-rte-wrapper">
    <RadzenHtmlEditor @ref="EditorRef"
                      @bind-Value="Value"
                      Change="@OnEditorChange"
                      style="height: 320px;">
        <RadzenHtmlEditorUndo />
        <RadzenHtmlEditorRedo />
        <RadzenHtmlEditorSeparator />
        <RadzenHtmlEditorBold />
        <RadzenHtmlEditorItalic />
        <RadzenHtmlEditorUnderline />
        <RadzenHtmlEditorStrikeThrough />
        <RadzenHtmlEditorSubscript />
        <RadzenHtmlEditorSuperscript />
        <RadzenHtmlEditorSeparator />
        <RadzenHtmlEditorColor />
        <RadzenHtmlEditorBackground />
        <RadzenHtmlEditorSeparator />
        <RadzenHtmlEditorFormatBlock />
        <RadzenHtmlEditorFontName />
        <RadzenHtmlEditorFontSize />
        <RadzenHtmlEditorSeparator />
        <RadzenHtmlEditorAlignLeft />
        <RadzenHtmlEditorAlignCenter />
        <RadzenHtmlEditorAlignRight />
        <RadzenHtmlEditorJustify />
        <RadzenHtmlEditorSeparator />
        <RadzenHtmlEditorOrderedList />
        <RadzenHtmlEditorUnorderedList />
        <RadzenHtmlEditorIndent />
        <RadzenHtmlEditorOutdent />
        <RadzenHtmlEditorSeparator />
        <RadzenHtmlEditorLink />
        <RadzenHtmlEditorUnlink />
        <RadzenHtmlEditorTable />
        <RadzenHtmlEditorSeparator />
        <RadzenHtmlEditorSource />
        <RadzenHtmlEditorRemoveFormat />
    </RadzenHtmlEditor>

    <div class="email-rte-upload">
        <label class="email-rte-width-label">
            Width (px):
            <input type="number" min="10" max="2000" class="email-rte-width-input" @bind="UploadImageWidth" />
        </label>
        <InputFile OnChange="@OnImageSelectedAsync" accept="image/png,image/jpeg,image/gif,image/webp" style="display:none;" id="@UploadInputId" />
        <label for="@UploadInputId" class="email-rte-upload-button">
            @(IsUploadingImage ? "Uploading..." : "📷 Upload image")
        </label>
        <button type="button" class="email-rte-upload-button" @onclick="ToggleGalleryAsync">
            🖼️ Choose from gallery
        </button>
    </div>

    @if (ShowGallery)
    {
        <div class="email-rte-gallery">
            @if (GalleryImages is null)
            {
                <p>Loading...</p>
            }
            else if (GalleryImages.Count == 0)
            {
                <p>No images uploaded yet for this festival.</p>
            }
            else
            {
                @foreach (GalleryImageDto image in GalleryImages)
                {
                    <div class="email-rte-gallery-item-wrapper">
                        <button type="button" class="email-rte-gallery-item" @onclick="() => InsertFromGalleryAsync(image)" title="@($"{image.Width}x{image.Height}")">
                            <img src="@image.Url" alt="" />
                        </button>
                        <button type="button" class="email-rte-gallery-delete" title="Delete" @onclick="() => DeleteGalleryImageAsync(image)" @onclick:stopPropagation="true">
                            <i class="ri-close-circle-fill"></i>
                        </button>
                    </div>
                }
            }
        </div>
    }

    @if (Variables is { Count: > 0 })
    {
        <div class="email-rte-variables">
            <span class="email-rte-variables-label">Variables:</span>
            @foreach (var variable in Variables)
            {
                <button type="button"
                        class="email-rte-variable-chip"
                        @onclick="() => InsertVariableAsync(variable)">
                    {{@variable}}
                </button>
            }
        </div>
    }
</div>

<style>
    /* Only styling MY OWN markup (the variable chips below the editor).
           Deliberately not touching any .rz-* class — Radzen's own CSS already
           lays the toolbar out horizontally and positions popups correctly;
           overriding it caused all the layout breakage we saw earlier. */
    .email-rte-upload {
        margin-top: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .email-rte-width-label {
        font-size: 0.8rem;
        color: #374151;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .email-rte-width-input {
        width: 70px;
        padding: 4px 6px;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: 0.8rem;
    }

    .email-rte-gallery {
        margin-top: 10px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
        gap: 8px;
        max-height: 260px;
        overflow-y: auto;
        padding: 10px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
    }

    .email-rte-gallery-item {
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        padding: 0;
        overflow: hidden;
        background: none;
        cursor: pointer;
        aspect-ratio: 1;
    }

    .email-rte-gallery-item:hover {
        border-color: #6D28D9;
    }

    .email-rte-gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .email-rte-gallery-item-wrapper {
        position: relative;
    }

    .email-rte-gallery-delete {
        position: absolute;
        top: -6px;
        right: -6px;
        background: #fff;
        border-radius: 9999px;
        color: #f1416c;
        font-size: 18px;
        line-height: 1;
        border: none;
        cursor: pointer;
    }

    .email-rte-upload-button {
        display: inline-block;
        background: #f3f4f6;
        color: #374151;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: 0.8rem;
        padding: 5px 12px;
        cursor: pointer;
    }

        .email-rte-upload-button:hover {
            background: #e5e7eb;
        }

    .email-rte-variables {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        align-items: center;
    }

    .email-rte-variables-label {
        font-size: 0.8rem;
        color: #6b7280;
        margin-right: 4px;
    }

    .email-rte-variable-chip {
        background: #eef2ff;
        color: #4338ca;
        border: 1px solid #c7d2fe;
        border-radius: 999px;
        font-size: 0.78rem;
        padding: 2px 10px;
        cursor: pointer;
        transition: background 0.15s ease;
    }

        .email-rte-variable-chip:hover {
            background: #e0e7ff;
        }
</style>

<script>
    window.getImageDimensions = window.getImageDimensions || function (url) {
        return new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = () => resolve({ width: img.naturalWidth, height: img.naturalHeight });
            img.onerror = reject;
            img.src = url;
        });
    };
</script>

@code {
    private class ImageDimensions
    {
        public int Width { get; set; }
        public int Height { get; set; }
    }

    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public List<string>? Variables { get; set; }
    [Parameter] public int InitialWidth { get; set; } = 600;
    [Parameter] public EventCallback<int> WidthChanged { get; set; }

    private RadzenHtmlEditor EditorRef { get; set; } = default!;
    private bool IsUploadingImage { get; set; }
    private readonly string UploadInputId = $"email-rte-upload-{Guid.NewGuid():N}";
    public int UploadImageWidth { get; set; } = 600;
    private bool _widthInitializedFromParameter;

    protected override void OnParametersSet()
    {
        if (!_widthInitializedFromParameter)
        {
            UploadImageWidth = InitialWidth;
            _widthInitializedFromParameter = true;
        }
    }

    private bool ShowGallery { get; set; }
    private List<GalleryImageDto>? GalleryImages { get; set; }

    private async Task ToggleGalleryAsync()
    {
        ShowGallery = !ShowGallery;

        if (ShowGallery && ActiveFestivalState.Active is not null)
        {
            GalleryImages = null;
            GalleryImages = await UploadsApiClient.GetGalleryAsync(ActiveFestivalState.Active.Id);
        }
    }

    private async Task InsertFromGalleryAsync(GalleryImageDto image)
    {
        await EditorRef.ExecuteCommandAsync(HtmlEditorCommands.InsertHtml,
            $"<img src=\"{image.Url}\" style=\"max-width:100%; width:{image.Width}px; height:auto; display:block;\" />");

        ShowGallery = false;
    }

    private async Task DeleteGalleryImageAsync(GalleryImageDto image)
    {
        await UploadsApiClient.DeleteGalleryImageAsync(image.Id);

        if (GalleryImages is not null)
        {
            GalleryImages.Remove(image);
        }
    }

    private async Task OnEditorChange(string html)
    {
        Value = html;
        await ValueChanged.InvokeAsync(html);
    }

    private async Task InsertVariableAsync(string variable)
    {
        if (EditorRef is null)
        {
            return;
        }

        await EditorRef.ExecuteCommandAsync(HtmlEditorCommands.InsertHtml, $"{{{{{variable}}}}}");
    }

    private async Task OnImageSelectedAsync(InputFileChangeEventArgs e)
    {
        if (EditorRef is null || IsUploadingImage)
        {
            return;
        }

        const long maxFileSize = 5 * 1024 * 1024; // 5 MB, debe coincidir con el límite del backend

        IsUploadingImage = true;

        try
        {
            using Stream stream = e.File.OpenReadStream(maxFileSize);
            UploadImageDetailResult uploaded = await UploadsApiClient.UploadImageWithDetailsAsync(
                stream, e.File.Name, e.File.ContentType, ActiveFestivalState.Active?.Id, UploadImageWidth);

            await EditorRef.ExecuteCommandAsync(HtmlEditorCommands.InsertHtml,
                $"<img src=\"{uploaded.Url}\" style=\"max-width:100%; width:{uploaded.Width}px; height:auto; display:block;\" />");

            await WidthChanged.InvokeAsync(UploadImageWidth);
        }
        finally
        {
            IsUploadingImage = false;
        }
    }

    /// <summary>
    /// Converts the current HTML value into a reasonably clean plain-text version,
    /// suitable for populating BodyText for email clients that don't render HTML.
    /// </summary>
    public static string ConvertHtmlToPlainText(string html)
    {
        if (string.IsNullOrWhiteSpace(html))
        {
            return string.Empty;
        }

        string text = html;

        text = System.Text.RegularExpressions.Regex.Replace(text, @"(?i)<\s*br\s*/?>", "\n");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"(?i)</\s*p\s*>", "\n");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"(?i)</\s*div\s*>", "\n");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"(?i)</\s*li\s*>", "\n");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"(?i)</\s*h[1-6]\s*>", "\n\n");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"(?i)<\s*li[^>]*>", "- ");
        text = System.Text.RegularExpressions.Regex.Replace(text, "<[^>]+>", string.Empty);
        text = System.Net.WebUtility.HtmlDecode(text);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"[ \t]+\n", "\n");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\n{3,}", "\n\n");

        return text.Trim();
    }
}
