@implements IDisposable
@inject ActiveFestivalState ActiveFestivalState

<!-- Start Sidebar -->
<nav class="sidebar lg:z-[9] z-[10]" x-on:click="if ($event.target.closest('a') && window.innerWidth < 1024 && $store.app.sidebar) { $store.app.toggleSidebar() }">
    <div class="h-full bg-white dark:bg-darklight group-data-[sidebar=dark]/item:bg-darklight group-data-[sidebar=brand]/item:bg-sky-950">
        <div class="p-4">
            <NavLink href="/" class="w-full main-logo flex items-center justify-center py-2">
                @if (!string.IsNullOrWhiteSpace(ActiveFestivalState.Active?.LogoUrl))
                {
                    <img src="@ActiveFestivalState.Active.LogoUrl" alt="@ActiveFestivalState.Active.Name" class="max-h-10 max-w-[160px] object-contain" />
                }
                else
                {
                    <span class="block mx-auto text-xl font-bold tracking-wide text-center text-black dark:text-white group-data-[sidebar=brand]/item:text-white">ALAKAI</span>
                }
            </NavLink>
        </div>

        <div class="h-[calc(100vh-60px)] overflow-y-auto overflow-x-hidden px-5 pb-4 space-y-6 detached-menu">
            <ul class="relative flex flex-col gap-1" x-data="{ activeMenu: 'eventSetup' }">
                <li class="menu-title">
                    <span class="text-xs text-black/40 dark:text-white/30">Menu</span>
                </li>

                <li class="menu nav-item">
                    <NavLink href="/" Match="NavLinkMatch.All" class="text-black nav-link group">
                        <div class="flex items-center">
                            <i class="ri-dashboard-fill"></i>
                            <span class="ltr:pl-1.5 rtl:pr-1.5">Dashboard</span>
                        </div>
                    </NavLink>
                </li>

                <li class="menu nav-item">
                    <a href="javascript:;" class="items-center justify-between text-black nav-link group" x-bind:class="{ 'active': activeMenu === 'eventSetup' }" x-on:click="activeMenu === 'eventSetup' ? activeMenu = null : activeMenu = 'eventSetup'">
                        <div class="flex items-center">
                            <i class="ri-settings-3-fill"></i>
                            <span class="ltr:pl-1.5 rtl:pr-1.5">Event Setup</span>
                        </div>
                        <i class="ri-arrow-down-s-line text-lg dropdown-icon" x-bind:class="{ '!rotate-180': activeMenu === 'eventSetup' }"></i>
                    </a>

                    <ul x-show="activeMenu === 'eventSetup'" x-collapse class="flex flex-col gap-1 text-black sub-menu dark:text-white/60 group-data-[sidebar=dark]/item:text-white/60 group-data-[sidebar=brand]/item:text-sky-200/50">
                        <li><NavLink href="/festivals">Festivals</NavLink></li>
                        <li><NavLink href="/editions">Editions</NavLink></li>
                        <li><NavLink href="/pass-types">Pass Types</NavLink></li>
                        <li><NavLink href="/levels">Levels</NavLink></li>
                        <li><NavLink href="/discount-codes">Discount Codes</NavLink></li>
                        <li><NavLink href="/competitions">Competitions</NavLink></li>
                        @if (ActiveFestivalState.HasModule(FestivalModule.Accommodation))
                        {
                            <li><NavLink href="/accommodation-buildings">Accommodation</NavLink></li>
                        }
                        @if (ActiveFestivalState.HasModule(FestivalModule.Transport))
                        {
                            <li><NavLink href="/buses">Buses</NavLink></li>
                        }
                    </ul>
                </li>

                <li class="menu nav-item">
                    <a href="javascript:;" class="items-center justify-between text-black nav-link group" x-bind:class="{ 'active': activeMenu === 'operations' }" x-on:click="activeMenu === 'operations' ? activeMenu = null : activeMenu = 'operations'">
                        <div class="flex items-center">
                            <i class="ri-apps-2-fill"></i>
                            <span class="ltr:pl-1.5 rtl:pr-1.5">Operations</span>
                        </div>
                        <i class="ri-arrow-down-s-line text-lg dropdown-icon" x-bind:class="{ '!rotate-180': activeMenu === 'operations' }"></i>
                    </a>

                    <ul x-show="activeMenu === 'operations'" x-collapse class="flex flex-col gap-1 text-black sub-menu dark:text-white/60 group-data-[sidebar=dark]/item:text-white/60 group-data-[sidebar=brand]/item:text-sky-200/50">
                        <li><NavLink href="/users">Users</NavLink></li>
                        <li><NavLink href="/registrations">Registrations</NavLink></li>
                        <li><NavLink href="/competition-entries">Competition Entries</NavLink></li>
                        @if (ActiveFestivalState.HasModule(FestivalModule.Accommodation))
                        {
                            <li><NavLink href="/accommodation-operations">Accommodation</NavLink></li>
                        }
                        @if (ActiveFestivalState.HasModule(FestivalModule.Transport))
                        {
                            <li><NavLink href="/bus-operations">Buses</NavLink></li>
                        }
                        @if (ActiveFestivalState.HasModule(FestivalModule.Meals))
                        {
                            <li><NavLink href="/meal-operations">Meals</NavLink></li>
                        }
                        <li><NavLink href="/invoices">Invoices</NavLink></li>
                    </ul>
                </li>

                <li class="menu nav-item">
                    <a href="javascript:;" class="items-center justify-between text-black nav-link group" x-bind:class="{ 'active': activeMenu === 'communication' }" x-on:click="activeMenu === 'communication' ? activeMenu = null : activeMenu = 'communication'">
                        <div class="flex items-center">
                            <i class="ri-mail-settings-fill"></i>
                            <span class="ltr:pl-1.5 rtl:pr-1.5">Communication</span>
                        </div>
                        <i class="ri-arrow-down-s-line text-lg dropdown-icon" x-bind:class="{ '!rotate-180': activeMenu === 'communication' }"></i>
                    </a>

                    <ul x-show="activeMenu === 'communication'" x-collapse class="flex flex-col gap-1 text-black sub-menu dark:text-white/60 group-data-[sidebar=dark]/item:text-white/60 group-data-[sidebar=brand]/item:text-sky-200/50">
                        <li><NavLink href="/emails">Email Templates</NavLink></li>
                        <li><NavLink href="/email-logs">Email Logs</NavLink></li>
                        <li><NavLink href="/email-layout">Header &amp; Footer</NavLink></li>
                    </ul>
                </li>

                <li class="menu nav-item">
                    <a href="javascript:;" class="items-center justify-between text-black nav-link group" x-bind:class="{ 'active': activeMenu === 'settings' }" x-on:click="activeMenu === 'settings' ? activeMenu = null : activeMenu = 'settings'">
                        <div class="flex items-center">
                            <i class="ri-equalizer-fill"></i>
                            <span class="ltr:pl-1.5 rtl:pr-1.5">Settings</span>
                        </div>
                        <i class="ri-arrow-down-s-line text-lg dropdown-icon" x-bind:class="{ '!rotate-180': activeMenu === 'settings' }"></i>
                    </a>

                    <ul x-show="activeMenu === 'settings'" x-collapse class="flex flex-col gap-1 text-black sub-menu dark:text-white/60 group-data-[sidebar=dark]/item:text-white/60 group-data-[sidebar=brand]/item:text-sky-200/50">
                        <li><NavLink href="/settings" Match="NavLinkMatch.All">Admin Users</NavLink></li>
                        <li><NavLink href="/settings/invoice-templates">Invoice Templates</NavLink></li>
                    </ul>
                </li>
                <li class="menu nav-item">
                    <NavLink href="/reports" class="text-black nav-link group">
                        <div class="flex items-center">
                            <i class="ri-file-download-fill"></i>
                            <span class="ltr:pl-1.5 rtl:pr-1.5">Reports</span>
                        </div>
                    </NavLink>
                </li>
            </ul>
        </div>
    </div>
</nav>
<!-- End Sidebar -->

@code {
    protected override void OnInitialized()
    {
        ActiveFestivalState.OnChange += HandleFestivalChanged;
    }

    private void HandleFestivalChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ActiveFestivalState.OnChange -= HandleFestivalChanged;
    }
}