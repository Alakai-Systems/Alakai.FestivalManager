@using Radzen.Blazor
@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JsRuntime
@inject ActiveFestivalState ActiveFestivalState

<AuthorizeView Policy="AdminAccess">
    <Authorized>
        <div class="bg-[#f9fbfd] dark:bg-dark">
            <div class="bg-black min-h-[220px] sm:min-h-[250px] bg-bottom fixed hidden w-full -z-50 detached-img" style="background-image: url('assets/images/bg-main.png');"></div>

            <div x-cloak class="fixed inset-0 bg-black/60 dark:bg-dark/90 z-[999] lg:hidden" x-bind:class="{ 'hidden': !$store.app.sidebar }" x-on:click="$store.app.toggleSidebar()"></div>

            <div class="flex mx-auto main-container">
                <Sidebar />

                <div class="flex-1 main-content min-w-0">
                    <Topbar />

                    <div class="h-[calc(100vh-60px)] relative overflow-y-auto overflow-x-hidden p-4 space-y-4 detached-content min-w-0">
                        @Body
                        <Footer />
                    </div>
                </div>
            </div>
        </div>

        <RadzenComponents />
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

<script>
    window.setFavicon = window.setFavicon || function (url) {
        document.querySelectorAll("link[rel~='icon']").forEach(el => el.remove());
        const link = document.createElement('link');
        link.rel = 'icon';
        link.href = url;
        document.head.appendChild(link);
    };

    window.setPageTitle = window.setPageTitle || function (title) {
        document.title = title;
    };
</script>

@code {
    protected override void OnInitialized()
    {
        ActiveFestivalState.OnChange += OnActiveFestivalChanged;
        UpdateFaviconAsync();
    }

    private void OnActiveFestivalChanged()
    {
        UpdateFaviconAsync();
        InvokeAsync(StateHasChanged);
    }

    private async void UpdateFaviconAsync()
    {
        string? url = ActiveFestivalState.Active?.FaviconUrl;
        string? name = ActiveFestivalState.Active?.Name;

        try
        {
            if (!string.IsNullOrWhiteSpace(url))
            {
                await JsRuntime.InvokeVoidAsync("setFavicon", url);
            }

            if (!string.IsNullOrWhiteSpace(name))
            {
                await JsRuntime.InvokeVoidAsync("setPageTitle", $"{name} - Alakai Festival Manager");
            }
        }
        catch
        {
            // Si falla (por ejemplo, durante el prerenderizado antes de tener JS disponible),
            // simplemente se mantiene el favicon/titulo actual - no es critico.
        }
    }

    public void Dispose()
    {
        ActiveFestivalState.OnChange -= OnActiveFestivalChanged;
    }
}